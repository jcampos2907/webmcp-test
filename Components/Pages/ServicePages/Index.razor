@page "/services"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "SuperAdmin,Admin")]
@using Microsoft.AspNetCore.Components.QuickGrid
@using Microsoft.EntityFrameworkCore
@using BikePOS.Models
@using BikePOS.Data
@implements IAsyncDisposable
@inject IDbContextFactory<BikePOS.Data.BikePosContext> DbFactory
@inject NavigationManager NavigationManager
@inject I18nText I18nText

<PageTitle>@L.Services_Title</PageTitle>

<h1>@L.Services_Title</h1>

<p>
    <a href="services/create">@L.Common_CreateNew</a>
</p>

<QuickGrid Class="table" Items="context.Service">
    <PropertyColumn Property="service => service.Name" />
    <PropertyColumn Property="service => service.Description" />
    <PropertyColumn Property="service => service.DefaultPrice" />
    <PropertyColumn Property="service => service.EstimatedMinutes" />

    <TemplateColumn Context="service">
        <a href="@($"services/edit?id={service.Id}")">@L.Common_Edit</a> |
        <a href="@($"services/details?id={service.Id}")">@L.Common_Details</a> |
        <a href="@($"services/delete?id={service.Id}")">@L.Common_Delete</a>
    </TemplateColumn>
</QuickGrid>

@code {
    Text L = new();

    protected override async Task OnInitializedAsync()
    {
        L = await I18nText.GetTextTableAsync<Text>(this);
    }
    private BikePosContext context = default!;

    protected override void OnInitialized()
    {
        context = DbFactory.CreateDbContext();
    }

    public async ValueTask DisposeAsync() => await context.DisposeAsync();
}
