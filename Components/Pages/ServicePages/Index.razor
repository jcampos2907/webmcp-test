@page "/services"
@using Microsoft.AspNetCore.Components.QuickGrid
@using Microsoft.EntityFrameworkCore
@using BikePOS.Models
@using BikePOS.Data
@implements IAsyncDisposable
@inject IDbContextFactory<BikePOS.Data.BikePosContext> DbFactory
@inject NavigationManager NavigationManager
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Services.Title"]</PageTitle>

<h1>@L["Services.Title"]</h1>

<p>
    <a href="services/create">@L["Common.CreateNew"]</a>
</p>

<QuickGrid Class="table" Items="context.Service">
    <PropertyColumn Property="service => service.Name" />
    <PropertyColumn Property="service => service.Description" />
    <PropertyColumn Property="service => service.DefaultPrice" />
    <PropertyColumn Property="service => service.EstimatedMinutes" />

    <TemplateColumn Context="service">
        <a href="@($"services/edit?id={service.Id}")">@L["Common.Edit"]</a> |
        <a href="@($"services/details?id={service.Id}")">@L["Common.Details"]</a> |
        <a href="@($"services/delete?id={service.Id}")">@L["Common.Delete"]</a>
    </TemplateColumn>
</QuickGrid>

@code {
    private BikePosContext context = default!;

    protected override void OnInitialized()
    {
        context = DbFactory.CreateDbContext();
    }

    public async ValueTask DisposeAsync() => await context.DisposeAsync();
}
