@page "/services/edit"
@using Microsoft.EntityFrameworkCore
@using BikePOS.Models
@inject IDbContextFactory<BikePOS.Data.BikePosContext> DbFactory
@inject NavigationManager NavigationManager
@inject I18nText I18nText

<PageTitle>@L.Services_Edit</PageTitle>

<h1>@L.Common_Edit</h1>

<h2>@L.Services_Entity</h2>
<hr />
@if (Service is null)
{
    <p><em>@L.Common_Loading</em></p>
}
else
{
    <div class="row">
        <div class="col-md-4">
            <EditForm method="post" Model="Service" OnValidSubmit="UpdateService" FormName="edit" Enhance>
                <DataAnnotationsValidator />
                <ValidationSummary role="alert"/>
                <input type="hidden" name="Service.Id" value="@Service.Id" />
                <div class="mb-3">
                <span class="text-danger">*</span>
                    <label for="name" class="form-label">@L.Common_Name:</label>
                    <InputText id="name" @bind-Value="Service.Name" class="form-control" aria-required="true"/>
                    <ValidationMessage For="() => Service.Name" class="text-danger" />
                </div>
                <div class="mb-3">
                    <label for="description" class="form-label">@L.Common_Description:</label>
                    <InputText id="description" @bind-Value="Service.Description" class="form-control" />
                    <ValidationMessage For="() => Service.Description" class="text-danger" />
                </div>
                <div class="mb-3">
                    <label for="defaultprice" class="form-label">@L.Common_DefaultPrice:</label>
                    <InputNumber id="defaultprice" @bind-Value="Service.DefaultPrice" class="form-control" />
                    <ValidationMessage For="() => Service.DefaultPrice" class="text-danger" />
                </div>
                <div class="mb-3">
                    <label for="estimatedminutes" class="form-label">@L.Common_EstimatedMinutes:</label>
                    <InputNumber id="estimatedminutes" @bind-Value="Service.EstimatedMinutes" class="form-control" />
                    <ValidationMessage For="() => Service.EstimatedMinutes" class="text-danger" />
                </div>
                <button type="submit" class="btn btn-primary">@L.Common_Save</button>
            </EditForm>
        </div>
    </div>
}

<div>
    <a href="/services">@L.Common_BackToList</a>
</div>

@code {
    Text L = new();
    [SupplyParameterFromQuery]
    private int Id { get; set; }

    [SupplyParameterFromForm]
    private Service? Service { get; set; }

    protected override async Task OnInitializedAsync()
    {
        L = await I18nText.GetTextTableAsync<Text>(this);
        using var context = DbFactory.CreateDbContext();
        Service ??= await context.Service.FirstOrDefaultAsync(m => m.Id == Id);

        if (Service is null)
        {
            NavigationManager.NotFound();
        }
    }

    // To protect from overposting attacks, enable the specific properties you want to bind to.
    // For more information, see https://learn.microsoft.com/aspnet/core/blazor/forms/#mitigate-overposting-attacks.
    private async Task UpdateService()
    {
        using var context = DbFactory.CreateDbContext();
        context.Attach(Service!).State = EntityState.Modified;

        try
        {
            await context.SaveChangesAsync();
        }
        catch (DbUpdateConcurrencyException)
        {
            if (!ServiceExists(Service!.Id))
            {
                NavigationManager.NotFound();
            }
            else
            {
                throw;
            }
        }

        NavigationManager.NavigateTo("/services");
    }

    private bool ServiceExists(int id)
    {
        using var context = DbFactory.CreateDbContext();
        return context.Service.Any(e => e.Id == id);
    }
}
