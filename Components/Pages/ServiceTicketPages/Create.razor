@page "/tickets/create"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using BikePOS.Models
@inject IDbContextFactory<BikePOS.Data.BikePosContext> DbFactory
@inject NavigationManager NavigationManager
@using BikePOS.Components.Pages.CustomerPages

<PageTitle>Crear Boleta de Servicio</PageTitle>

<div class="p-6 max-w-5xl mx-auto">

    @* Step indicator *@
    <div class="flex items-center gap-2 mb-6 text-sm text-gray-400">
        <span class="@(step >= 1 ? "text-indigo-600 font-semibold" : "")">1. Cliente</span>
        <span>&rsaquo;</span>
        <span class="@(step >= 2 ? "text-indigo-600 font-semibold" : "")">2. Bicicleta</span>
        <span>&rsaquo;</span>
        <span class="@(step >= 3 ? "text-indigo-600 font-semibold" : "")">3. Servicio</span>
        <span>&rsaquo;</span>
        <span class="@(step >= 4 ? "text-indigo-600 font-semibold" : "")">4. Resumen</span>
    </div>

    @* Create Customer Modal *@
    @if (showCreateCustomer)
    {
        <div style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); display: flex; align-items: center; justify-content: center; z-index: 9999;">
            <div style="background: white; border-radius: 12px; box-shadow: 0 25px 50px rgba(0,0,0,0.25); max-width: 672px; width: 100%; max-height: 90vh; overflow-y: auto; padding: 24px;">
                <CustomerForm OnSaved="HandleNewCustomerSaved" OnCancelled="() => showCreateCustomer = false" />
            </div>
        </div>
    }

    @* ==================== STEP 1: Select Customer ==================== *@
    @if (step == 1)
    {
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
            <div class="flex items-center justify-between mb-4">
                <div class="flex items-center gap-3 flex-1">
                    <input type="text" class="flex-1 border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300"
                           placeholder="Buscar Cliente..."
                           @bind="customerSearch" @bind:event="oninput" @onkeyup="SearchCustomers" />
                </div>
                <button class="ml-3 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors"
                        @onclick="() => showCreateCustomer = true">
                    Crear Cliente
                </button>
            </div>

            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b border-gray-200 text-left text-gray-500">
                        <th class="py-2 font-medium">Nombre</th>
                        <th class="py-2 font-medium">Teléfono</th>
                        <th class="py-2 font-medium">Email</th>
                        <th class="py-2"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var customer in customerResults)
                    {
                        <tr class="border-b border-gray-100 hover:bg-gray-50">
                            <td class="py-2 text-gray-800">@customer.FullName</td>
                            <td class="py-2 text-gray-500">@customer.Phone</td>
                            <td class="py-2 text-gray-500">@customer.Email</td>
                            <td class="py-2 text-right">
                                <button class="bg-white border border-gray-300 hover:bg-indigo-50 hover:border-indigo-300 text-sm px-3 py-1 rounded-md transition-colors"
                                        @onclick="() => SelectCustomer(customer)">Utilizar</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (!customerResults.Any() && !string.IsNullOrEmpty(customerSearch))
            {
                <p class="text-sm text-gray-400 mt-4 text-center">No se encontraron clientes</p>
            }
        </div>
    }

    @* ==================== STEP 2: Select Bike ==================== *@
    @if (step == 2)
    {
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
            <div class="flex items-center justify-between mb-4">
                <div class="flex items-center gap-3 flex-1">
                    <input type="text" class="flex-1 border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300"
                           placeholder="Buscar Bicicleta o Componente..."
                           @bind="bikeSearch" @bind:event="oninput" @onkeyup="SearchBikes" />
                </div>
                <button class="ml-3 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors"
                        @onclick="() => showCreateBike = true">
                    Crear Componente
                </button>
            </div>

            @if (showCreateBike)
            {
                <div class="bg-gray-50 rounded-lg p-4 mb-4 border border-gray-200">
                    <h4 class="text-sm font-semibold text-gray-700 mb-3">Nuevo Componente</h4>
                    <div class="grid grid-cols-2 gap-3">
                        <input type="text" class="border border-gray-300 rounded-lg px-3 py-2 text-sm" placeholder="Nombre" @bind="newBikeName" />
                        <input type="text" class="border border-gray-300 rounded-lg px-3 py-2 text-sm" placeholder="SKU (mayúsculas)" @bind="newBikeSku" />
                        <input type="text" class="border border-gray-300 rounded-lg px-3 py-2 text-sm" placeholder="Color" @bind="newBikeColor" />
                        <input type="text" class="border border-gray-300 rounded-lg px-3 py-2 text-sm" placeholder="Marca" @bind="newBikeBrand" />
                    </div>
                    <div class="flex gap-2 mt-3">
                        <button class="bg-indigo-600 hover:bg-indigo-700 text-white text-sm px-4 py-1.5 rounded-lg" @onclick="CreateBike">Guardar</button>
                        <button class="bg-gray-200 hover:bg-gray-300 text-gray-700 text-sm px-4 py-1.5 rounded-lg" @onclick="() => showCreateBike = false">Cancelar</button>
                    </div>
                </div>
            }

            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b border-gray-200 text-left text-gray-500">
                        <th class="py-2 font-medium">Nombre</th>
                        <th class="py-2 font-medium">SKU</th>
                        <th class="py-2 font-medium">Marca</th>
                        <th class="py-2 font-medium">Color</th>
                        <th class="py-2"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var bike in bikeResults)
                    {
                        <tr class="border-b border-gray-100 hover:bg-gray-50">
                            <td class="py-2 text-gray-800">@bike.Name</td>
                            <td class="py-2 text-gray-500">@bike.Sku</td>
                            <td class="py-2 text-gray-500">@bike.Brand</td>
                            <td class="py-2 text-gray-500">@bike.Color</td>
                            <td class="py-2 text-right">
                                <button class="bg-white border border-gray-300 hover:bg-indigo-50 hover:border-indigo-300 text-sm px-3 py-1 rounded-md transition-colors"
                                        @onclick="() => SelectBike(bike)">Utilizar</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (!bikeResults.Any() && !string.IsNullOrEmpty(bikeSearch))
            {
                <p class="text-sm text-gray-400 mt-4 text-center">No se encontraron bicicletas</p>
            }

            <div class="mt-4">
                <button class="text-sm text-gray-500 hover:text-gray-700" @onclick="() => step = 1">&larr; Volver</button>
            </div>
        </div>
    }

    @* ==================== STEP 3: Select Service ==================== *@
    @if (step == 3)
    {
        <div class="flex items-center gap-3 mb-4">
            <button class="text-sm text-gray-500 hover:text-gray-700" @onclick="() => step = 2">&larr; Volver</button>
            <input type="text" class="flex-1 border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300"
                   placeholder="Buscar servicio..." @bind="serviceSearch" @bind:event="oninput" />
        </div>

        <div class="grid grid-cols-3 gap-4">
            @foreach (var service in FilteredServices)
            {
                <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4 cursor-pointer hover:shadow-md hover:border-indigo-300 transition-all"
                     @onclick="() => SelectService(service)">
                    <div class="w-full h-24 bg-gray-100 rounded-lg mb-3 flex items-center justify-center">
                        <i class="fa-solid fa-gears text-gray-300 text-3xl"></i>
                    </div>
                    <p class="text-sm font-medium text-gray-800">@service.Name</p>
                    <p class="text-xs text-gray-500 mb-1">@(service.EstimatedMinutes.HasValue ? $"{service.EstimatedMinutes} min" : "")</p>
                    <p class="text-sm text-gray-800 font-semibold">@service.DefaultPrice.ToString("C")</p>
                </div>
            }
        </div>

        @if (!FilteredServices.Any())
        {
            <p class="text-sm text-gray-400 mt-4 text-center">No se encontraron servicios</p>
        }
    }

    @* ==================== STEP 4: Summary + Products ==================== *@
    @if (step == 4)
    {
        @if (!showProductSelector)
        {
            @* Ticket Summary *@
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
                <div class="flex items-center justify-between mb-1">
                    <h2 class="text-xl font-bold text-gray-800">Boleta de servicio</h2>
                    <span class="text-sm text-gray-500">Mecanico @selectedMechanic?.Name</span>
                </div>

                <div class="mb-4">
                    <span class="text-sm text-gray-500">@selectedCustomer?.FullName</span>
                    <span class="text-sm text-gray-800 ml-4 font-medium">@selectedBike?.Name</span>
                </div>

                <div class="mb-4">
                    <p class="text-sm text-gray-700">@selectedService?.Name</p>
                </div>

                @* Mechanic selector *@
                <div class="mb-4">
                    <label class="block text-sm text-gray-600 mb-1">Mecánico asignado</label>
                    <select class="border border-gray-300 rounded-lg px-3 py-2 text-sm w-full max-w-xs focus:outline-none focus:ring-2 focus:ring-indigo-300"
                            @bind="selectedMechanicId">
                        <option value="">— Sin asignar —</option>
                        @foreach (var m in availableMechanics)
                        {
                            <option value="@m.Id">@m.Name</option>
                        }
                    </select>
                </div>

                @* Product list *@
                @if (ticketProducts.Any())
                {
                    <div class="mb-4">
                        <h4 class="text-sm font-semibold text-gray-700 mb-2">Productos</h4>
                        @foreach (var tp in ticketProducts)
                        {
                            <div class="flex items-center justify-between text-sm py-1 border-b border-gray-100">
                                <span class="text-gray-700">@tp.Product.Name x@tp.Quantity</span>
                                <div class="flex items-center gap-2">
                                    <span class="text-gray-800">@((tp.UnitPrice * tp.Quantity).ToString("C"))</span>
                                    <button class="text-red-400 hover:text-red-600 text-xs" @onclick="() => RemoveProduct(tp)">quitar</button>
                                </div>
                            </div>
                        }
                    </div>
                }

                <button class="text-sm text-indigo-600 hover:underline mb-4 block" @onclick="OpenProductSelector">
                    Agregar productos
                </button>

                @* Notes *@
                <div class="mb-4">
                    <label class="block text-sm font-semibold text-gray-700 mb-1">Anotaciones</label>
                    <textarea class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300"
                              rows="3" @bind="ticketNotes" placeholder="Notas adicionales..."></textarea>
                </div>

                @* Total *@
                <div class="flex justify-between items-center text-sm font-semibold border-t border-gray-200 pt-3 mb-4">
                    <span class="text-gray-700">Total</span>
                    <span class="text-gray-800 text-lg">@CalculateTotal().ToString("C")</span>
                </div>

                <div class="flex gap-3">
                    <button class="bg-indigo-600 hover:bg-indigo-700 text-white font-semibold px-6 py-2 rounded-lg transition-colors"
                            @onclick="SaveTicket">
                        Continuar al cobro
                    </button>
                    <button class="text-sm text-gray-500 hover:text-gray-700 px-4 py-2" @onclick="() => step = 3">&larr; Volver</button>
                </div>
            </div>
        }
        else
        {
            @* Product Selector *@
            <div class="flex gap-6">
                @* Product grid *@
                <div class="flex-1">
                    <div class="flex items-center gap-3 mb-4">
                        <button class="text-sm text-gray-500 hover:text-gray-700" @onclick="CloseProductSelector">&larr; Volver</button>
                        <input type="text" class="flex-1 border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300"
                               placeholder="Buscar producto..." @bind="productSearch" @bind:event="oninput" @onkeyup="SearchProducts" />
                    </div>

                    <div class="grid grid-cols-3 gap-4">
                        @foreach (var product in productResults)
                        {
                            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4 cursor-pointer hover:shadow-md hover:border-indigo-300 transition-all"
                                 @onclick="() => AddProduct(product)">
                                <div class="w-full h-24 bg-gray-100 rounded-lg mb-3"></div>
                                <p class="text-sm font-medium text-gray-800">@product.Name</p>
                                <p class="text-sm text-gray-500">@product.Price.ToString("C")</p>
                            </div>
                        }
                    </div>
                </div>

                @* Ticket sidebar summary *@
                <div class="w-72 bg-white rounded-xl shadow-sm border border-gray-200 p-4 h-fit sticky top-6">
                    <h4 class="text-sm font-bold text-gray-800 mb-1">Boleta de servicio</h4>
                    <p class="text-xs text-gray-500 mb-3">@selectedCustomer?.FullName</p>

                    <div class="text-xs text-gray-700 mb-1">@selectedService?.Name</div>
                    <div class="text-xs text-gray-500 mb-3 text-right">@selectedService?.DefaultPrice.ToString("C")</div>

                    @foreach (var tp in ticketProducts)
                    {
                        <div class="flex justify-between text-xs text-gray-700 mb-1">
                            <span>@tp.Product.Name</span>
                            <span>@((tp.UnitPrice * tp.Quantity).ToString("C"))</span>
                        </div>
                    }

                    <div class="flex justify-between text-sm font-semibold border-t border-gray-200 pt-2 mt-3">
                        <span>Total</span>
                        <span>@CalculateTotal().ToString("C")</span>
                    </div>

                    <button class="w-full bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold py-2 rounded-lg mt-3 transition-colors"
                            @onclick="SaveTicket">
                        Guardar
                    </button>
                    <button class="w-full border border-gray-300 text-gray-700 text-sm py-2 rounded-lg mt-2 hover:bg-gray-50 transition-colors"
                            @onclick="SaveAndCharge">
                        Continuar al cobro
                    </button>
                </div>
            </div>
        }
    }
</div>

@code {
    private int step = 1;

    // Step 1 — Customer
    private string customerSearch = "";
    private List<Customer> customerResults = new();
    private Customer? selectedCustomer;
    private bool showCreateCustomer = false;

    // Step 2 — Bike
    private string bikeSearch = "";
    private List<Bike> bikeResults = new();
    private Bike? selectedBike;
    private bool showCreateBike = false;
    private string newBikeName = "";
    private string newBikeSku = "";
    private string newBikeColor = "";
    private string newBikeBrand = "";

    // Step 3 — Service
    private List<Service> availableServices = new();
    private Service? selectedService;
    private string serviceSearch = "";
    private IEnumerable<Service> FilteredServices =>
        string.IsNullOrWhiteSpace(serviceSearch)
            ? availableServices
            : availableServices.Where(s => s.Name.Contains(serviceSearch, StringComparison.OrdinalIgnoreCase));

    // Step 4 — Summary
    private List<Mechanic> availableMechanics = new();
    private int? selectedMechanicId;
    private Mechanic? selectedMechanic => availableMechanics.FirstOrDefault(m => m.Id == selectedMechanicId);
    private string ticketNotes = "";
    private List<TicketProductEntry> ticketProducts = new();
    private bool showProductSelector = false;
    private string productSearch = "";
    private List<Product> productResults = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadCustomers();
    }

    // --- Customer ---
    private async Task LoadCustomers()
    {
        using var context = DbFactory.CreateDbContext();
        customerResults = await context.Customer.OrderBy(c => c.LastName).ThenBy(c => c.FirstName).ToListAsync();
    }

    private async Task SearchCustomers()
    {
        using var context = DbFactory.CreateDbContext();
        if (string.IsNullOrWhiteSpace(customerSearch))
        {
            customerResults = await context.Customer.OrderBy(c => c.LastName).ThenBy(c => c.FirstName).ToListAsync();
        }
        else
        {
            customerResults = await context.Customer
                .Where(c => c.FirstName.Contains(customerSearch) || c.LastName.Contains(customerSearch) ||
                       (c.Phone != null && c.Phone.Contains(customerSearch)) ||
                       (c.Email != null && c.Email.Contains(customerSearch)))
                .OrderBy(c => c.LastName).ThenBy(c => c.FirstName)
                .ToListAsync();
        }
    }

    private void HandleNewCustomerSaved(Customer customer)
    {
        showCreateCustomer = false;
        SelectCustomer(customer);
    }

    private void SelectCustomer(Customer customer)
    {
        selectedCustomer = customer;
        step = 2;
        _ = LoadBikesForCustomer();
    }

    // --- Bike ---
    private async Task LoadBikesForCustomer()
    {
        using var context = DbFactory.CreateDbContext();
        bikeResults = await context.Bike
            .Where(b => b.CustomerId == selectedCustomer!.Id)
            .OrderBy(b => b.Name)
            .ToListAsync();
    }

    private async Task SearchBikes()
    {
        using var context = DbFactory.CreateDbContext();
        var query = context.Bike.Where(b => b.CustomerId == selectedCustomer!.Id);
        if (!string.IsNullOrWhiteSpace(bikeSearch))
        {
            query = query.Where(b => b.Name!.Contains(bikeSearch) || b.Sku.Contains(bikeSearch) || b.Brand.Contains(bikeSearch));
        }
        bikeResults = await query.OrderBy(b => b.Name).ToListAsync();
    }

    private async Task CreateBike()
    {
        if (string.IsNullOrWhiteSpace(newBikeName)) return;
        using var context = DbFactory.CreateDbContext();
        var bike = new Bike
        {
            Name = newBikeName, Sku = newBikeSku, Color = newBikeColor,
            Brand = newBikeBrand, CustomerId = selectedCustomer!.Id
        };
        context.Bike.Add(bike);
        await context.SaveChangesAsync();
        showCreateBike = false;
        newBikeName = ""; newBikeSku = ""; newBikeColor = ""; newBikeBrand = "";
        SelectBike(bike);
    }

    private void SelectBike(Bike bike)
    {
        selectedBike = bike;
        step = 3;
        _ = LoadServices();
    }

    // --- Service ---
    private async Task LoadServices()
    {
        using var context = DbFactory.CreateDbContext();
        availableServices = await context.Service.OrderBy(s => s.Name).ToListAsync();
    }

    private async Task SelectService(Service service)
    {
        selectedService = service;
        step = 4;
        using var context = DbFactory.CreateDbContext();
        availableMechanics = await context.Mechanic.Where(m => m.IsActive).OrderBy(m => m.Name).ToListAsync();
    }

    // --- Products ---
    private async Task OpenProductSelector()
    {
        showProductSelector = true;
        using var context = DbFactory.CreateDbContext();
        productResults = await context.Product.Where(p => p.QuantityInStock > 0).OrderBy(p => p.Name).ToListAsync();
    }

    private void CloseProductSelector() => showProductSelector = false;

    private async Task SearchProducts()
    {
        using var context = DbFactory.CreateDbContext();
        var query = context.Product.Where(p => p.QuantityInStock > 0);
        if (!string.IsNullOrWhiteSpace(productSearch))
        {
            query = query.Where(p => p.Name.Contains(productSearch) || (p.Sku != null && p.Sku.Contains(productSearch)));
        }
        productResults = await query.OrderBy(p => p.Name).ToListAsync();
    }

    private void AddProduct(Product product)
    {
        var existing = ticketProducts.FirstOrDefault(tp => tp.Product.Id == product.Id);
        if (existing is not null)
        {
            existing.Quantity++;
        }
        else
        {
            ticketProducts.Add(new TicketProductEntry { Product = product, UnitPrice = product.Price, Quantity = 1 });
        }
    }

    private void RemoveProduct(TicketProductEntry tp) => ticketProducts.Remove(tp);

    private decimal CalculateTotal()
    {
        var servicePrice = selectedService?.DefaultPrice ?? 0;
        var productsTotal = ticketProducts.Sum(tp => tp.UnitPrice * tp.Quantity);
        return servicePrice + productsTotal;
    }

    // --- Save ---
    private async Task SaveTicket()
    {
        using var context = DbFactory.CreateDbContext();
        var ticket = new ServiceTicket
        {
            BikeId = selectedBike!.Id,
            MechanicId = selectedMechanicId,
            BaseServiceId = selectedService!.Id,
            Description = ticketNotes,
            Price = CalculateTotal(),
            Status = TicketStatus.Open,
            CreatedAt = DateTime.UtcNow,
            UpdatedAt = DateTime.UtcNow,
        };
        context.ServiceTicket.Add(ticket);
        await context.SaveChangesAsync();

        foreach (var tp in ticketProducts)
        {
            context.TicketProduct.Add(new TicketProduct
            {
                ServiceTicketId = ticket.Id,
                ProductId = tp.Product.Id,
                Quantity = tp.Quantity,
                UnitPrice = tp.UnitPrice
            });
        }
        await context.SaveChangesAsync();

        NavigationManager.NavigateTo($"/tickets/details?id={ticket.Id}");
    }

    private async Task SaveAndCharge()
    {
        using var context = DbFactory.CreateDbContext();
        var ticket = new ServiceTicket
        {
            BikeId = selectedBike!.Id,
            MechanicId = selectedMechanicId,
            BaseServiceId = selectedService!.Id,
            Description = ticketNotes,
            Price = CalculateTotal(),
            Status = TicketStatus.Open,
            CreatedAt = DateTime.UtcNow,
            UpdatedAt = DateTime.UtcNow,
        };
        context.ServiceTicket.Add(ticket);
        await context.SaveChangesAsync();

        foreach (var tp in ticketProducts)
        {
            context.TicketProduct.Add(new TicketProduct
            {
                ServiceTicketId = ticket.Id,
                ProductId = tp.Product.Id,
                Quantity = tp.Quantity,
                UnitPrice = tp.UnitPrice
            });
        }
        await context.SaveChangesAsync();

        // Navigate back to home where they can search and charge the ticket
        NavigationManager.NavigateTo("/");
    }

    private class TicketProductEntry
    {
        public Product Product { get; set; } = null!;
        public decimal UnitPrice { get; set; }
        public int Quantity { get; set; }
    }
}
