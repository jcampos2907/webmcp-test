@page "/tickets/create"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using BikePOS.Models
@inject IDbContextFactory<BikePOS.Data.BikePosContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Create Service Ticket</PageTitle>

<h1>Create</h1>

<h2>Service Ticket</h2>
<hr />
<div class="row">
    <div class="col-md-4">
        <EditForm method="post" Model="ServiceTicket" OnValidSubmit="AddServiceTicket" FormName="create" Enhance>
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" role="alert"/>
            <div class="mb-3">
                <span class="text-danger">*</span>
                <label for="bikeid" class="form-label">Bike:</label>
                <InputSelect id="bikeid" @bind-Value="ServiceTicket.BikeId" class="form-control" aria-required="true">
                    <option value="">-- Select Bike --</option>
                    @foreach (var bike in Bikes)
                    {
                        <option value="@bike.Id">@bike.Name (@bike.Sku)</option>
                    }
                </InputSelect>
                <ValidationMessage For="() => ServiceTicket.BikeId" class="text-danger" />
            </div>
            <div class="mb-3">
                <label for="mechanicid" class="form-label">Mechanic:</label>
                <InputSelect id="mechanicid" @bind-Value="ServiceTicket.MechanicId" class="form-control">
                    <option value="">-- None --</option>
                    @foreach (var mechanic in Mechanics)
                    {
                        <option value="@mechanic.Id">@mechanic.Name</option>
                    }
                </InputSelect>
            </div>
            <div class="mb-3">
                <label for="baseserviceid" class="form-label">Service:</label>
                <InputSelect id="baseserviceid" @bind-Value="ServiceTicket.BaseServiceId" class="form-control">
                    <option value="">-- None --</option>
                    @foreach (var service in Services)
                    {
                        <option value="@service.Id">@service.Name (@service.DefaultPrice.ToString("C"))</option>
                    }
                </InputSelect>
            </div>
            <div class="mb-3">
                <label for="description" class="form-label">Description:</label>
                <InputTextArea id="description" @bind-Value="ServiceTicket.Description" class="form-control" rows="3" />
                <ValidationMessage For="() => ServiceTicket.Description" class="text-danger" />
            </div>
            <div class="mb-3">
                <span class="text-danger">*</span>
                <label for="price" class="form-label">Price:</label>
                <InputNumber id="price" @bind-Value="ServiceTicket.Price" class="form-control" aria-required="true"/>
                <ValidationMessage For="() => ServiceTicket.Price" class="text-danger" />
            </div>
            <button type="submit" class="btn btn-primary">Create</button>
        </EditForm>
    </div>
</div>

<div>
    <a href="/tickets">Back to List</a>
</div>

@code {
    [SupplyParameterFromForm]
    private ServiceTicket ServiceTicket { get; set; } = default!;

    private List<Bike> Bikes { get; set; } = new();
    private List<Mechanic> Mechanics { get; set; } = new();
    private List<Service> Services { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        ServiceTicket ??= new();
        using var context = DbFactory.CreateDbContext();
        Bikes = await context.Bike.OrderBy(b => b.Name).ToListAsync();
        Mechanics = await context.Mechanic.Where(m => m.IsActive).OrderBy(m => m.Name).ToListAsync();
        Services = await context.Service.OrderBy(s => s.Name).ToListAsync();
    }

    private async Task AddServiceTicket()
    {
        using var context = DbFactory.CreateDbContext();
        ServiceTicket.CreatedAt = DateTime.UtcNow;
        ServiceTicket.UpdatedAt = DateTime.UtcNow;
        context.ServiceTicket.Add(ServiceTicket);
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/tickets");
    }
}
