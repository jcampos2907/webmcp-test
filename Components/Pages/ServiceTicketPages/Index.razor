@page "/tickets"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "SuperAdmin,Admin,Mechanic")]
@using Microsoft.AspNetCore.Components.QuickGrid
@using Microsoft.EntityFrameworkCore
@using BikePOS.Models
@using BikePOS.Data
@implements IAsyncDisposable
@inject IDbContextFactory<BikePosContext> DbFactory

<PageTitle>@L.Tickets_Title</PageTitle>

<h1>@L.Tickets_Title</h1>

<div class="mb-3">
    <label class="form-label">@L.Tickets_FilterByStatus</label>
    <select @bind="StatusFilter" @bind:event="onchange" class="form-select" style="width: 200px; display: inline-block;">
        <option value="">@L.Status_All</option>
        @foreach (var status in Enum.GetValues<TicketStatus>())
        {
            <option value="@status">@status</option>
        }
    </select>
</div>

<p>
    <a href="tickets/create">@L.Common_CreateNew</a>
</p>

<QuickGrid Class="table" Items="FilteredTickets" Pagination="pagination">
    <PropertyColumn Property="t => t.Id" Title="#" />
    <PropertyColumn Property="t => t.Status" />
    <TemplateColumn Title="@L.Tickets_Component" Context="ticket">
        @ticket.Component?.Name
        <span class="text-xs text-gray-400 ml-1">@ticket.Component?.ComponentType</span>
    </TemplateColumn>
    <TemplateColumn Title="@L.Tickets_Mechanic" Context="ticket">
        @ticket.Mechanic?.Name
    </TemplateColumn>
    <PropertyColumn Property="t => t.Price" Format="C" />
    <PropertyColumn Property="t => t.CreatedAt" Format="g" />

    <TemplateColumn Context="ticket">
        <a href="@($"tickets/edit?id={ticket.Id}")">@L.Common_Edit</a> |
        <a href="@($"tickets/details?id={ticket.Id}")">@L.Common_Details</a> |
        <a href="@($"tickets/delete?id={ticket.Id}")">@L.Common_Delete</a>
    </TemplateColumn>
</QuickGrid>

<Paginator State="pagination" />

@code {
    [CascadingParameter] public Text L { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
    }
    private PaginationState pagination = new PaginationState { ItemsPerPage = 10 };
    private string StatusFilter = string.Empty;
    private BikePosContext context = default!;

    private IQueryable<ServiceTicket> FilteredTickets
    {
        get
        {
            var query = context.ServiceTicket
                .Include(t => t.Component)
                .Include(t => t.Mechanic)
                .AsQueryable();

            if (Enum.TryParse<TicketStatus>(StatusFilter, out var status))
            {
                query = query.Where(t => t.Status == status);
            }

            return query.OrderByDescending(t => t.CreatedAt);
        }
    }

    protected override void OnInitialized()
    {
        context = DbFactory.CreateDbContext();
    }

    public async ValueTask DisposeAsync() => await context.DisposeAsync();
}
