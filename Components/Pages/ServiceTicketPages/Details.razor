@page "/tickets/details"
@using Microsoft.EntityFrameworkCore
@using BikePOS.Models
@inject IDbContextFactory<BikePOS.Data.BikePosContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Service Ticket Details</PageTitle>

<h1>Details</h1>

<div>
    <h2>Service Ticket</h2>
    <hr />
    @if (serviceticket is null)
    {
        <p><em>Loading...</em></p>
    }
    else {
        <dl class="row">
            <dt class="col-sm-2">Status</dt>
            <dd class="col-sm-10">@serviceticket.Status</dd>
            <dt class="col-sm-2">Bike</dt>
            <dd class="col-sm-10">@serviceticket.Bike?.Name</dd>
            <dt class="col-sm-2">Mechanic</dt>
            <dd class="col-sm-10">@(serviceticket.Mechanic?.Name ?? "Unassigned")</dd>
            <dt class="col-sm-2">Service</dt>
            <dd class="col-sm-10">@(serviceticket.BaseService?.Name ?? "None")</dd>
            <dt class="col-sm-2">Description</dt>
            <dd class="col-sm-10">@serviceticket.Description</dd>
            <dt class="col-sm-2">Price</dt>
            <dd class="col-sm-10">@serviceticket.Price.ToString("C")</dd>
            <dt class="col-sm-2">Created</dt>
            <dd class="col-sm-10">@serviceticket.CreatedAt.ToString("g")</dd>
            <dt class="col-sm-2">Updated</dt>
            <dd class="col-sm-10">@serviceticket.UpdatedAt.ToString("g")</dd>
        </dl>

        @if (serviceticket.TicketProducts.Any())
        {
            <h3>Products</h3>
            <table class="table">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>Qty</th>
                        <th>Unit Price</th>
                        <th>Subtotal</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var tp in serviceticket.TicketProducts)
                    {
                        <tr>
                            <td>@tp.Product?.Name</td>
                            <td>@tp.Quantity</td>
                            <td>@tp.UnitPrice.ToString("C")</td>
                            <td>@((tp.Quantity * tp.UnitPrice).ToString("C"))</td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        <div>
            <a href="@($"/tickets/edit?id={serviceticket.Id}")">Edit</a> |
            <a href="/tickets">Back to List</a>
        </div>
    }
</div>

@code {
    private ServiceTicket? serviceticket;

    [SupplyParameterFromQuery]
    private int Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        serviceticket = await context.ServiceTicket
            .Include(t => t.Bike)
            .Include(t => t.Mechanic)
            .Include(t => t.BaseService)
            .Include(t => t.TicketProducts)
                .ThenInclude(tp => tp.Product)
            .FirstOrDefaultAsync(m => m.Id == Id);

        if (serviceticket is null)
        {
            NavigationManager.NotFound();
        }
    }
}
