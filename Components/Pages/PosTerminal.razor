@page "/pos-terminal"
@rendermode InteractiveServer
@implements IAsyncDisposable
@inject IJSRuntime JS

<PageTitle>POS Terminal</PageTitle>

<h1>POS Terminal</h1>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">Terminal Status</div>
            <div class="card-body">
                <p>Connection: <span class="badge @(isOnline ? "bg-success" : "bg-danger")">@(isOnline ? "Online" : "Offline")</span></p>
                @if (terminalInfo is not null)
                {
                    <p class="mb-1"><small class="text-muted">Screen: @terminalInfo.ScreenWidth x @terminalInfo.ScreenHeight</small></p>
                    <p class="mb-0"><small class="text-muted">Locale: @terminalInfo.Language</small></p>
                }
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card">
            <div class="card-header">Cashier</div>
            <div class="card-body">
                <div class="input-group">
                    <input type="text" class="form-control" placeholder="Cashier name" @bind="cashierName" />
                    <button class="btn btn-primary" @onclick="SaveCashier">Set</button>
                </div>
                @if (!string.IsNullOrEmpty(activeCashier))
                {
                    <p class="mt-2 mb-0">Active: <strong>@activeCashier</strong></p>
                }
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card">
            <div class="card-header">Charge Customer</div>
            <div class="card-body">
                <div class="input-group mb-2">
                    <span class="input-group-text">$</span>
                    <input type="number" class="form-control" placeholder="Amount" step="0.01" min="0" @bind="chargeAmount" />
                </div>
                <button class="btn btn-success" @onclick="ProcessCharge" disabled="@(!isOnline)">Process Charge</button>
                @if (chargeResult is not null)
                {
                    <div class="alert @(chargeResult.Value ? "alert-success" : "alert-warning") mt-2 mb-0">
                        @(chargeResult.Value ? "Charge processed." : "Charge cancelled.")
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card">
            <div class="card-header">Notifications</div>
            <div class="card-body">
                <button class="btn btn-secondary me-2" @onclick="RequestPermission">Enable Notifications</button>
                <button class="btn btn-outline-primary" @onclick="TestNotification">Test</button>
                @if (notificationPermission is not null)
                {
                    <p class="mt-2 mb-0">Permission: <strong>@notificationPermission</strong></p>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private IJSObjectReference? module;
    private DotNetObjectReference<PosTerminal>? dotNetRef;

    private bool isOnline = true;
    private TerminalInfoModel? terminalInfo;
    private string cashierName = "";
    private string? activeCashier;
    private decimal chargeAmount;
    private bool? chargeResult;
    private string? notificationPermission;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            module = await JS.InvokeAsync<IJSObjectReference>("import",
                "./Components/Pages/PosTerminal.razor.js");

            dotNetRef = DotNetObjectReference.Create(this);
            await module.InvokeVoidAsync("initialize", dotNetRef);
            await module.InvokeVoidAsync("addOnlineStatusListener");

            terminalInfo = await module.InvokeAsync<TerminalInfoModel>("getTerminalInfo");
            activeCashier = await module.InvokeAsync<string?>("loadCashierName");

            StateHasChanged();
        }
    }

    private async Task SaveCashier()
    {
        if (module is not null && !string.IsNullOrEmpty(cashierName))
        {
            await module.InvokeVoidAsync("saveCashierName", cashierName);
            activeCashier = cashierName;
            cashierName = "";
        }
    }

    private async Task ProcessCharge()
    {
        if (module is not null && chargeAmount > 0)
        {
            chargeResult = await module.InvokeAsync<bool>("confirmCharge", chargeAmount);
            if (chargeResult.Value)
            {
                await module.InvokeAsync<bool>("showNotification",
                    "BikePOS", $"Charge of ${chargeAmount:F2} processed by {activeCashier ?? "unknown"}.");
            }
        }
    }

    private async Task RequestPermission()
    {
        if (module is not null)
            notificationPermission = await module.InvokeAsync<string>("requestNotificationPermission");
    }

    private async Task TestNotification()
    {
        if (module is not null)
            await module.InvokeAsync<bool>("showNotification", "BikePOS", "Terminal notifications are working.");
    }

    [JSInvokable]
    public void OnConnectionStatusChanged(bool online)
    {
        isOnline = online;
        InvokeAsync(StateHasChanged);
    }

    public async ValueTask DisposeAsync()
    {
        dotNetRef?.Dispose();
        if (module is not null)
            await module.DisposeAsync();
    }

    private class TerminalInfoModel
    {
        public string UserAgent { get; set; } = "";
        public string Language { get; set; } = "";
        public int ScreenWidth { get; set; }
        public int ScreenHeight { get; set; }
        public string Url { get; set; } = "";
        public bool Online { get; set; }
    }
}
