@page "/"

<PageTitle>BikePOS</PageTitle>

<h1>BikePOS</h1>

<p>Bike shop point-of-sale and service ticket management.</p>

<div class="row g-4 mt-2">
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Inventory</h5>
                <p class="card-text">Browse, add, and manage bike inventory.</p>
                <a href="/bikes" class="btn btn-primary">Go to Inventory</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">POS Terminal</h5>
                <p class="card-text">Ring up sales and manage service tickets.</p>
                <a href="/pos-terminal" class="btn btn-primary">Open Terminal</a>
            </div>
        </div>
    </div>
</div>
