@page "/"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "SuperAdmin,Admin,Mechanic,Cashier")]
@implements IAsyncDisposable
@using Microsoft.EntityFrameworkCore
@using BikePOS.Models
@inject IJSRuntime JS
@inject IDbContextFactory<BikePOS.Data.BikePosContext> DbFactory
@inject NavigationManager NavigationManager
@inject I18nText I18nText
@inject ShopCultureService CultureService
@inject TenantContext Tenant

<PageTitle>@L.Pos_Title</PageTitle>

<div class="p-6">
    @* Header *@
    <div class="flex items-center justify-between mb-6">
        <h1 class="text-2xl font-bold text-gray-800">@L.Pos_Title</h1>
        <div class="flex items-center gap-3">
            <span class="inline-block w-3 h-3 rounded-full @(isOnline ? "bg-green-400" : "bg-red-400")" title="@(isOnline ? L.Pos_Online : L.Pos_Offline)"></span>
            <span class="text-sm text-gray-500">@L.Pos_Cashier: <strong class="text-gray-800">@(Tenant.DisplayName ?? "—")</strong></span>
        </div>
    </div>

    @* Create Service Ticket — Hero Card *@
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-6 cursor-pointer hover:shadow-md transition-shadow"
         @onclick="ShowCreateTicket">
        <div class="flex items-center gap-4">
            <div class="w-14 h-14 bg-indigo-100 rounded-lg flex items-center justify-center">
                <i class="fa-solid fa-file-circle-plus text-indigo-600 text-2xl"></i>
            </div>
            <div>
                <h2 class="text-xl font-semibold text-gray-800">@L.Pos_CreateTicket</h2>
                <p class="text-sm text-gray-500">@L.Pos_CreateTicketDesc</p>
            </div>
        </div>
    </div>

    @* Two cards side by side *@
    <div class="grid grid-cols-2 gap-6 mb-6">
        @* Search Tickets *@
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
            <h3 class="text-lg font-semibold text-gray-800 mb-4">@L.Pos_SearchTicket</h3>
            <div class="mb-3">
                <input type="text" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300"
                       placeholder="@L.Pos_SearchTicketPlaceholder"
                       @bind="ticketSearch" @bind:event="oninput" @onkeyup="SearchTickets" />
            </div>
            @if (searchResults.Any())
            {
                <div class="space-y-2 max-h-48 overflow-y-auto">
                    @foreach (var ticket in searchResults)
                    {
                        <div class="flex items-center justify-between p-2 bg-gray-50 rounded-lg cursor-pointer hover:bg-indigo-50 transition-colors"
                             @onclick="() => SelectTicket(ticket)">
                            <div>
                                <span class="text-sm font-medium text-gray-800">#@ticket.Id</span>
                                <span class="text-sm text-gray-500 ml-2">@ticket.Component?.Name</span>
                            </div>
                            <span class="text-xs px-2 py-1 rounded-full @GetStatusBadgeClass(ticket.Status)">@ticket.Status</span>
                        </div>
                    }
                </div>
            }
            else if (!string.IsNullOrEmpty(ticketSearch))
            {
                <p class="text-sm text-gray-400">@L.Pos_NoTicketsFound</p>
            }
        </div>

        @* Customer Lookup *@
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
            <h3 class="text-lg font-semibold text-gray-800 mb-4">@L.Pos_SearchCustomer</h3>
            <div class="mb-3">
                <input type="text" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300"
                       placeholder="@L.Pos_SearchCustomerPlaceholder"
                       @bind="customerSearch" @bind:event="oninput" @onkeyup="SearchCustomers" />
            </div>
            @if (customerResults.Any())
            {
                <div class="space-y-2 max-h-48 overflow-y-auto">
                    @foreach (var customer in customerResults)
                    {
                        <div class="flex items-center justify-between p-2 bg-gray-50 rounded-lg">
                            <div>
                                <span class="text-sm font-medium text-gray-800">@customer.FullName</span>
                                <span class="text-xs text-gray-400 ml-2">@customer.Phone</span>
                            </div>
                            <span class="text-xs text-gray-500">@customer.Email</span>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    @* Charge / Selected Ticket + Recent Charges *@
    <div class="grid grid-cols-2 gap-6">
        @* Process Charge *@
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
            <h3 class="text-lg font-semibold text-gray-800 mb-4">@L.Pos_ProcessCharge</h3>
            @if (selectedTicket is not null)
            {
                <div class="bg-indigo-50 rounded-lg p-3 mb-4">
                    <div class="flex justify-between text-sm">
                        <span class="text-gray-600">Ticket #@selectedTicket.Id</span>
                        <span class="font-semibold text-gray-800">@selectedTicket.Component?.Name</span>
                    </div>
                    <div class="flex justify-between text-sm mt-1">
                        <span class="text-gray-600">@(selectedTicket.Mechanic?.Name ?? L.Common_Unassigned)</span>
                        <span class="font-bold text-indigo-600">@selectedTicket.Price.ToString("C", culture)</span>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="block text-sm text-gray-600 mb-1">@L.Pos_Amount</label>
                    <input type="number" step="0.01" min="0"
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300"
                           @bind="chargeAmount" />
                </div>

                <div class="mb-4">
                    <label class="block text-sm text-gray-600 mb-1">@L.Pos_PaymentMethod</label>
                    <select class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300"
                            @bind="selectedPaymentMethod">
                        <option value="@PaymentMethod.Cash">@L.Pos_Cash</option>
                        <option value="@PaymentMethod.Card">@L.Pos_Card</option>
                    </select>
                </div>

                <button class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-2 rounded-lg transition-colors disabled:opacity-50"
                        @onclick="ProcessCharge" disabled="@(!isOnline || chargeAmount <= 0)">
                    @L.Pos_ProcessChargeButton
                </button>

                @if (chargeSuccess is not null)
                {
                    <div class="mt-3 p-2 rounded-lg text-sm text-center @(chargeSuccess.Value ? "bg-green-100 text-green-700" : "bg-red-100 text-red-700")">
                        @if (chargeSuccess.Value)
                        {
                            @L.Pos_ChargeSuccess
                        }
                        else
                        {
                            @(chargeError ?? L.Pos_ChargeFailed)
                        }
                    </div>
                }
            }
            else
            {
                <p class="text-sm text-gray-400">@L.Pos_SelectTicketHint</p>
            }
        </div>

        @* Recent Charges *@
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
            <h3 class="text-lg font-semibold text-gray-800 mb-4">@L.Pos_RecentCharges</h3>
            @if (recentCharges.Any())
            {
                <div class="space-y-2 max-h-64 overflow-y-auto">
                    @foreach (var charge in recentCharges)
                    {
                        <div class="flex items-center justify-between p-2 bg-gray-50 rounded-lg">
                            <div>
                                <span class="text-sm font-medium text-gray-800">@charge.Amount.ToString("C", culture)</span>
                                <span class="text-xs text-gray-400 ml-2">Ticket #@charge.ServiceTicketId</span>
                            </div>
                            <div class="text-right">
                                <span class="text-xs px-2 py-1 rounded-full bg-blue-100 text-blue-700">@charge.PaymentMethod</span>
                                <div class="text-xs text-gray-400 mt-1">@charge.ChargedAt.ToLocalTime().ToString("g", culture)</div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="text-sm text-gray-400">@L.Pos_NoCharges</p>
            }
        </div>
    </div>
</div>


@code {
    Text L = new();
    CultureInfo culture = CultureInfo.CurrentCulture;

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    protected override async Task OnInitializedAsync()
    {
        L = await I18nText.GetTextTableAsync<Text>(this);
        culture = await CultureService.GetCultureAsync();

        if (AuthState != null)
        {
            var state = await AuthState;
            Tenant.PopulateFromClaims(state.User);
        }
    }
    private IJSObjectReference? module;
    private DotNetObjectReference<Home>? dotNetRef;

    private bool isOnline = true;

    [SupplyParameterFromQuery]
    private int? ticketId { get; set; }

    // Ticket search
    private string ticketSearch = "";
    private List<ServiceTicket> searchResults = new();
    private ServiceTicket? selectedTicket;

    // Customer search
    private string customerSearch = "";
    private List<Customer> customerResults = new();

    // Charge
    private decimal chargeAmount;
    private PaymentMethod selectedPaymentMethod = PaymentMethod.Cash;
    private bool? chargeSuccess;
    private List<Charge> recentCharges = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            module = await JS.InvokeAsync<IJSObjectReference>("import",
                "./Components/Pages/Home.razor.js");

            dotNetRef = DotNetObjectReference.Create(this);
            await module.InvokeVoidAsync("initialize", dotNetRef);
            await module.InvokeVoidAsync("addOnlineStatusListener");

            await LoadRecentCharges();

            // Auto-select ticket if ticketId query param is provided
            if (ticketId.HasValue)
            {
                using var context = DbFactory.CreateDbContext();
                var t = await context.ServiceTicket
                    .Include(t => t.Component)
                    .Include(t => t.Mechanic)
                    .FirstOrDefaultAsync(t => t.Id == ticketId.Value);
                if (t is not null)
                {
                    SelectTicket(t);
                }
            }

            StateHasChanged();
        }
    }

    private async Task SearchTickets()
    {
        if (string.IsNullOrWhiteSpace(ticketSearch))
        {
            searchResults.Clear();
            return;
        }

        using var context = DbFactory.CreateDbContext();
        var query = context.ServiceTicket
            .Include(t => t.Component)
            .Include(t => t.Mechanic)
            .Where(t => t.Status != TicketStatus.Cancelled && t.Status != TicketStatus.Charged);

        if (int.TryParse(ticketSearch, out var ticketId))
        {
            query = query.Where(t => t.Id == ticketId);
        }
        else
        {
            query = query.Where(t => t.Component.Name!.Contains(ticketSearch));
        }

        searchResults = await query.OrderByDescending(t => t.CreatedAt).Take(10).ToListAsync();
    }

    private async Task SearchCustomers()
    {
        if (string.IsNullOrWhiteSpace(customerSearch))
        {
            customerResults.Clear();
            return;
        }

        using var context = DbFactory.CreateDbContext();
        customerResults = await context.Customer
            .Where(c => c.FirstName.Contains(customerSearch) || c.LastName.Contains(customerSearch) ||
                   (c.Phone != null && c.Phone.Contains(customerSearch)) ||
                   (c.Email != null && c.Email.Contains(customerSearch)))
            .Take(10)
            .ToListAsync();
    }

    private void SelectTicket(ServiceTicket ticket)
    {
        selectedTicket = ticket;
        chargeAmount = ticket.Price;
        chargeSuccess = null;
    }

    private string? chargeError;

    private async Task ProcessCharge()
    {
        if (selectedTicket is null || chargeAmount <= 0) return;
        chargeError = null;

        // Prevent charging cancelled tickets
        if (selectedTicket.Status == TicketStatus.Cancelled)
        {
            chargeError = L.Pos_ErrorCancelled;
            chargeSuccess = false;
            return;
        }

        // Prevent charging already charged tickets
        if (selectedTicket.Status == TicketStatus.Charged)
        {
            chargeError = L.Pos_ErrorAlreadyCharged;
            chargeSuccess = false;
            return;
        }

        // Prevent charging $0 tickets
        if (selectedTicket.Price <= 0)
        {
            chargeError = L.Pos_ErrorZeroTotal;
            chargeSuccess = false;
            return;
        }

        try
        {
            using var context = DbFactory.CreateDbContext();
            var charge = new Charge
            {
                ServiceTicketId = selectedTicket.Id,
                Amount = chargeAmount,
                ChargedAt = DateTime.UtcNow,
                CashierName = Tenant.UserIdentifier,
                PaymentMethod = selectedPaymentMethod,
                CreatedBy = Tenant.UserIdentifier
            };

            context.Charge.Add(charge);

            // Update ticket status to Charged
            var ticket = await context.ServiceTicket.FindAsync(selectedTicket.Id);
            if (ticket is not null)
            {
                ticket.Status = TicketStatus.Charged;
                ticket.UpdatedAt = DateTime.UtcNow;
                ticket.UpdatedBy = Tenant.UserIdentifier;
            }

            await context.SaveChangesAsync();

            chargeSuccess = true;
            selectedTicket = null;
            chargeAmount = 0;

            await LoadRecentCharges();

            if (module is not null)
            {
                await module.InvokeAsync<bool>("showNotification",
                    "BikePOS", $"Charge of {charge.Amount:C} processed by {Tenant.DisplayName ?? "unknown"}.");
            }
        }
        catch
        {
            chargeSuccess = false;
        }
    }

    private async Task LoadRecentCharges()
    {
        using var context = DbFactory.CreateDbContext();
        recentCharges = await context.Charge
            .Include(c => c.ServiceTicket)
            .OrderByDescending(c => c.ChargedAt)
            .Take(10)
            .ToListAsync();
    }

    private void ShowCreateTicket()
    {
        NavigationManager.NavigateTo("/tickets/create");
    }

    [JSInvokable]
    public void OnConnectionStatusChanged(bool online)
    {
        isOnline = online;
        InvokeAsync(StateHasChanged);
    }

    private static string GetStatusBadgeClass(TicketStatus status) => status switch
    {
        TicketStatus.Open => "bg-yellow-100 text-yellow-700",
        TicketStatus.InProgress => "bg-blue-100 text-blue-700",
        TicketStatus.WaitingForParts => "bg-orange-100 text-orange-700",
        TicketStatus.Completed => "bg-green-100 text-green-700",
        TicketStatus.Charged => "bg-purple-100 text-purple-700",
        TicketStatus.Cancelled => "bg-red-100 text-red-700",
        _ => "bg-gray-100 text-gray-700"
    };

    public async ValueTask DisposeAsync()
    {
        dotNetRef?.Dispose();
        if (module is not null)
            await module.DisposeAsync();
    }
}
