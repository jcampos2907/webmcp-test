@page "/mechanics/create"
@using Microsoft.EntityFrameworkCore
@using BikePOS.Models
@inject IDbContextFactory<BikePOS.Data.BikePosContext> DbFactory
@inject NavigationManager NavigationManager
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Mechanics.Create"]</PageTitle>

<h1>@L["Common.Create"]</h1>

<h2>@L["Mechanics.Entity"]</h2>
<hr />
<div class="row">
    <div class="col-md-4">
        <EditForm method="post" Model="Mechanic" OnValidSubmit="AddMechanic" FormName="create" Enhance>
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" role="alert"/>
            <div class="mb-3">
                <span class="text-danger">*</span>
                <label for="name" class="form-label">@L["Common.Name"]:</label>
                <InputText id="name" @bind-Value="Mechanic.Name" class="form-control" aria-required="true"/> 
                <ValidationMessage For="() => Mechanic.Name" class="text-danger" /> 
            </div>        
            <div class="mb-3">
                <label for="phone" class="form-label">@L["Common.Phone"]:</label>
                <InputText id="phone" @bind-Value="Mechanic.Phone" class="form-control" /> 
                <ValidationMessage For="() => Mechanic.Phone" class="text-danger" /> 
            </div>        
            <div class="mb-3">
                <label for="email" class="form-label">@L["Common.Email"]:</label>
                <InputText id="email" @bind-Value="Mechanic.Email" class="form-control" /> 
                <ValidationMessage For="() => Mechanic.Email" class="text-danger" /> 
            </div>        
            <div class="mb-3">
                <label for="isactive" class="form-label">@L["Common.IsActive"]:</label>
                <InputCheckbox id="isactive" @bind-Value="Mechanic.IsActive" class="form-check-input" /> 
                <ValidationMessage For="() => Mechanic.IsActive" class="text-danger" /> 
            </div>        
            <button type="submit" class="btn btn-primary">@L["Common.Create"]</button>
        </EditForm>
    </div>
</div>

<div>
    <a href="/mechanics">@L["Common.BackToList"]</a>
</div>

@code {
    [SupplyParameterFromForm]
    private Mechanic Mechanic { get; set; } = default!;

    protected override void OnInitialized() => Mechanic ??= new();

    // To protect from overposting attacks, see https://learn.microsoft.com/aspnet/core/blazor/forms/#mitigate-overposting-attacks.
    private async Task AddMechanic()
    {
        using var context = DbFactory.CreateDbContext();
        context.Mechanic.Add(Mechanic);
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/mechanics");
    }
}
