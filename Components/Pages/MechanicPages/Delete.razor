@page "/mechanics/delete"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "SuperAdmin,Admin")]
@using Microsoft.EntityFrameworkCore
@using BikePOS.Models
@inject IDbContextFactory<BikePOS.Data.BikePosContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>@L.Mechanics_Delete</PageTitle>

<h1>@L.Common_Delete</h1>

<p>@L.Mechanics_ConfirmDelete</p>
<div>
    <h2>@L.Mechanics_Entity</h2>
    <hr />
    @if (mechanic is null)
    {
        <p><em>@L.Common_Loading</em></p>
    }
    else {
        <dl class="row">
            <dt class="col-sm-2">@L.Common_Name</dt>
            <dd class="col-sm-10">@mechanic.Name</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">@L.Common_Phone</dt>
            <dd class="col-sm-10">@mechanic.Phone</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">@L.Common_Email</dt>
            <dd class="col-sm-10">@mechanic.Email</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">@L.Common_IsActive</dt>
            <dd class="col-sm-10">@mechanic.IsActive</dd>
        </dl>
        <EditForm method="post" Model="mechanic" OnValidSubmit="DeleteMechanic" FormName="delete" Enhance>
            <button type="submit" class="btn btn-danger" disabled="@(mechanic is null)">@L.Common_Delete</button> |
            <a href="/mechanics">@L.Common_BackToList</a>
        </EditForm>
    }
</div>

@code {
    [CascadingParameter] public Text L { get; set; } = default!;
    private Mechanic? mechanic;

    [SupplyParameterFromQuery]
    private string Id { get; set; } = "";

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        mechanic = await context.Mechanic.FirstOrDefaultAsync(m => m.Id == Id);

        if (mechanic is null)
        {
            NavigationManager.NotFound();
        }
    }

    private async Task DeleteMechanic()
    {
        using var context = DbFactory.CreateDbContext();
        context.Mechanic.Remove(mechanic!);
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/mechanics");
    }
}
