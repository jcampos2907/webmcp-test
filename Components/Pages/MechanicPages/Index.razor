@page "/mechanics"
@using Microsoft.AspNetCore.Components.QuickGrid
@using Microsoft.EntityFrameworkCore
@using BikePOS.Models
@using BikePOS.Data
@implements IAsyncDisposable
@inject IDbContextFactory<BikePOS.Data.BikePosContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Index</PageTitle>

<h1>Index</h1>

<p>
    <a href="mechanics/create">Create New</a>
</p>

<QuickGrid Class="table" Items="context.Mechanic">
    <PropertyColumn Property="mechanic => mechanic.Name" />
    <PropertyColumn Property="mechanic => mechanic.Phone" />
    <PropertyColumn Property="mechanic => mechanic.Email" />
    <PropertyColumn Property="mechanic => mechanic.IsActive" />

    <TemplateColumn Context="mechanic">
        <a href="@($"mechanics/edit?id={mechanic.Id}")">Edit</a> |
        <a href="@($"mechanics/details?id={mechanic.Id}")">Details</a> |
        <a href="@($"mechanics/delete?id={mechanic.Id}")">Delete</a>
    </TemplateColumn>
</QuickGrid>

@code {
    private BikePosContext context = default!;

    protected override void OnInitialized()
    {
        context = DbFactory.CreateDbContext();
    }

    public async ValueTask DisposeAsync() => await context.DisposeAsync();
}
