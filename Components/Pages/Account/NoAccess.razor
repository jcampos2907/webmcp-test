@page "/account/no-access"
@layout EmptyLayout
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]

<PageTitle>No Store Access</PageTitle>

<div class="flex items-center justify-center h-screen bg-gray-100">
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8 max-w-md text-center">
        <div class="w-16 h-16 bg-amber-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <i class="fa-solid fa-triangle-exclamation text-amber-500 text-2xl"></i>
        </div>
        <h1 class="text-xl font-bold text-gray-800 mb-2">No Store Access</h1>
        <p class="text-sm text-gray-500 mb-6">
            Your account has been created but you have not been assigned to any store yet.
            Please contact your administrator to get access.
        </p>
        <a href="/account/logout"
           class="inline-block bg-gray-200 hover:bg-gray-300 text-gray-700 text-sm font-semibold px-5 py-2 rounded-lg transition-colors">
            Sign Out
        </a>
    </div>
</div>
