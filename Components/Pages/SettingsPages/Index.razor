@page "/settings"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "SuperAdmin")]
@using Microsoft.EntityFrameworkCore
@using BikePOS.Models
@inject IDbContextFactory<BikePOS.Data.BikePosContext> DbFactory
@inject I18nText I18nText
@inject ShopCultureService CultureService
@inject TenantContext Tenant

<PageTitle>@L.Settings_Title</PageTitle>

<div class="flex h-full">
    @* Vertical nav *@
    <nav class="w-56 bg-white border-r border-gray-200 p-4 flex-shrink-0">
        <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-3">@L.Settings_Title</h2>
        <ul class="space-y-1">
            <li>
                <button class="w-full text-left text-sm px-3 py-2 rounded-lg transition-colors @NavClass("profile")"
                        @onclick='() => activeSection = "profile"'>
                    <i class="fa-solid fa-user w-5 text-center mr-2"></i>@L.Settings_Profile
                </button>
            </li>
            <li>
                <button class="w-full text-left text-sm px-3 py-2 rounded-lg transition-colors @NavClass("components")"
                        @onclick='() => activeSection = "components"'>
                    <i class="fa-solid fa-cubes w-5 text-center mr-2"></i>@L.Settings_ComponentTypes
                </button>
            </li>
            <li>
                <button class="w-full text-left text-sm px-3 py-2 rounded-lg transition-colors @NavClass("meta")"
                        @onclick='() => activeSection = "meta"'>
                    <i class="fa-solid fa-sliders w-5 text-center mr-2"></i>@L.Settings_MetaFields
                </button>
            </li>
            <li>
                <button class="w-full text-left text-sm px-3 py-2 rounded-lg transition-colors @NavClass("shop")"
                        @onclick='() => activeSection = "shop"'>
                    <i class="fa-solid fa-store w-5 text-center mr-2"></i>@L.Settings_ShopInfo
                </button>
            </li>
            <li>
                <button class="w-full text-left text-sm px-3 py-2 rounded-lg transition-colors @NavClass("billing")"
                        @onclick='() => activeSection = "billing"'>
                    <i class="fa-solid fa-file-invoice w-5 text-center mr-2"></i>@L.Settings_Billing
                </button>
            </li>
            <li>
                <button class="w-full text-left text-sm px-3 py-2 rounded-lg transition-colors @NavClass("notifications")"
                        @onclick='() => activeSection = "notifications"'>
                    <i class="fa-solid fa-bell w-5 text-center mr-2"></i>@L.Settings_Notifications
                </button>
            </li>

            @* Admin section divider *@
            <li class="mt-4 pt-3 border-t border-gray-200">
                <span class="text-[10px] text-gray-400 uppercase tracking-wider px-3">@L.Settings_AdminSection</span>
            </li>
            <li>
                <button class="w-full text-left text-sm px-3 py-2 rounded-lg transition-colors @NavClass("organization")"
                        @onclick='() => activeSection = "organization"'>
                    <i class="fa-solid fa-sitemap w-5 text-center mr-2"></i>@L.Settings_Organization
                </button>
            </li>
            <li>
                <button class="w-full text-left text-sm px-3 py-2 rounded-lg transition-colors @NavClass("users")"
                        @onclick='() => activeSection = "users"'>
                    <i class="fa-solid fa-user-gear w-5 text-center mr-2"></i>@L.Settings_Users
                </button>
            </li>
        </ul>
    </nav>

    @* Content *@
    <div class="flex-1 p-6 overflow-y-auto">
        <div class="max-w-3xl">

            @* ==================== Profile ==================== *@
            @if (activeSection == "profile")
            {
                <h1 class="text-xl font-bold text-gray-800 mb-1">@L.Settings_Profile</h1>
                <p class="text-sm text-gray-500 mb-6">@L.Settings_ProfileSubtitle</p>

                <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
                    <div class="flex items-center gap-4 mb-6">
                        <div class="w-16 h-16 bg-indigo-100 rounded-full flex items-center justify-center">
                            <i class="fa-solid fa-user text-indigo-400 text-2xl"></i>
                        </div>
                        <div>
                            <p class="text-gray-800 font-semibold">@(string.IsNullOrEmpty(Tenant.DisplayName) ? L.Settings_NoName : Tenant.DisplayName)</p>
                            <p class="text-sm text-gray-500">@(string.IsNullOrEmpty(Tenant.Email) ? L.Settings_NoEmail : Tenant.Email)</p>
                        </div>
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm text-gray-600 mb-1">@L.Settings_FullName</label>
                            <input type="text" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm bg-gray-50 text-gray-500"
                                   value="@Tenant.DisplayName" disabled />
                        </div>
                        <div>
                            <label class="block text-sm text-gray-600 mb-1">@L.Common_Email</label>
                            <input type="email" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm bg-gray-50 text-gray-500"
                                   value="@Tenant.Email" disabled />
                        </div>
                        <div>
                            <label class="block text-sm text-gray-600 mb-1">@L.Common_Phone</label>
                            <input type="tel" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300"
                                   @bind="profilePhone" placeholder="@L.Settings_PhonePlaceholder" />
                        </div>
                        <div>
                            <label class="block text-sm text-gray-600 mb-1">@L.Settings_Role</label>
                            <input type="text" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm bg-gray-50 text-gray-500" value="@Tenant.Role" disabled />
                        </div>
                        <div>
                            <label class="block text-sm text-gray-600 mb-1">@L.Settings_Language</label>
                            <select class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300"
                                    @bind="selectedLanguage">
                                <option value="es">Espanol</option>
                                <option value="en">English</option>
                            </select>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(profileSaveMessage))
                    {
                        <div class="text-sm text-green-600 bg-green-50 rounded-lg px-3 py-2 mt-4">@profileSaveMessage</div>
                    }

                    <div class="mt-4">
                        <button class="bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold px-5 py-2 rounded-lg transition-colors"
                                @onclick="SaveProfile">@L.Common_Save</button>
                    </div>
                </div>
            }

            @* ==================== Component Types ==================== *@
            @if (activeSection == "components")
            {
                <h1 class="text-xl font-bold text-gray-800 mb-1">@L.Settings_ComponentTypes</h1>
                <p class="text-sm text-gray-500 mb-6">@L.Settings_ComponentTypesSubtitle</p>

                <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
                    @if (componentTypes.Any())
                    {
                        <div class="space-y-2 mb-4">
                            @foreach (var ct in componentTypes)
                            {
                                <div class="flex items-center justify-between bg-gray-50 rounded-lg px-4 py-2">
                                    <span class="text-sm text-gray-800">@ct</span>
                                    <button class="text-red-400 hover:text-red-600 text-xs" @onclick="() => RemoveComponentType(ct)">@L.Common_Remove</button>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-sm text-gray-400 mb-4">@L.Settings_NoTypes</p>
                    }

                    <div class="flex items-center gap-2">
                        <input type="text" class="flex-1 border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300"
                               placeholder="@L.Settings_NewTypePlaceholder" @bind="newComponentType" @bind:event="oninput"
                               @onkeydown="HandleComponentTypeKeyDown" />
                        <button class="bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors"
                                @onclick="AddComponentType" disabled="@string.IsNullOrWhiteSpace(newComponentType)">
                            @L.Common_Add
                        </button>
                    </div>

                    @if (!string.IsNullOrEmpty(componentTypeError))
                    {
                        <div class="text-sm text-red-600 bg-red-50 rounded-lg px-3 py-2 mt-3">@componentTypeError</div>
                    }
                    @if (!string.IsNullOrEmpty(componentTypeSaveMessage))
                    {
                        <div class="text-sm text-green-600 bg-green-50 rounded-lg px-3 py-2 mt-3">@componentTypeSaveMessage</div>
                    }
                </div>
            }

            @* ==================== Meta Field Definitions ==================== *@
            @if (activeSection == "meta")
            {
                <div class="flex items-center justify-between mb-4">
                    <div>
                        <h1 class="text-xl font-bold text-gray-800 mb-1">@L.Settings_MetaFields</h1>
                        <p class="text-sm text-gray-500">@L.Settings_MetaFieldsSubtitle</p>
                    </div>
                    <button class="bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors flex-shrink-0"
                            @onclick="ShowAddField">
                        @L.Settings_AddField
                    </button>
                </div>

                @* Entity type tabs *@
                <div class="flex gap-1 mb-6 bg-gray-100 rounded-lg p-1">
                    @foreach (var et in EntityTypes)
                    {
                        <button class="flex-1 text-sm px-3 py-2 rounded-md transition-colors @(selectedEntityType == et.Key ? "bg-white text-indigo-700 font-semibold shadow-sm" : "text-gray-600 hover:text-gray-800")"
                                @onclick="() => SwitchEntityType(et.Key)">
                            @et.Value
                        </button>
                    }
                </div>

                @if (showFieldForm)
                {
                    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-4">
                        <h4 class="text-sm font-semibold text-gray-800 mb-4">@(editingFieldId.HasValue ? L.Settings_EditField : L.Settings_NewField)</h4>

                        <div class="grid grid-cols-3 gap-3 mb-4">
                            <div>
                                <label class="block text-xs text-gray-500 mb-1">@L.Settings_Label <span class="text-red-500">*</span></label>
                                <input type="text" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300"
                                       placeholder="@L.Settings_LabelPlaceholder" @bind="fieldLabel" />
                            </div>
                            <div>
                                <label class="block text-xs text-gray-500 mb-1">@L.Settings_Key <span class="text-red-500">*</span></label>
                                <input type="text" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-indigo-300"
                                       placeholder="@L.Settings_KeyPlaceholder" @bind="fieldKey" />
                            </div>
                            <div>
                                <label class="block text-xs text-gray-500 mb-1">@L.Settings_Order</label>
                                <input type="number" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300"
                                       @bind="fieldSortOrder" />
                            </div>
                        </div>

                        <div class="grid grid-cols-2 gap-3 mb-4">
                            <div>
                                <label class="block text-xs text-gray-500 mb-1">@L.Settings_FieldType</label>
                                <select class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" @bind="fieldType">
                                    <option value="text">@L.Settings_FieldText</option>
                                    <option value="number">@L.Settings_FieldNumber</option>
                                    <option value="email">@L.Settings_FieldEmail</option>
                                    <option value="tel">@L.Settings_FieldPhone</option>
                                    <option value="date">@L.Settings_FieldDate</option>
                                    <option value="url">@L.Settings_FieldUrl</option>
                                    <option value="select">@L.Settings_FieldSelect</option>
                                </select>
                            </div>
                            @if (fieldType == "select")
                            {
                                <div>
                                    <label class="block text-xs text-gray-500 mb-1">@L.Settings_OptionsComma</label>
                                    <input type="text" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300"
                                           placeholder="@L.Settings_OptionsPlaceholder" @bind="fieldOptions" />
                                </div>
                            }
                        </div>

                        <p class="text-xs text-gray-400 uppercase tracking-wide mb-2">@L.Settings_Validation</p>
                        <div class="grid grid-cols-2 gap-3 mb-4">
                            <div>
                                <label class="block text-xs text-gray-500 mb-1">@L.Settings_RegexValidation</label>
                                <input type="text" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-indigo-300"
                                       placeholder="@L.Settings_RegexPlaceholder" @bind="fieldRegex" />
                            </div>
                            <div>
                                <label class="block text-xs text-gray-500 mb-1">@L.Settings_RegexErrorMessage</label>
                                <input type="text" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300"
                                       placeholder="@L.Settings_RegexErrorPlaceholder" @bind="fieldRegexMessage" />
                            </div>
                        </div>

                        <div class="grid grid-cols-2 gap-3 mb-4">
                            <div>
                                <label class="block text-xs text-gray-500 mb-1">@L.Settings_FormatMask</label>
                                <input type="text" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300"
                                       placeholder="@L.Settings_FormatMaskPlaceholder" @bind="fieldFormatMask" />
                            </div>
                            <div class="flex items-end pb-1">
                                <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer">
                                    <input type="checkbox" class="rounded border-gray-300" @bind="fieldIsRequired" />
                                    @L.Settings_RequiredField
                                </label>
                            </div>
                        </div>

                        <p class="text-xs text-gray-400 uppercase tracking-wide mb-2">@L.Settings_ConditionalVisibility</p>
                        <div class="grid grid-cols-2 gap-3 mb-4">
                            <div>
                                <label class="block text-xs text-gray-500 mb-1">@L.Settings_ShowWhenField</label>
                                <select class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300"
                                        @bind="fieldConditionalOnId">
                                    <option value="">@L.Settings_AlwaysVisible</option>
                                    @foreach (var f in metaFields.Where(f => f.Id != editingFieldId && f.FieldType == "select"))
                                    {
                                        <option value="@f.Id">@f.Label</option>
                                    }
                                </select>
                            </div>
                            @if (!string.IsNullOrEmpty(fieldConditionalOnId))
                            {
                                var parentField = metaFields.FirstOrDefault(f => f.Id.ToString() == fieldConditionalOnId);
                                @if (parentField is not null && !string.IsNullOrEmpty(parentField.Options))
                                {
                                    <div>
                                        <label class="block text-xs text-gray-500 mb-1">@L.Settings_HasValue</label>
                                        <select class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300"
                                                @bind="fieldConditionalOnValue">
                                            <option value="">@L.Common_Select</option>
                                            @foreach (var opt in parentField.Options.Split(',', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries))
                                            {
                                                <option value="@opt">@opt</option>
                                            }
                                        </select>
                                    </div>
                                }
                            }
                        </div>

                        @if (!string.IsNullOrEmpty(fieldError))
                        {
                            <div class="text-sm text-red-600 bg-red-50 rounded-lg px-3 py-2 mb-3">@fieldError</div>
                        }

                        <div class="flex gap-2">
                            <button class="bg-indigo-600 hover:bg-indigo-700 text-white text-sm px-4 py-2 rounded-lg" @onclick="SaveField">@L.Settings_SaveField</button>
                            <button class="bg-gray-200 hover:bg-gray-300 text-gray-700 text-sm px-4 py-2 rounded-lg" @onclick="CancelFieldForm">@L.Common_Cancel</button>
                        </div>
                    </div>
                }

                @if (metaFields.Any())
                {
                    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
                        <table class="w-full text-sm">
                            <thead class="bg-gray-50">
                                <tr class="text-left text-gray-500 text-xs uppercase tracking-wide">
                                    <th class="py-3 px-4 font-medium">@L.Settings_FieldTableOrder</th>
                                    <th class="py-3 px-4 font-medium">@L.Settings_FieldTableLabel</th>
                                    <th class="py-3 px-4 font-medium">@L.Settings_FieldTableType</th>
                                    <th class="py-3 px-4 font-medium">@L.Settings_FieldTableValidation</th>
                                    <th class="py-3 px-4 font-medium">@L.Settings_FieldTableCondition</th>
                                    <th class="py-3 px-4 font-medium">@L.Settings_FieldTableStatus</th>
                                    <th class="py-3 px-4"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var field in metaFields)
                                {
                                    <tr class="border-t border-gray-100 hover:bg-gray-50">
                                        <td class="py-3 px-4 text-gray-400">@field.SortOrder</td>
                                        <td class="py-3 px-4">
                                            <span class="text-gray-800 font-medium">@field.Label</span>
                                            <span class="text-gray-400 text-xs font-mono ml-1">@field.Key</span>
                                            @if (field.IsRequired) { <span class="text-red-500 ml-1">*</span> }
                                        </td>
                                        <td class="py-3 px-4 text-gray-500">
                                            @field.FieldType
                                            @if (field.FieldType == "select" && !string.IsNullOrEmpty(field.Options))
                                            {
                                                <span class="text-gray-400 text-xs block">@field.Options</span>
                                            }
                                        </td>
                                        <td class="py-3 px-4">
                                            @if (!string.IsNullOrEmpty(field.RegexPattern))
                                            {
                                                <span class="text-xs font-mono bg-gray-100 text-gray-600 px-1.5 py-0.5 rounded" title="@field.RegexPattern">regex</span>
                                            }
                                            @if (!string.IsNullOrEmpty(field.FormatMask))
                                            {
                                                <span class="text-xs text-gray-400 block">@field.FormatMask</span>
                                            }
                                        </td>
                                        <td class="py-3 px-4 text-xs text-gray-500">
                                            @if (field.ConditionalOnFieldId.HasValue)
                                            {
                                                var parent = metaFields.FirstOrDefault(f => f.Id == field.ConditionalOnFieldId);
                                                <span>@(parent?.Label ?? "?") = @field.ConditionalOnValue</span>
                                            }
                                        </td>
                                        <td class="py-3 px-4">
                                            @if (field.IsActive)
                                            {
                                                <span class="text-xs bg-green-100 text-green-700 px-2 py-0.5 rounded-full">@L.Common_Active</span>
                                            }
                                            else
                                            {
                                                <span class="text-xs bg-gray-100 text-gray-500 px-2 py-0.5 rounded-full">@L.Common_Inactive</span>
                                            }
                                        </td>
                                        <td class="py-3 px-4 text-right">
                                            <button class="text-indigo-600 hover:text-indigo-800 text-xs mr-2" @onclick="() => EditField(field)">@L.Common_Edit</button>
                                            <button class="text-gray-400 hover:text-gray-600 text-xs" @onclick="() => ToggleFieldActive(field)">
                                                @(field.IsActive ? L.Settings_Deactivate : L.Settings_Activate)
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else if (!showFieldForm)
                {
                    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8 text-center">
                        <i class="fa-solid fa-sliders text-gray-300 text-3xl mb-3"></i>
                        <p class="text-sm text-gray-400">@L.Settings_NoFieldsConfigured</p>
                        <p class="text-xs text-gray-400 mt-1">@L.Settings_NoFieldsHint</p>
                    </div>
                }
            }

            @* ==================== Shop Info ==================== *@
            @if (activeSection == "shop")
            {
                <h1 class="text-xl font-bold text-gray-800 mb-1">@L.Settings_ShopInfo</h1>
                <p class="text-sm text-gray-500 mb-6">@L.Settings_ShopInfoSubtitle</p>

                <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
                    <div class="grid grid-cols-2 gap-4">
                        <div class="col-span-2">
                            <label class="block text-sm text-gray-600 mb-1">@L.Settings_ShopName</label>
                            <input type="text" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300"
                                   @bind="shopName" placeholder="@L.Settings_ShopNamePlaceholder" />
                        </div>
                        <div>
                            <label class="block text-sm text-gray-600 mb-1">@L.Settings_TaxId</label>
                            <input type="text" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300"
                                   @bind="shopTaxId" placeholder="@L.Settings_TaxIdPlaceholder" />
                        </div>
                        <div>
                            <label class="block text-sm text-gray-600 mb-1">@L.Settings_BusinessType</label>
                            <input type="text" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300"
                                   @bind="shopBusinessType" placeholder="@L.Settings_BusinessTypePlaceholder" />
                        </div>
                        <div>
                            <label class="block text-sm text-gray-600 mb-1">@L.Common_Phone</label>
                            <input type="tel" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300"
                                   @bind="shopPhone" placeholder="@L.Settings_ShopPhone" />
                        </div>
                        <div>
                            <label class="block text-sm text-gray-600 mb-1">@L.Common_Email</label>
                            <input type="email" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300"
                                   @bind="shopEmail" placeholder="@L.Settings_ShopEmail" />
                        </div>
                        <div class="col-span-2">
                            <label class="block text-sm text-gray-600 mb-1">@L.Common_Address</label>
                            <input type="text" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300"
                                   @bind="shopAddress" placeholder="@L.Settings_ShopAddress" />
                        </div>
                        <div class="col-span-2">
                            <label class="block text-sm text-gray-600 mb-1">@L.Settings_Locale</label>
                            <input type="text" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm bg-gray-50 text-gray-500"
                                   value="@(Tenant.CompanyName ?? "—")" disabled />
                            <p class="text-xs text-gray-400 mt-1">@L.Settings_LocaleManagedByCompany</p>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(shopSaveMessage))
                    {
                        <div class="text-sm text-green-600 bg-green-50 rounded-lg px-3 py-2 mt-4">@shopSaveMessage</div>
                    }

                    <div class="mt-4">
                        <button class="bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold px-5 py-2 rounded-lg transition-colors"
                                @onclick="SaveShopSettings">@L.Common_Save</button>
                    </div>
                </div>
            }

            @* ==================== Placeholder sections ==================== *@
            @if (activeSection == "billing")
            {
                <h1 class="text-xl font-bold text-gray-800 mb-1">@L.Settings_Billing</h1>
                <p class="text-sm text-gray-500 mb-6">@L.Settings_BillingSubtitle</p>
                <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8 text-center">
                    <i class="fa-solid fa-file-invoice text-gray-300 text-3xl mb-3"></i>
                    <p class="text-sm text-gray-400">@L.Settings_BillingComingSoon</p>
                </div>
            }

            @if (activeSection == "notifications")
            {
                <h1 class="text-xl font-bold text-gray-800 mb-1">@L.Settings_Notifications</h1>
                <p class="text-sm text-gray-500 mb-6">@L.Settings_NotificationsSubtitle</p>
                <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8 text-center">
                    <i class="fa-solid fa-bell text-gray-300 text-3xl mb-3"></i>
                    <p class="text-sm text-gray-400">@L.Settings_NotificationsComingSoon</p>
                </div>
            }

            @* ==================== Admin sections ==================== *@
            @if (activeSection == "organization")
            {
                <OrganizationSection />
            }

            @if (activeSection == "users")
            {
                <UsersSection />
            }

        </div>
    </div>
</div>

@code {
    Text L = new();
    private string activeSection = "profile";

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    // --- Profile ---
    private string profilePhone = "";
    private string? profileSaveMessage;

    // --- Component Types ---
    private List<string> componentTypes = new();
    private string newComponentType = "";
    private string? componentTypeError;
    private string? componentTypeSaveMessage;

    private static readonly string[] DefaultComponentTypes = ["Bicicleta", "Aro", "Pedal", "Marco", "Rueda", "Otro"];

    // --- Meta Fields ---
    private string selectedEntityType = "Customer";
    private List<MetaFieldDefinition> metaFields = new();
    private bool showFieldForm = false;
    private int? editingFieldId;
    private string fieldLabel = "";
    private string fieldKey = "";
    private string fieldType = "text";
    private bool fieldIsRequired = false;
    private int fieldSortOrder = 0;
    private string fieldRegex = "";
    private string fieldRegexMessage = "";
    private string fieldFormatMask = "";
    private string fieldOptions = "";
    private string fieldConditionalOnId = "";
    private string fieldConditionalOnValue = "";
    private string? fieldError;

    // --- Shop Settings ---
    private string shopName = "";
    private string shopTaxId = "";
    private string shopBusinessType = "";
    private string shopPhone = "";
    private string shopEmail = "";
    private string shopAddress = "";
    private string? shopSaveMessage;

    // --- Language ---
    private string selectedLanguage = "es";

    private string NavClass(string section) =>
        activeSection == section ? "bg-indigo-50 text-indigo-700 font-semibold" : "text-gray-600 hover:bg-gray-50";

    private Dictionary<string, string> EntityTypes => new()
    {
        ["Customer"] = L.Settings_EntityCustomer,
        ["Company"] = L.Settings_EntityCompany,
        ["Conglomerate"] = L.Settings_EntityConglomerate,
        ["Store"] = L.Settings_EntityStore
    };

    protected override async Task OnInitializedAsync()
    {
        if (AuthState != null)
        {
            var state = await AuthState;
            Tenant.PopulateFromClaims(state.User);
        }

        await LoadComponentTypes();
        await LoadMetaFields();
        await LoadShopSettings();
        await LoadProfile();
        await LoadLanguage();
        await I18nText.SetCurrentLanguageAsync(selectedLanguage);
        L = await I18nText.GetTextTableAsync<Text>(this);
    }

    // ===== Profile =====

    private async Task LoadProfile()
    {
        using var context = DbFactory.CreateDbContext();
        var settings = await context.ShopSetting.ToListAsync();
        profilePhone = settings.FirstOrDefault(s => s.Key == "user_phone")?.Value ?? "";
    }

    private async Task SaveProfile()
    {
        profileSaveMessage = null;
        using var context = DbFactory.CreateDbContext();
        var settings = await context.ShopSetting.ToListAsync();
        UpsertSetting(context, settings, "user_phone", profilePhone);
        UpsertSetting(context, settings, "user_language", selectedLanguage);
        await context.SaveChangesAsync();

        await I18nText.SetCurrentLanguageAsync(selectedLanguage);
        L = await I18nText.GetTextTableAsync<Text>(this);
        profileSaveMessage = L.Settings_ProfileSaved;
    }

    // ===== Component Types =====

    private async Task LoadComponentTypes()
    {
        using var context = DbFactory.CreateDbContext();
        var setting = await context.ShopSetting.FirstOrDefaultAsync(s => s.Key == "component_types");
        if (setting is not null && !string.IsNullOrWhiteSpace(setting.Value))
        {
            componentTypes = setting.Value.Split(',', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries).ToList();
        }
        else
        {
            componentTypes = DefaultComponentTypes.ToList();
            await SaveComponentTypes();
        }
    }

    private async Task SaveComponentTypes()
    {
        using var context = DbFactory.CreateDbContext();
        var settings = await context.ShopSetting.ToListAsync();
        UpsertSetting(context, settings, "component_types", string.Join(", ", componentTypes));
        await context.SaveChangesAsync();
    }

    private async Task AddComponentType()
    {
        componentTypeError = null;
        componentTypeSaveMessage = null;

        var trimmed = newComponentType?.Trim() ?? "";
        if (string.IsNullOrWhiteSpace(trimmed)) return;

        if (componentTypes.Any(ct => ct.Equals(trimmed, StringComparison.OrdinalIgnoreCase)))
        {
            componentTypeError = string.Format(L.Settings_TypeAlreadyExists, trimmed);
            return;
        }

        componentTypes.Add(trimmed);
        newComponentType = "";
        await SaveComponentTypes();
        componentTypeSaveMessage = string.Format(L.Settings_TypeAdded, trimmed);
    }

    private async Task RemoveComponentType(string type)
    {
        componentTypeError = null;
        componentTypeSaveMessage = null;

        if (componentTypes.Count <= 1)
        {
            componentTypeError = L.Settings_MinOneType;
            return;
        }

        componentTypes.Remove(type);
        await SaveComponentTypes();
        componentTypeSaveMessage = string.Format(L.Settings_TypeRemoved, type);
    }

    private async Task HandleComponentTypeKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await AddComponentType();
    }

    // ===== Meta Fields =====

    private async Task LoadMetaFields()
    {
        using var context = DbFactory.CreateDbContext();
        metaFields = await context.MetaFieldDefinition
            .Where(f => f.EntityType == selectedEntityType)
            .OrderBy(f => f.SortOrder).ThenBy(f => f.Label)
            .ToListAsync();
    }

    private async Task SwitchEntityType(string entityType)
    {
        selectedEntityType = entityType;
        showFieldForm = false;
        await LoadMetaFields();
    }

    private void ShowAddField()
    {
        editingFieldId = null;
        fieldLabel = ""; fieldKey = ""; fieldType = "text"; fieldIsRequired = false;
        fieldSortOrder = metaFields.Any() ? metaFields.Max(f => f.SortOrder) + 1 : 0;
        fieldRegex = ""; fieldRegexMessage = ""; fieldFormatMask = ""; fieldOptions = "";
        fieldConditionalOnId = ""; fieldConditionalOnValue = ""; fieldError = null;
        showFieldForm = true;
    }

    private void EditField(MetaFieldDefinition field)
    {
        editingFieldId = field.Id;
        fieldLabel = field.Label; fieldKey = field.Key; fieldType = field.FieldType;
        fieldIsRequired = field.IsRequired; fieldSortOrder = field.SortOrder;
        fieldRegex = field.RegexPattern ?? ""; fieldRegexMessage = field.RegexMessage ?? "";
        fieldFormatMask = field.FormatMask ?? ""; fieldOptions = field.Options ?? "";
        fieldConditionalOnId = field.ConditionalOnFieldId?.ToString() ?? "";
        fieldConditionalOnValue = field.ConditionalOnValue ?? ""; fieldError = null;
        showFieldForm = true;
    }

    private void CancelFieldForm() { showFieldForm = false; fieldError = null; }

    private async Task SaveField()
    {
        fieldError = null;

        if (string.IsNullOrWhiteSpace(fieldLabel) || string.IsNullOrWhiteSpace(fieldKey))
        { fieldError = L.Validation_LabelKeyRequired; return; }

        if (fieldType == "select" && string.IsNullOrWhiteSpace(fieldOptions))
        { fieldError = L.Validation_SelectOptionsRequired; return; }

        if (!string.IsNullOrWhiteSpace(fieldRegex))
        {
            try { System.Text.RegularExpressions.Regex.Match("", fieldRegex); }
            catch { fieldError = L.Validation_InvalidRegex; return; }
        }

        using var context = DbFactory.CreateDbContext();

        var duplicate = await context.MetaFieldDefinition
            .AnyAsync(f => f.Key == fieldKey.Trim() && f.Id != (editingFieldId ?? 0));
        if (duplicate) { fieldError = string.Format(L.Validation_DuplicateKey, fieldKey.Trim()); return; }

        int? conditionalId = int.TryParse(fieldConditionalOnId, out var cid) ? cid : null;

        if (editingFieldId.HasValue)
        {
            var field = await context.MetaFieldDefinition.FindAsync(editingFieldId.Value);
            if (field is not null)
            {
                field.Label = fieldLabel.Trim(); field.Key = fieldKey.Trim(); field.FieldType = fieldType;
                field.IsRequired = fieldIsRequired; field.SortOrder = fieldSortOrder;
                field.RegexPattern = NullIfEmpty(fieldRegex); field.RegexMessage = NullIfEmpty(fieldRegexMessage);
                field.FormatMask = NullIfEmpty(fieldFormatMask); field.Options = NullIfEmpty(fieldOptions);
                field.ConditionalOnFieldId = conditionalId; field.ConditionalOnValue = NullIfEmpty(fieldConditionalOnValue);
            }
        }
        else
        {
            context.MetaFieldDefinition.Add(new MetaFieldDefinition
            {
                Label = fieldLabel.Trim(), Key = fieldKey.Trim(), FieldType = fieldType,
                IsRequired = fieldIsRequired, SortOrder = fieldSortOrder, IsActive = true,
                RegexPattern = NullIfEmpty(fieldRegex), RegexMessage = NullIfEmpty(fieldRegexMessage),
                FormatMask = NullIfEmpty(fieldFormatMask), Options = NullIfEmpty(fieldOptions),
                ConditionalOnFieldId = conditionalId, ConditionalOnValue = NullIfEmpty(fieldConditionalOnValue),
            });
        }

        await context.SaveChangesAsync();
        showFieldForm = false;
        await LoadMetaFields();
    }

    private async Task ToggleFieldActive(MetaFieldDefinition field)
    {
        using var context = DbFactory.CreateDbContext();
        var entity = await context.MetaFieldDefinition.FindAsync(field.Id);
        if (entity is not null)
        {
            entity.IsActive = !entity.IsActive;
            await context.SaveChangesAsync();
            await LoadMetaFields();
        }
    }

    // ===== Shop Settings =====

    private async Task LoadShopSettings()
    {
        using var context = DbFactory.CreateDbContext();
        var settings = await context.ShopSetting.ToListAsync();
        shopName = settings.FirstOrDefault(s => s.Key == "shop_name")?.Value ?? "";
        shopTaxId = settings.FirstOrDefault(s => s.Key == "shop_tax_id")?.Value ?? "";
        shopBusinessType = settings.FirstOrDefault(s => s.Key == "shop_business_type")?.Value ?? "";
        shopPhone = settings.FirstOrDefault(s => s.Key == "shop_phone")?.Value ?? "";
        shopEmail = settings.FirstOrDefault(s => s.Key == "shop_email")?.Value ?? "";
        shopAddress = settings.FirstOrDefault(s => s.Key == "shop_address")?.Value ?? "";
    }

    private async Task SaveShopSettings()
    {
        shopSaveMessage = null;
        using var context = DbFactory.CreateDbContext();
        var settings = await context.ShopSetting.ToListAsync();
        UpsertSetting(context, settings, "shop_name", shopName);
        UpsertSetting(context, settings, "shop_tax_id", shopTaxId);
        UpsertSetting(context, settings, "shop_business_type", shopBusinessType);
        UpsertSetting(context, settings, "shop_phone", shopPhone);
        UpsertSetting(context, settings, "shop_email", shopEmail);
        UpsertSetting(context, settings, "shop_address", shopAddress);
        await context.SaveChangesAsync();
        CultureService.Invalidate();
        shopSaveMessage = L.Settings_ConfigSaved;
    }

    // ===== Language =====

    private async Task LoadLanguage()
    {
        using var context = DbFactory.CreateDbContext();
        var setting = await context.ShopSetting.FirstOrDefaultAsync(s => s.Key == "user_language");
        selectedLanguage = setting?.Value ?? "es";
    }

    // ===== Helpers =====

    private void UpsertSetting(BikePOS.Data.BikePosContext context, List<ShopSetting> settings, string key, string value)
    {
        var existing = settings.FirstOrDefault(s => s.Key == key);
        if (existing is not null)
            existing.Value = value?.Trim() ?? "";
        else
            context.ShopSetting.Add(new ShopSetting { Key = key, Value = value?.Trim() ?? "" });
    }

    private static string? NullIfEmpty(string? s) =>
        string.IsNullOrWhiteSpace(s) ? null : s.Trim();
}
