                        </div>
                        <div>
                            <label class="block text-sm text-gray-600 mb-1">@L.Settings_TaxId</label>
                            <input type="text" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300"
                                   @bind="shopTaxId" placeholder="@L.Settings_TaxIdPlaceholder" />
                        </div>
                        <div>
                            <label class="block text-sm text-gray-600 mb-1">@L.Settings_BusinessType</label>
                            <input type="text" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300"
                                   @bind="shopBusinessType" placeholder="@L.Settings_BusinessTypePlaceholder" />
                        </div>
                        <div>
                            <label class="block text-sm text-gray-600 mb-1">@L.Common_Phone</label>
                            <input type="tel" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300"
                                   @bind="shopPhone" placeholder="@L.Settings_ShopPhone" />
                        </div>
                        <div>
                            <label class="block text-sm text-gray-600 mb-1">@L.Common_Email</label>
                            <input type="email" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300"
                                   @bind="shopEmail" placeholder="@L.Settings_ShopEmail" />
                        </div>
                        <div class="col-span-2">
                            <label class="block text-sm text-gray-600 mb-1">@L.Common_Address</label>
                            <input type="text" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300"
                                   @bind="shopAddress" placeholder="@L.Settings_ShopAddress" />
                        </div>
                        <div class="col-span-2">
                            <label class="block text-sm text-gray-600 mb-1">@L.Settings_Locale</label>
                            <input type="text" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm bg-gray-50 text-gray-500"
                                   value="@(Tenant.CompanyName ?? "—")" disabled />
                            <p class="text-xs text-gray-400 mt-1">@L.Settings_LocaleManagedByCompany</p>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(shopSaveMessage))
                    {
                        <div class="text-sm text-green-600 bg-green-50 rounded-lg px-3 py-2 mt-4">@shopSaveMessage</div>
                    }

                    <div class="mt-4">
                        <button class="bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold px-5 py-2 rounded-lg transition-colors"
                                @onclick="SaveShopSettings">@L.Common_Save</button>
                    </div>
                </div>
            }

            @* ==================== Placeholder sections ==================== *@
            @if (activeSection == "billing")
            {
                <h1 class="text-xl font-bold text-gray-800 mb-1">@L.Settings_Billing</h1>
                <p class="text-sm text-gray-500 mb-6">@L.Settings_BillingSubtitle</p>
                <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8 text-center">
                    <i class="fa-solid fa-file-invoice text-gray-300 text-3xl mb-3"></i>
                    <p class="text-sm text-gray-400">@L.Settings_BillingComingSoon</p>
                </div>
            }

            @if (activeSection == "notifications")
            {
                <h1 class="text-xl font-bold text-gray-800 mb-1">@L.Settings_Notifications</h1>
                <p class="text-sm text-gray-500 mb-6">@L.Settings_NotificationsSubtitle</p>
                <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8 text-center">
                    <i class="fa-solid fa-bell text-gray-300 text-3xl mb-3"></i>
                    <p class="text-sm text-gray-400">@L.Settings_NotificationsComingSoon</p>
                </div>
            }

            @* ==================== Role-gated sections ==================== *@
            @if (activeSection == "organization" && IsSuperAdmin)
            {
                <OrganizationSection />
            }

            @if (activeSection == "users" && IsSuperAdmin)
            {
                <UsersSection />
            }

            @if (activeSection == "terminals" && IsAdminOrAbove)
            {
                <TerminalsSection />
            }

            @if (activeSection == "oauth" && IsSuperAdminOrDev)
            {
                <OAuthSection />
            }

        </div>
    </div>
</div>

@code {
    Text L = new();
    private string activeSection = "profile";

    [Parameter]
    public string? Section { get; set; }

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    private static readonly HashSet<string> ValidSections = new(StringComparer.OrdinalIgnoreCase)
    {
        "profile", "components", "meta", "shop", "billing", "notifications", "organization", "users", "terminals", "oauth"
    };

    // --- Profile ---
    private string profilePhone = "";
    private string? profileSaveMessage;

    // --- Component Types ---
    private List<string> componentTypes = new();
    private string newComponentType = "";
    private string? componentTypeError;
    private string? componentTypeSaveMessage;

    private static readonly string[] DefaultComponentTypes = ["Bicicleta", "Aro", "Pedal", "Marco", "Rueda", "Otro"];

    // --- Form Editor ---
    private string selectedEntityType = "Customer";
    private List<MetaFieldDefinition> metaFields = new();
    private List<BaseFieldLayout> baseFields = new();
    private List<EditorBlockGroup> editorBlockGroups = new();
    private string? editorSaveMessage;
    private DotNetObjectReference<Index>? _dotNetRef;
    private bool _dndInitialized;
    private bool showFieldForm = false;
    private string? editingFieldId;
    private string fieldLabel = "";
    private string fieldKey = "";
    private string fieldType = "text";
    private bool fieldIsRequired = false;
    private int fieldSortOrder = 0;
    private string fieldRegex = "";
    private string fieldRegexMessage = "";
    private string fieldFormatMask = "";
    private string fieldDefaultValue = "";
    private string fieldOptions = "";
    private string fieldConditionalOnId = "";
    private string fieldConditionalOnValue = "";
    private string fieldActionEvent = "";
    private string fieldActionScript = "";
    private string fieldBlock = "";
    private string? fieldError;

    // --- Shop Settings ---
    private string shopName = "";
    private string shopTaxId = "";
    private string shopBusinessType = "";
    private string shopPhone = "";
    private string shopEmail = "";
    private string shopAddress = "";
    private string? shopSaveMessage;

    // --- Language ---
    private string selectedLanguage = "es";

    private string NavClass(string section) =>
        activeSection == section ? "bg-indigo-50 text-indigo-700 font-semibold" : "text-gray-600 hover:bg-gray-50";

    private bool IsSuperAdmin => Tenant.Role == StoreRole.SuperAdmin;
    private bool IsSuperAdminOrDev => Tenant.Role == StoreRole.SuperAdmin || Tenant.Role == StoreRole.Developer;
    private bool IsAdminOrAbove => Tenant.Role == StoreRole.SuperAdmin || Tenant.Role == StoreRole.Admin;

    // Sections that require specific roles — anything not listed is available to all Settings users
    private static readonly Dictionary<string, Func<StoreRole, bool>> SectionRoleGuards = new()
    {
        ["organization"] = role => role == StoreRole.SuperAdmin,
        ["users"] = role => role == StoreRole.SuperAdmin,
        ["terminals"] = role => role is StoreRole.SuperAdmin or StoreRole.Admin,
        ["oauth"] = role => role is StoreRole.SuperAdmin or StoreRole.Developer,
        ["meta"] = role => role == StoreRole.SuperAdmin,
    };

    private bool CanAccessSection(string section) =>
        Tenant.Role.HasValue && (!SectionRoleGuards.TryGetValue(section, out var guard) || guard(Tenant.Role.Value));

    protected override void OnParametersSet()
    {
        var requested = ValidSections.Contains(Section ?? "")
            ? Section!.ToLowerInvariant()
            : "profile";

        // Enforce role — fall back to profile if unauthorized
        activeSection = CanAccessSection(requested) ? requested : "profile";
    }

    private void NavigateToSection(string section)
    {
        Navigation.NavigateTo($"/settings/{section}");
    }

    private Dictionary<string, string> EntityTypes => new()
    {
        ["Customer"] = L.Settings_EntityCustomer,
        ["Component"] = L.Settings_EntityComponent,
        ["ServiceTicket"] = L.Settings_EntityServiceTicket,
        ["Company"] = L.Settings_EntityCompany,
        ["Conglomerate"] = L.Settings_EntityConglomerate,
        ["Store"] = L.Settings_EntityStore
    };

    protected override async Task OnInitializedAsync()
    {
        if (AuthState != null)
        {
            var state = await AuthState;
            Tenant.PopulateFromClaims(state.User);
        }

        await LoadComponentTypes();
        await LoadMetaFields();
        await LoadShopSettings();
        await LoadProfile();
        await LoadLanguage();
        await I18nText.SetCurrentLanguageAsync(selectedLanguage);
        L = await I18nText.GetTextTableAsync<Text>(this);
    }

    // ===== Profile =====

    private async Task LoadProfile()
    {
        using var context = DbFactory.CreateDbContext();
        var settings = await context.ShopSetting.ToListAsync();
        profilePhone = settings.FirstOrDefault(s => s.Key == "user_phone")?.Value ?? "";
    }

    private async Task SaveProfile()
    {
        profileSaveMessage = null;
        using var context = DbFactory.CreateDbContext();
        var settings = await context.ShopSetting.ToListAsync();
        UpsertSetting(context, settings, "user_phone", profilePhone);
        UpsertSetting(context, settings, "user_language", selectedLanguage);
        await context.SaveChangesAsync();

        await I18nText.SetCurrentLanguageAsync(selectedLanguage);
        L = await I18nText.GetTextTableAsync<Text>(this);
        profileSaveMessage = L.Settings_ProfileSaved;
    }

    // ===== Component Types =====

    private async Task LoadComponentTypes()
    {
        using var context = DbFactory.CreateDbContext();
        var setting = await context.ShopSetting.FirstOrDefaultAsync(s => s.Key == "component_types");
        if (setting is not null && !string.IsNullOrWhiteSpace(setting.Value))
        {
            componentTypes = setting.Value.Split(',', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries).ToList();
        }
        else
        {
            componentTypes = DefaultComponentTypes.ToList();
            await SaveComponentTypes();
        }
    }

    private async Task SaveComponentTypes()
    {
        using var context = DbFactory.CreateDbContext();
        var settings = await context.ShopSetting.ToListAsync();
        UpsertSetting(context, settings, "component_types", string.Join(", ", componentTypes));
        await context.SaveChangesAsync();
    }

    private async Task AddComponentType()
    {
        componentTypeError = null;
        componentTypeSaveMessage = null;

        var trimmed = newComponentType?.Trim() ?? "";
        if (string.IsNullOrWhiteSpace(trimmed)) return;

        if (componentTypes.Any(ct => ct.Equals(trimmed, StringComparison.OrdinalIgnoreCase)))
        {
            componentTypeError = string.Format(L.Settings_TypeAlreadyExists, trimmed);
            return;
        }

        componentTypes.Add(trimmed);
        newComponentType = "";
        await SaveComponentTypes();
        componentTypeSaveMessage = string.Format(L.Settings_TypeAdded, trimmed);
    }

    private async Task RemoveComponentType(string type)
    {
        componentTypeError = null;
        componentTypeSaveMessage = null;

        if (componentTypes.Count <= 1)
        {
            componentTypeError = L.Settings_MinOneType;
            return;
        }

        componentTypes.Remove(type);
        await SaveComponentTypes();
        componentTypeSaveMessage = string.Format(L.Settings_TypeRemoved, type);
    }

    private async Task HandleComponentTypeKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await AddComponentType();
    }

    // ===== Meta Fields =====

    private static readonly HashSet<string> OrgEntityTypes = new() { "Company", "Conglomerate", "Store" };

    private async Task LoadMetaFields()
    {
        using var context = DbFactory.CreateDbContext();
        var isOrgType = OrgEntityTypes.Contains(selectedEntityType);

        var query = context.MetaFieldDefinition
            .Where(f => f.EntityType == selectedEntityType);
        if (!isOrgType)
            query = query.Where(f => f.CompanyId == Tenant.CompanyId);

        metaFields = await query
            .OrderBy(f => f.SortOrder).ThenBy(f => f.Label)
            .ToListAsync();

        // Auto-apply country presets for company-scoped entity types
        if (!isOrgType)
            await AutoApplyPresets(context);

        // Load base field layouts
        await LoadBaseFields(context);

        // Build merged editor field list
        BuildEditorFields();
    }

    private async Task LoadBaseFields(BikePOS.Data.BikePosContext context)
    {
        var isOrgType = OrgEntityTypes.Contains(selectedEntityType);
        var companyId = isOrgType ? null : Tenant.CompanyId;

        baseFields = await context.BaseFieldLayout
            .Where(b => b.EntityType == selectedEntityType && b.CompanyId == companyId)
            .OrderBy(b => b.SortOrder)
            .ToListAsync();

        // Auto-seed if no base fields exist for this entity type
        if (!baseFields.Any())
        {
            var defaults = BaseFieldLayout.GetBaseFields(selectedEntityType);
            foreach (var d in defaults)
                d.CompanyId = companyId;
            context.BaseFieldLayout.AddRange(defaults);
            await context.SaveChangesAsync();
            baseFields = defaults;
        }
    }

    private void BuildEditorFields()
    {
        var blocks = FormBlockDefinition.GetBlocks(selectedEntityType);
        var defaultBlock = FormBlockDefinition.DefaultBlock(selectedEntityType);
        var allFields = new List<EditorField>();

        foreach (var bf in baseFields)
        {
            allFields.Add(new EditorField
            {
                UniqueId = "base_" + bf.Id,
                BaseFieldId = bf.Id,
                FieldKey = bf.FieldKey,
                Label = bf.Label,
                FieldType = "base",
                SortOrder = bf.SortOrder,
                IsBase = true,
                IsRequired = false,
                Block = bf.Block,
            });
        }

        foreach (var mf in metaFields)
        {
            allFields.Add(new EditorField
            {
                UniqueId = "meta_" + mf.Id,
                MetaFieldId = mf.Id,
                FieldKey = mf.Key,
                Label = mf.Label,
                FieldType = mf.FieldType,
                SortOrder = mf.SortOrder,
                IsBase = false,
                IsRequired = mf.IsRequired,
                MetaField = mf,
                Block = mf.Block ?? defaultBlock,
            });
        }

        editorBlockGroups = blocks.Select(b => new EditorBlockGroup
        {
            BlockKey = b.Key,
            BlockLabel = ResolveBlockLabel(b.LabelKey),
            IsFixed = b.IsFixed,
            DisplayOrder = b.DisplayOrder,
            Fields = allFields
                .Where(f => f.Block == b.Key)
                .OrderBy(f => f.SortOrder).ThenBy(f => f.Label)
                .ToList()
        }).ToList();
    }

    private string ResolveBlockLabel(string labelKey)
    {
        // Use reflection-like lookup on i18n Text object
        var prop = typeof(Text).GetProperty(labelKey);
        if (prop != null) return prop.GetValue(L)?.ToString() ?? labelKey;
        return labelKey;
    }

    private async Task AutoApplyPresets(BikePOS.Data.BikePosContext context)
    {
        var company = await context.Company.FindAsync(Tenant.CompanyId);
        if (company is null || string.IsNullOrEmpty(company.CountryCode)) return;

        var presets = MetaFieldDefinition.GetPresetsForCountry(company.CountryCode, selectedEntityType);
        if (!presets.Any()) return;

        var existing = await context.MetaFieldDefinition
            .Where(f => f.EntityType == selectedEntityType && f.CompanyId == Tenant.CompanyId)
            .ToListAsync();
        var existingByKey = existing.ToDictionary(f => f.Key, StringComparer.OrdinalIgnoreCase);
        var presetKeyToDbId = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
        var changed = false;

        foreach (var preset in presets)
        {
            if (existingByKey.TryGetValue(preset.Key, out var dbField))
            {
                presetKeyToDbId[preset.Key] = dbField.Id;
            }
            else
            {
                preset.CompanyId = Tenant.CompanyId;
                context.MetaFieldDefinition.Add(preset);
                presetKeyToDbId[preset.Key] = preset.Id;
                changed = true;
            }
        }

        // Patch conditional links on existing fields
        foreach (var preset in presets)
        {
            if (preset.ConditionalOnFieldId == null) continue;
            if (!existingByKey.TryGetValue(preset.Key, out var dbField)) continue;
            var parentPreset = presets.FirstOrDefault(p => p.Id == preset.ConditionalOnFieldId);
            if (parentPreset == null) continue;
            var parentDbId = presetKeyToDbId.GetValueOrDefault(parentPreset.Key);
            if (parentDbId != null && (dbField.ConditionalOnFieldId != parentDbId || dbField.ConditionalOnValue != preset.ConditionalOnValue))
            {
                dbField.ConditionalOnFieldId = parentDbId;
                dbField.ConditionalOnValue = preset.ConditionalOnValue;
                changed = true;
            }
        }

        if (changed)
        {
            await context.SaveChangesAsync();
            metaFields = await context.MetaFieldDefinition
                .Where(f => f.EntityType == selectedEntityType && f.CompanyId == Tenant.CompanyId)
                .OrderBy(f => f.SortOrder).ThenBy(f => f.Label)
                .ToListAsync();
        }
    }

    private async Task SwitchEntityType(string entityType)
    {
        selectedEntityType = entityType;
        showFieldForm = false;
        _dndInitialized = false;
        await LoadMetaFields();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (activeSection == "meta" && editorBlockGroups.Any(g => g.Fields.Any()) && !_dndInitialized)
        {
            _dndInitialized = true;
            _dotNetRef ??= DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("FormEditorDnD.init", ".form-editor-block", _dotNetRef);
        }
    }

    [JSInvokable]
    public async Task OnFieldReordered(string blockKey, string[] orderedIds)
    {
        using var context = DbFactory.CreateDbContext();
        var isOrgType = OrgEntityTypes.Contains(selectedEntityType);
        var companyId = isOrgType ? null : Tenant.CompanyId;

        for (int i = 0; i < orderedIds.Length; i++)
        {
            var uid = orderedIds[i];
            if (uid.StartsWith("base_"))
            {
                var id = uid["base_".Length..];
                var bf = await context.BaseFieldLayout.FindAsync(id);
                if (bf != null) { bf.SortOrder = i; bf.Block = blockKey; }
            }
            else if (uid.StartsWith("meta_"))
            {
                var id = uid["meta_".Length..];
                var mf = await context.MetaFieldDefinition.FindAsync(id);
                if (mf != null) { mf.SortOrder = i; mf.Block = blockKey; }
            }
        }

        await context.SaveChangesAsync();

        // Reload to reflect new order
        var metaQuery = context.MetaFieldDefinition
            .Where(f => f.EntityType == selectedEntityType);
        if (!isOrgType)
            metaQuery = metaQuery.Where(f => f.CompanyId == companyId);
        metaFields = await metaQuery.OrderBy(f => f.SortOrder).ThenBy(f => f.Label).ToListAsync();

        baseFields = await context.BaseFieldLayout
            .Where(b => b.EntityType == selectedEntityType && b.CompanyId == companyId)
            .OrderBy(b => b.SortOrder)
            .ToListAsync();

        BuildEditorFields();
        editorSaveMessage = L.Settings_FormEditorSaved;
        await InvokeAsync(StateHasChanged);
    }

    private void ShowAddField()
    {
        editingFieldId = null;
        fieldLabel = ""; fieldKey = ""; fieldType = "text"; fieldIsRequired = false;
        fieldBlock = FormBlockDefinition.DefaultBlock(selectedEntityType);
        var blockFields = editorBlockGroups.SelectMany(g => g.Fields);
        fieldSortOrder = blockFields.Any() ? blockFields.Max(f => f.SortOrder) + 1 : 0;
        fieldRegex = ""; fieldRegexMessage = ""; fieldFormatMask = ""; fieldDefaultValue = ""; fieldOptions = "";
        fieldConditionalOnId = ""; fieldConditionalOnValue = "";
        fieldActionEvent = ""; fieldActionScript = ""; fieldError = null;
        showFieldForm = true;
    }

    private void EditField(MetaFieldDefinition field)
    {
        editingFieldId = field.Id;
        fieldLabel = field.Label; fieldKey = field.Key; fieldType = field.FieldType;
        fieldIsRequired = field.IsRequired; fieldSortOrder = field.SortOrder;
        fieldRegex = field.RegexPattern ?? ""; fieldRegexMessage = field.RegexMessage ?? "";
        fieldFormatMask = field.FormatMask ?? ""; fieldDefaultValue = field.DefaultValue ?? ""; fieldOptions = field.Options ?? "";
        fieldConditionalOnId = field.ConditionalOnFieldId ?? "";
        fieldConditionalOnValue = field.ConditionalOnValue ?? "";
        fieldActionEvent = field.ActionEvent ?? ""; fieldActionScript = field.ActionScript ?? "";
        fieldBlock = field.Block ?? FormBlockDefinition.DefaultBlock(selectedEntityType);
        fieldError = null; showFieldForm = true;
    }

    private void CancelFieldForm() { showFieldForm = false; fieldError = null; }

    private async Task SaveField()
    {
        fieldError = null;

        if (string.IsNullOrWhiteSpace(fieldLabel) || string.IsNullOrWhiteSpace(fieldKey))
        { fieldError = L.Validation_LabelKeyRequired; return; }

        if (fieldType == "select" && string.IsNullOrWhiteSpace(fieldOptions))
        { fieldError = L.Validation_SelectOptionsRequired; return; }

        if (!string.IsNullOrWhiteSpace(fieldRegex))
        {
            try { System.Text.RegularExpressions.Regex.Match("", fieldRegex); }
            catch { fieldError = L.Validation_InvalidRegex; return; }
        }

        // Validate action script — block dangerous patterns server-side
        if (!string.IsNullOrWhiteSpace(fieldActionScript))
        {
            var blocked = new[] { "fetch", "XMLHttpRequest", "import", "require", "eval", "Function",
                "setTimeout", "setInterval", "document.", "window.", "globalThis",
                "localStorage", "sessionStorage", "cookie", "indexedDB", "WebSocket",
                "Worker", "ServiceWorker", "navigator.", "location.", "history." };
            var scriptLower = fieldActionScript;
            if (blocked.Any(b => scriptLower.Contains(b)))
            { fieldError = L.Validation_ActionScriptBlocked; return; }
        }

        using var context = DbFactory.CreateDbContext();

        var isOrgType = OrgEntityTypes.Contains(selectedEntityType);
        var dupQuery = context.MetaFieldDefinition
            .Where(f => f.Key == fieldKey.Trim() && f.EntityType == selectedEntityType && f.Id != (editingFieldId ?? ""));
        if (!isOrgType)
            dupQuery = dupQuery.Where(f => f.CompanyId == Tenant.CompanyId);
        var duplicate = await dupQuery.AnyAsync();
        if (duplicate) { fieldError = string.Format(L.Validation_DuplicateKey, fieldKey.Trim()); return; }

        string? conditionalId = string.IsNullOrWhiteSpace(fieldConditionalOnId) ? null : fieldConditionalOnId;

        if (!string.IsNullOrEmpty(editingFieldId))
        {
            var field = await context.MetaFieldDefinition.FindAsync(editingFieldId);
            if (field is not null)
            {
                field.Label = fieldLabel.Trim(); field.Key = fieldKey.Trim(); field.FieldType = fieldType;
                field.IsRequired = fieldIsRequired; field.SortOrder = fieldSortOrder;
                field.RegexPattern = NullIfEmpty(fieldRegex); field.RegexMessage = NullIfEmpty(fieldRegexMessage);
                field.FormatMask = NullIfEmpty(fieldFormatMask); field.DefaultValue = NullIfEmpty(fieldDefaultValue);
                field.Options = NullIfEmpty(fieldOptions);
                field.ConditionalOnFieldId = conditionalId; field.ConditionalOnValue = NullIfEmpty(fieldConditionalOnValue);
                field.ActionEvent = NullIfEmpty(fieldActionEvent); field.ActionScript = NullIfEmpty(fieldActionScript);
                field.Block = NullIfEmpty(fieldBlock);
            }
        }
        else
        {
            context.MetaFieldDefinition.Add(new MetaFieldDefinition
            {
                EntityType = selectedEntityType,
                CompanyId = isOrgType ? null : Tenant.CompanyId,
                Label = fieldLabel.Trim(), Key = fieldKey.Trim(), FieldType = fieldType,
                IsRequired = fieldIsRequired, SortOrder = fieldSortOrder, IsActive = true,
                RegexPattern = NullIfEmpty(fieldRegex), RegexMessage = NullIfEmpty(fieldRegexMessage),
                FormatMask = NullIfEmpty(fieldFormatMask), DefaultValue = NullIfEmpty(fieldDefaultValue),
                Options = NullIfEmpty(fieldOptions),
                ConditionalOnFieldId = conditionalId, ConditionalOnValue = NullIfEmpty(fieldConditionalOnValue),
                ActionEvent = NullIfEmpty(fieldActionEvent), ActionScript = NullIfEmpty(fieldActionScript),
                Block = NullIfEmpty(fieldBlock),
            });
        }

        await context.SaveChangesAsync();
        showFieldForm = false;
        _dndInitialized = false;
        await LoadMetaFields();
    }

    private async Task ToggleFieldActive(MetaFieldDefinition field)
    {
        using var context = DbFactory.CreateDbContext();
        var entity = await context.MetaFieldDefinition.FindAsync(field.Id);
        if (entity is not null)
        {
            entity.IsActive = !entity.IsActive;
            await context.SaveChangesAsync();
            _dndInitialized = false;
            await LoadMetaFields();
        }
    }

    private async Task DeleteField(MetaFieldDefinition field)
    {
        using var context = DbFactory.CreateDbContext();
        var entity = await context.MetaFieldDefinition.FindAsync(field.Id);
        if (entity is null) return;

        // Remove any meta values referencing this field
        var relatedValues = await context.EntityMetaValue
            .Where(v => v.MetaFieldDefinitionId == field.Id)
            .ToListAsync();
        context.EntityMetaValue.RemoveRange(relatedValues);

        var relatedCustomerValues = await context.CustomerMetaValue
            .Where(v => v.MetaFieldDefinitionId == field.Id)
            .ToListAsync();
        context.CustomerMetaValue.RemoveRange(relatedCustomerValues);

        context.MetaFieldDefinition.Remove(entity);
        await context.SaveChangesAsync();
        _dndInitialized = false;
        await LoadMetaFields();
    }

    // ===== Shop Settings =====

    private async Task LoadShopSettings()
    {
        using var context = DbFactory.CreateDbContext();
        var settings = await context.ShopSetting.ToListAsync();
        shopName = settings.FirstOrDefault(s => s.Key == "shop_name")?.Value ?? "";
        shopTaxId = settings.FirstOrDefault(s => s.Key == "shop_tax_id")?.Value ?? "";
        shopBusinessType = settings.FirstOrDefault(s => s.Key == "shop_business_type")?.Value ?? "";
        shopPhone = settings.FirstOrDefault(s => s.Key == "shop_phone")?.Value ?? "";
        shopEmail = settings.FirstOrDefault(s => s.Key == "shop_email")?.Value ?? "";
        shopAddress = settings.FirstOrDefault(s => s.Key == "shop_address")?.Value ?? "";
    }

    private async Task SaveShopSettings()
    {
        shopSaveMessage = null;
        using var context = DbFactory.CreateDbContext();
        var settings = await context.ShopSetting.ToListAsync();
        UpsertSetting(context, settings, "shop_name", shopName);
        UpsertSetting(context, settings, "shop_tax_id", shopTaxId);
        UpsertSetting(context, settings, "shop_business_type", shopBusinessType);
        UpsertSetting(context, settings, "shop_phone", shopPhone);
        UpsertSetting(context, settings, "shop_email", shopEmail);
        UpsertSetting(context, settings, "shop_address", shopAddress);
        await context.SaveChangesAsync();
        CultureService.Invalidate();
        shopSaveMessage = L.Settings_ConfigSaved;
    }

    // ===== Language =====

    private async Task LoadLanguage()
    {
        using var context = DbFactory.CreateDbContext();
        var setting = await context.ShopSetting.FirstOrDefaultAsync(s => s.Key == "user_language");
        selectedLanguage = setting?.Value ?? "es";
    }

    // ===== Helpers =====

    private void UpsertSetting(BikePOS.Data.BikePosContext context, List<ShopSetting> settings, string key, string value)
    {
        var existing = settings.FirstOrDefault(s => s.Key == key);
        if (existing is not null)
            existing.Value = value?.Trim() ?? "";
        else
            context.ShopSetting.Add(new ShopSetting { Key = key, Value = value?.Trim() ?? "" });
    }

    private static string? NullIfEmpty(string? s) =>
        string.IsNullOrWhiteSpace(s) ? null : s.Trim();

