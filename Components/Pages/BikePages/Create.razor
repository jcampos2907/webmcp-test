@page "/bikes/create"
@using Microsoft.EntityFrameworkCore
@using BikePOS.Models
@inject IDbContextFactory<BikePOS.Data.BikePosContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Create</PageTitle>

<h1>Create</h1>

<h2>Bike</h2>
<hr />
<div class="row">
    <div class="col-md-4">
        <EditForm method="post" Model="Bike" OnValidSubmit="AddBike" FormName="create" Enhance>
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" role="alert"/>
            <div class="mb-3">
                <label for="name" class="form-label">Name:</label> 
                <InputText id="name" @bind-Value="Bike.Name" class="form-control" /> 
                <ValidationMessage For="() => Bike.Name" class="text-danger" /> 
            </div>        
            <div class="mb-3">
                <label for="sku" class="form-label">Sku:</label> 
                <InputText id="sku" @bind-Value="Bike.Sku" class="form-control" /> 
                <ValidationMessage For="() => Bike.Sku" class="text-danger" /> 
            </div>        
            <div class="mb-3">
                <label for="color" class="form-label">Color:</label> 
                <InputText id="color" @bind-Value="Bike.Color" class="form-control" /> 
                <ValidationMessage For="() => Bike.Color" class="text-danger" /> 
            </div>        
            <div class="mb-3">
                <label for="brand" class="form-label">Brand:</label> 
                <InputText id="brand" @bind-Value="Bike.Brand" class="form-control" /> 
                <ValidationMessage For="() => Bike.Brand" class="text-danger" /> 
            </div>        
            <div class="mb-3">
                <label for="price" class="form-label">Price:</label> 
                <InputNumber id="price" @bind-Value="Bike.Price" class="form-control" /> 
                <ValidationMessage For="() => Bike.Price" class="text-danger" /> 
            </div>        
            <button type="submit" class="btn btn-primary">Create</button>
        </EditForm>
    </div>
</div>

<div>
    <a href="/bikes">Back to List</a>
</div>

@code {
    [SupplyParameterFromForm]
    private Bike Bike { get; set; } = default!;

    protected override void OnInitialized() => Bike ??= new();

    // To protect from overposting attacks, see https://learn.microsoft.com/aspnet/core/blazor/forms/#mitigate-overposting-attacks.
    private async Task AddBike()
    {
        using var context = DbFactory.CreateDbContext();
        context.Bike.Add(Bike);
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/bikes");
    }
}
