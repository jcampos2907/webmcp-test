@using BikePOS.Models
@inject TenantContext Tenant
@inject I18nText I18nText
@implements IDisposable

<header class="h-12 bg-white border-b border-gray-200 flex items-center justify-between px-4 flex-shrink-0">
    <div class="flex items-center gap-2 text-sm">
        @if (Tenant.IsResolved)
        {
            <i class="fa-solid fa-building text-gray-400 text-xs"></i>
            <span class="text-gray-500 font-medium">@Tenant.CompanyName</span>
            <i class="fa-solid fa-chevron-right text-gray-300 text-[10px]"></i>
            <i class="fa-solid fa-store text-gray-400 text-xs"></i>
            <span class="text-gray-700 font-semibold">@Tenant.StoreName</span>
        }
    </div>

    <div class="flex items-center gap-3">
        @if (Tenant.IsResolved)
        {
            <span class="text-[10px] bg-indigo-100 text-indigo-600 px-2 py-1 rounded-full font-medium">@GetRoleLabel()</span>
        }
    </div>
</header>

@code {
    Text L = new();

    protected override async Task OnInitializedAsync()
    {
        L = await I18nText.GetTextTableAsync<Text>(this);
        Tenant.OnContextChanged += HandleChanged;
    }

    private string GetRoleLabel() => Tenant.Role switch
    {
        StoreRole.SuperAdmin => L.Settings_RoleSuperAdmin,
        StoreRole.Admin => L.Settings_RoleAdmin,
        StoreRole.Mechanic => L.Settings_RoleMechanic,
        StoreRole.Cashier => L.Settings_RoleCashier,
        StoreRole.Developer => L.Settings_RoleDeveloper,
        _ => ""
    };

    public void Dispose() => Tenant.OnContextChanged -= HandleChanged;

    private void HandleChanged() => InvokeAsync(StateHasChanged);
}
