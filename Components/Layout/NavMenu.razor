@inject NavigationManager NavigationManager

<aside class="w-20 bg-gray-800 flex flex-col items-center py-4 gap-1 flex-shrink-0">
    @* Brand *@
    <a href="/" class="w-12 h-12 bg-indigo-500 rounded-lg flex items-center justify-center mb-4 hover:bg-indigo-600 transition-colors" title="Home">
        <i class="fa-solid fa-cash-register text-white text-lg"></i>
    </a>

    <NavButton Href="/" Icon="fa-house" Label="Home" Match="NavLinkMatch.All" />
    <NavButton Href="/tickets" Icon="fa-ticket" Label="Tickets" />
    <NavButton Href="/bikes" Icon="fa-bicycle" Label="Inventory" />

    <hr class="w-10 border-gray-600 my-2" />

    <NavButton Href="/mechanics" Icon="fa-wrench" Label="Mechanics" />
    <NavButton Href="/services" Icon="fa-gears" Label="Services" />
    <NavButton Href="/products" Icon="fa-box-open" Label="Products" />

    <div class="mt-auto"></div>
</aside>

@code {
    private void Navigate(string url) => NavigationManager.NavigateTo(url);
}
