@using Microsoft.EntityFrameworkCore
@using BikePOS.Models
@inject IDbContextFactory<BikePOS.Data.BikePosContext> DbFactory
@inject TenantContext Tenant
@inject PaymentTerminalService TerminalService

<h1 class="text-xl font-bold text-gray-800 mb-1">@L.Settings_Terminals</h1>
<p class="text-sm text-gray-500 mb-6">@L.Settings_TerminalsSubtitle</p>

<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
    @if (!loaded)
    {
        <p class="text-sm text-gray-400">@L.Common_Loading</p>
    }
    else
    {
        @* Add terminal button *@
        <div class="flex justify-between items-center mb-4">
            <span class="text-sm text-gray-500">
                @(terminals.Count) @(terminals.Count == 1 ? "terminal" : "terminals")
            </span>
            <button class="bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors"
                    @onclick="ShowAddForm">
                <i class="fa-solid fa-plus mr-1"></i> @L.Settings_AddTerminal
            </button>
        </div>

        @* Terminal form (add/edit) *@
        @if (showForm)
        {
            <div class="bg-gray-50 rounded-lg border border-gray-200 p-5 mb-6">
                <h3 class="text-sm font-semibold text-gray-700 mb-4">
                    @(editingTerminal is not null ? L.Settings_EditTerminal : L.Settings_AddTerminal)
                </h3>
                <div class="grid grid-cols-2 gap-4 mb-4">
                    <div>
                        <label class="block text-sm text-gray-600 mb-1">@L.Common_Name <span class="text-red-500">*</span></label>
                        <input type="text" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300"
                               placeholder="@L.Settings_TerminalNamePlaceholder"
                               @bind="formName" />
                    </div>
                    <div>
                        <label class="block text-sm text-gray-600 mb-1">@L.Settings_TerminalProvider <span class="text-red-500">*</span></label>
                        <select class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300"
                                @bind="formProvider">
                            @foreach (var p in Enum.GetValues<TerminalProvider>().Where(p => p != TerminalProvider.Manual))
                            {
                                <option value="@p">@p</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm text-gray-600 mb-1">@L.Settings_TerminalIp <span class="text-red-500">*</span></label>
                        <input type="text" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-indigo-300"
                               placeholder="192.168.1.100"
                               @bind="formIpAddress" />
                    </div>
                    <div>
                        <label class="block text-sm text-gray-600 mb-1">@L.Settings_TerminalPort</label>
                        <input type="number" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-indigo-300"
                               @bind="formPort" />
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(formError))
                {
                    <div class="text-sm text-red-600 bg-red-50 rounded-lg px-3 py-2 mb-3">@formError</div>
                }

                <div class="flex gap-2">
                    <button class="bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold px-5 py-2 rounded-lg transition-colors"
                            @onclick="SaveTerminal">
                        @L.Common_Save
                    </button>
                    <button class="text-sm text-gray-500 hover:text-gray-700 px-4 py-2"
                            @onclick="CancelForm">
                        @L.Common_Cancel
                    </button>
                </div>
            </div>
        }

        @* Terminal list *@
        @if (terminals.Count == 0 && !showForm)
        {
            <div class="text-center py-8 text-gray-400">
                <i class="fa-solid fa-credit-card text-3xl mb-2"></i>
                <p class="text-sm">@L.Settings_NoTerminals</p>
                <p class="text-xs mt-1">@L.Settings_NoTerminalsHint</p>
            </div>
        }
        else
        {
            <div class="space-y-3">
                @foreach (var terminal in terminals)
                {
                    <div class="flex items-center justify-between p-4 rounded-lg border @(terminal.IsActive ? "border-gray-200 bg-white" : "border-gray-100 bg-gray-50 opacity-60")">
                        <div class="flex items-center gap-4">
                            @* Status indicator *@
                            <div class="relative">
                                <i class="fa-solid fa-credit-card text-xl @(terminal.IsActive ? "text-gray-600" : "text-gray-400")"></i>
                                @if (pingResults.TryGetValue(terminal.Id, out var isOnline))
                                {
                                    <div class="absolute -bottom-0.5 -right-0.5 w-3 h-3 rounded-full border-2 border-white @(isOnline ? "bg-green-500" : "bg-red-500")"></div>
                                }
                            </div>
                            <div>
                                <div class="text-sm font-medium text-gray-800">@terminal.Name</div>
                                <div class="text-xs text-gray-500 font-mono">@terminal.IpAddress:@terminal.Port — @terminal.Provider</div>
                                @if (terminal.LastSeenAt.HasValue)
                                {
                                    <div class="text-xs text-gray-400">@L.Settings_TerminalLastSeen: @terminal.LastSeenAt.Value.ToString("g")</div>
                                }
                            </div>
                        </div>
                        <div class="flex items-center gap-2">
                            <button class="text-xs text-indigo-600 hover:text-indigo-800 px-2 py-1 rounded hover:bg-indigo-50 transition-colors"
                                    title="@L.Settings_TerminalTestConnection"
                                    disabled="@(pingInProgress.Contains(terminal.Id))"
                                    @onclick="() => TestConnection(terminal)">
                                <i class="fa-solid @(pingInProgress.Contains(terminal.Id) ? "fa-spinner fa-spin" : "fa-wifi") mr-1"></i>
                                @L.Settings_TerminalTestConnection
                            </button>
                            <button class="text-xs text-gray-500 hover:text-gray-700 px-2 py-1 rounded hover:bg-gray-100 transition-colors"
                                    @onclick="() => EditTerminal(terminal)">
                                <i class="fa-solid fa-pen-to-square mr-1"></i> @L.Common_Edit
                            </button>
                            <button class="text-xs @(terminal.IsActive ? "text-yellow-600 hover:text-yellow-800" : "text-green-600 hover:text-green-800") px-2 py-1 rounded hover:bg-gray-100 transition-colors"
                                    @onclick="() => ToggleActive(terminal)">
                                @(terminal.IsActive ? L.Settings_Deactivate : L.Settings_Activate)
                            </button>
                            <button class="text-xs text-red-500 hover:text-red-700 px-2 py-1 rounded hover:bg-red-50 transition-colors"
                                    @onclick="() => DeleteTerminal(terminal)">
                                <i class="fa-solid fa-trash-can"></i>
                            </button>
                        </div>
                    </div>
                }
            </div>
        }

        @if (!string.IsNullOrEmpty(statusMessage))
        {
            <div class="text-sm @(isError ? "text-red-600 bg-red-50" : "text-green-600 bg-green-50") rounded-lg px-3 py-2 mt-4">@statusMessage</div>
        }
    }
</div>

@code {
    [CascadingParameter] public Text L { get; set; } = default!;
    private bool loaded;
    private List<PaymentTerminal> terminals = new();
    private bool showForm;
    private PaymentTerminal? editingTerminal;

    // Form fields
    private string formName = "";
    private string formIpAddress = "";
    private int formPort = 8080;
    private TerminalProvider formProvider = TerminalProvider.Ingenico;
    private string? formError;

    // Status
    private string? statusMessage;
    private bool isError;
    private Dictionary<string, bool> pingResults = new();
    private HashSet<string> pingInProgress = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadTerminals();
        loaded = true;
    }

    private async Task LoadTerminals()
    {
        using var context = DbFactory.CreateDbContext();
        terminals = await context.PaymentTerminal
            .Where(t => t.StoreId == (Tenant.StoreId ?? ""))
            .OrderBy(t => t.Name)
            .ToListAsync();
    }

    private void ShowAddForm()
    {
        editingTerminal = null;
        formName = "";
        formIpAddress = "";
        formPort = 8080;
        formProvider = TerminalProvider.Ingenico;
        formError = null;
        showForm = true;
    }

    private void EditTerminal(PaymentTerminal terminal)
    {
        editingTerminal = terminal;
        formName = terminal.Name;
        formIpAddress = terminal.IpAddress;
        formPort = terminal.Port;
        formProvider = terminal.Provider;
        formError = null;
        showForm = true;
    }

    private void CancelForm()
    {
        showForm = false;
        editingTerminal = null;
        formError = null;
    }

    private async Task SaveTerminal()
    {
        formError = null;
        statusMessage = null;

        if (string.IsNullOrWhiteSpace(formName))
        {
            formError = L.Settings_TerminalNameRequired;
            return;
        }
        if (string.IsNullOrWhiteSpace(formIpAddress))
        {
            formError = L.Settings_TerminalIpRequired;
            return;
        }

        using var context = DbFactory.CreateDbContext();

        if (editingTerminal is not null)
        {
            var existing = await context.PaymentTerminal.FindAsync(editingTerminal.Id);
            if (existing is not null)
            {
                existing.Name = formName.Trim();
                existing.IpAddress = formIpAddress.Trim();
                existing.Port = formPort;
                existing.Provider = formProvider;
            }
        }
        else
        {
            context.PaymentTerminal.Add(new PaymentTerminal
            {
                StoreId = Tenant.StoreId ?? "",
                Name = formName.Trim(),
                IpAddress = formIpAddress.Trim(),
                Port = formPort,
                Provider = formProvider
            });
        }

        await context.SaveChangesAsync();
        await LoadTerminals();
        showForm = false;
        editingTerminal = null;
        statusMessage = L.Common_SavedSuccess;
        isError = false;
    }

    private async Task ToggleActive(PaymentTerminal terminal)
    {
        statusMessage = null;
        using var context = DbFactory.CreateDbContext();
        var entity = await context.PaymentTerminal.FindAsync(terminal.Id);
        if (entity is not null)
        {
            entity.IsActive = !entity.IsActive;
            await context.SaveChangesAsync();
            await LoadTerminals();
            statusMessage = entity.IsActive ? L.Settings_TerminalActivated : L.Settings_TerminalDeactivated;
            isError = false;
        }
    }

    private async Task DeleteTerminal(PaymentTerminal terminal)
    {
        statusMessage = null;
        using var context = DbFactory.CreateDbContext();
        var entity = await context.PaymentTerminal.FindAsync(terminal.Id);
        if (entity is not null)
        {
            context.PaymentTerminal.Remove(entity);
            await context.SaveChangesAsync();
            await LoadTerminals();
            pingResults.Remove(terminal.Id);
        }
    }

    private async Task TestConnection(PaymentTerminal terminal)
    {
        statusMessage = null;
        pingInProgress.Add(terminal.Id);
        StateHasChanged();

        try
        {
            var provider = TerminalService.GetProvider(terminal.Provider);
            var result = await provider.PingAsync(terminal);
            pingResults[terminal.Id] = result;

            // Update LastSeenAt if successful
            if (result)
            {
                using var context = DbFactory.CreateDbContext();
                var entity = await context.PaymentTerminal.FindAsync(terminal.Id);
                if (entity is not null)
                {
                    entity.LastSeenAt = DateTime.UtcNow;
                    await context.SaveChangesAsync();
                    await LoadTerminals();
                }
                statusMessage = L.Settings_TerminalOnline;
                isError = false;
            }
            else
            {
                statusMessage = L.Settings_TerminalOffline;
                isError = true;
            }
        }
        catch
        {
            pingResults[terminal.Id] = false;
            statusMessage = L.Settings_TerminalOffline;
            isError = true;
        }
        finally
        {
            pingInProgress.Remove(terminal.Id);
        }
    }
}
