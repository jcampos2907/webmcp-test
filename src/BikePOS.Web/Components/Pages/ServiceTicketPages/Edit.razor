    private void AddProduct(Product product)
    {
        var existing = ticketProducts.FirstOrDefault(tp => tp.ProductId == product.Id);
        if (existing is not null)
        {
            existing.Quantity++;
        }
        else
        {
            ticketProducts.Add(new TicketProduct
            {
                ServiceTicketId = ticket!.Id,
                ProductId = product.Id,
                Product = product,
                UnitPrice = product.Price,
                Quantity = 1
            });
        }
    }

    private async Task SaveTicket()
    {
        if (ticket is null || isReadOnly) return;
        if (!ValidateMetaFields()) return;

        using var context = DbFactory.CreateDbContext();
        ticket.Price = CalculateTotal();
        ticket.UpdatedAt = DateTime.UtcNow;
        ticket.UpdatedBy = Tenant.UserIdentifier;
        context.Attach(ticket).State = EntityState.Modified;

        // Restore inventory for removed products
        foreach (var removed in removedProducts)
        {
            context.TicketProduct.Remove(removed);
            var product = await context.Product.FindAsync(removed.ProductId);
            if (product is not null)
            {
                product.QuantityInStock += removed.Quantity;
            }
        }

        foreach (var tp in ticketProducts)
        {
            if (!savedProductIds.Contains(tp.Id))
            {
                // Decrement inventory for new products
                var product = await context.Product.FindAsync(tp.ProductId);
                if (product is not null)
                {
                    product.QuantityInStock -= tp.Quantity;
                }

                // Detach nav property so EF doesn't try to INSERT the existing Product
                var navProduct = tp.Product;
                tp.Product = null!;
                context.TicketProduct.Add(tp);
                tp.Product = navProduct;
            }
            else
            {
                context.Attach(tp).State = EntityState.Modified;
            }
        }

        await SaveMetaValues(context);
        await context.SaveChangesAsync();
        SyncTrigger.TriggerPush("ServiceTicket", ticket.Id);

        // Record timeline events for changes
        var user = Tenant.UserIdentifier;
        var store = Tenant.StoreId;
        if (ticket.Status != originalStatus)
        {
            await TicketEvents.RecordStatusChange(ticket.Id, originalStatus, ticket.Status, user, store);
            // Auto-notify customer when ticket is completed
            if (ticket.Status == TicketStatus.Completed)
            {
                _ = Task.Run(async () =>
                {
                    try { await Notifications.NotifyTicketReadyAsync(ticket.Id); }
                    catch { /* logged inside service */ }
                });
            }
        }
        if (ticket.MechanicId != originalMechanicId)
        {
            var mechName = mechanics.FirstOrDefault(m => m.Id == ticket.MechanicId)?.Name;
            await TicketEvents.RecordMechanicAssigned(ticket.Id, mechName, user, store);
        }
        if (ticket.Description != originalDescription)
            await TicketEvents.RecordNoteUpdated(ticket.Id, user, store);
        if (ticket.DiscountPercent != originalDiscountPercent)
            await TicketEvents.RecordDiscountChanged(ticket.Id, originalDiscountPercent, ticket.DiscountPercent, user, store);
        foreach (var removed in removedProducts)
            await TicketEvents.RecordProductRemoved(ticket.Id, removed.Product?.Name ?? "?", removed.Quantity, user, store);
        foreach (var tp in ticketProducts.Where(tp => !savedProductIds.Contains(tp.Id)))
            await TicketEvents.RecordProductAdded(ticket.Id, tp.Product?.Name ?? "?", tp.Quantity, user, store);

        // Check meta field changes
        foreach (var field in metaFields)
        {
            var oldVal = originalMetaValues.GetValueOrDefault(field.Id, "");
            var newVal = metaValues.GetValueOrDefault(field.Id, "");
            if (oldVal != newVal)
                await TicketEvents.RecordMetaFieldChanged(ticket.Id, field.Label, user, store);
        }

        // Update snapshots
        originalStatus = ticket.Status;
        originalMechanicId = ticket.MechanicId;
        originalDescription = ticket.Description;
        originalDiscountPercent = ticket.DiscountPercent;
        originalMetaValues = new Dictionary<string, string>(metaValues);
        savedProductIds = ticketProducts.Select(tp => tp.Id).ToHashSet();

        removedProducts.Clear();

        // Reload timeline
        using var ctx2 = DbFactory.CreateDbContext();
        await LoadTimeline(ctx2);

        await snackbar.Show();
    }

    private async Task CancelTicket()
    {
        if (ticket is null || isReadOnly) return;

        var success = await CancelTicketHandler.HandleAsync(new CancelTicketRequest(
            ticket.Id, Tenant.UserIdentifier, Tenant.StoreId));

        if (!success) return;

        // Update local state
        ticket.Status = TicketStatus.Cancelled;
        ticketProducts.Clear();
        removedProducts.Clear();

        // Reload timeline
        using var ctx2 = DbFactory.CreateDbContext();
        await LoadTimeline(ctx2);

        await snackbar.Show();
    }

    private async Task ProcessRefund()
    {
        if (ticket is null || refundAmount <= 0 || refundAmount > totalCharged) return;
        refundSuccess = null;

        try
        {
            var domainMethod = (BikePOS.Domain.Aggregates.ServiceTicket.PaymentMethod)(int)refundMethod;
            var result = await RefundHandler.HandleAsync(new ProcessRefundRequest(
                ticket.Id, refundAmount, domainMethod,
                Tenant.UserIdentifier, Tenant.StoreId));

            if (result.ErrorMessage is not null)
            {
                refundSuccess = false;
                return;
            }

            // Update local state
            ticket.Status = TicketStatus.Completed;
            totalCharged -= result.RefundedAmount;
            refundSuccess = true;
            showRefundForm = false;
            refundAmount = 0;

            // Reload timeline
            using var ctx2 = DbFactory.CreateDbContext();
            await LoadTimeline(ctx2);
        }
        catch
        {
            refundSuccess = false;
        }
    }

    private async Task GoToCharge()
    {
        if (ticket is null) return;
        // Save first so the total is up to date
        await SaveTicket();
        NavigationManager.NavigateTo($"/?ticketId={ticket.Id}");
    }

    // ===== Meta Field Helpers =====

    private async Task RunMetaAction(MetaFieldDefinition field, string eventName)
    {
        if (string.IsNullOrEmpty(field.ActionEvent) || string.IsNullOrEmpty(field.ActionScript)) return;
        if (!string.Equals(field.ActionEvent, eventName, StringComparison.OrdinalIgnoreCase)) return;
        var currentVal = GetMetaValue(field.Id);
        var result = await JS.InvokeAsync<string>("MetaFieldActions.execute", field.ActionScript, currentVal);
        if (result != currentVal) { metaValues[field.Id] = result; StateHasChanged(); }
    }

    private async Task OnMetaInput(MetaFieldDefinition field, ChangeEventArgs e)
    {
        var val = e.Value?.ToString() ?? "";
        if (!string.IsNullOrEmpty(field.FormatMask))
            val = await JS.InvokeAsync<string>("MetaFieldActions.applyMask", field.FormatMask, val);
        SetMetaValue(field.Id, val);
        await RunMetaAction(field, "input");
    }

    private async Task OnMetaChange(MetaFieldDefinition field, ChangeEventArgs e)
    {
        SetMetaValue(field.Id, e.Value?.ToString());
        await RunMetaAction(field, "change");
        StateHasChanged();
    }

    private async Task OnMetaBlur(MetaFieldDefinition field)
    {
        await RunMetaAction(field, "blur");
        ValidateMetaField(field);
    }

    private void ValidateMetaField(MetaFieldDefinition field)
    {
        var val = GetMetaValue(field.Id);
        metaFieldErrors.Remove(field.Id);
        if (field.IsRequired && string.IsNullOrWhiteSpace(val))
        {
            metaFieldErrors[field.Id] = string.Format(L.Validation_FieldRequired, field.Label);
            return;
        }
        if (!string.IsNullOrWhiteSpace(val) && !string.IsNullOrWhiteSpace(field.RegexPattern))
        {
            try
            {
                if (!System.Text.RegularExpressions.Regex.IsMatch(val, field.RegexPattern))
                    metaFieldErrors[field.Id] = field.RegexMessage ?? string.Format(L.Validation_InvalidFormat, field.Label);
            }
            catch { }
        }
    }

    private string GetMetaValue(string fieldId) =>
        metaValues.TryGetValue(fieldId, out var val) ? val : "";

    private void SetMetaValue(string fieldId, string? value)
    {
        metaValues[fieldId] = value ?? "";
        metaFieldErrors.Remove(fieldId);
    }

    private bool IsMetaFieldVisible(MetaFieldDefinition field)
    {
        if (string.IsNullOrEmpty(field.ConditionalOnFieldId)) return true;
        var parentValue = GetMetaValue(field.ConditionalOnFieldId);
        return string.Equals(parentValue, field.ConditionalOnValue, StringComparison.OrdinalIgnoreCase);
    }

    private bool ValidateMetaFields()
    {
        metaFieldErrors.Clear();
        foreach (var field in metaFields.Where(IsMetaFieldVisible))
        {
            var val = GetMetaValue(field.Id);
            if (field.IsRequired && string.IsNullOrWhiteSpace(val))
            {
                metaFieldErrors[field.Id] = string.Format(L.Validation_FieldRequired, field.Label);
                continue;
            }
            if (!string.IsNullOrWhiteSpace(val) && !string.IsNullOrWhiteSpace(field.RegexPattern))
            {
                try
                {
                    if (!System.Text.RegularExpressions.Regex.IsMatch(val, field.RegexPattern))
                        metaFieldErrors[field.Id] = field.RegexMessage ?? string.Format(L.Validation_InvalidFormat, field.Label);
                }
                catch { }
            }
        }
        return !metaFieldErrors.Any();
    }

    private async Task SaveMetaValues(BikePOS.Data.BikePosContext context)
    {
        var existing = await context.EntityMetaValue
            .Where(mv => mv.EntityType == "ServiceTicket" && mv.EntityId == ticket!.Id)
            .ToListAsync();

        foreach (var field in metaFields)
        {
            var isVisible = IsMetaFieldVisible(field);
            var val = metaValues.TryGetValue(field.Id, out var v) ? v : null;
            var record = existing.FirstOrDefault(mv => mv.MetaFieldDefinitionId == field.Id);

            if (!isVisible) { if (record is not null) record.Value = null; continue; }

            if (record is not null)
                record.Value = val;
            else if (!string.IsNullOrWhiteSpace(val))
                context.EntityMetaValue.Add(new EntityMetaValue
                {
                    EntityType = "ServiceTicket",
                    EntityId = ticket!.Id,
                    MetaFieldDefinitionId = field.Id,
                    Value = val
                });
        }
    }

