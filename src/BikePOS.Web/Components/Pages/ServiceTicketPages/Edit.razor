@page "/tickets/edit"
@page "/tickets/details"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "SuperAdmin,Admin,Mechanic")]
@using Microsoft.EntityFrameworkCore
@using BikePOS.Models
@using BikePOS.Application.Commands
@using BikePOS.Application.Queries
@inject IDbContextFactory<BikePOS.Data.BikePosContext> DbFactory
@inject ListMechanicsQueryHandler ListMechanicsHandler
@inject ListProductsQueryHandler ListProductsHandler
@inject CancelTicketCommandHandler CancelTicketHandler
@inject ProcessRefundCommandHandler RefundHandler
@inject NavigationManager NavigationManager
@inject ShopCultureService CultureService
@inject TenantContext Tenant
@inject AuditDisplayService AuditDisplay
@inject TicketEventService TicketEvents
@inject NotificationService Notifications
@inject SyncTriggerService SyncTrigger
@inject IJSRuntime JS
@using BikePOS.Components.Shared

<PageTitle>@(isPaid ? L.Tickets_ServiceTicket : L.Common_Edit + " " + L.Tickets_ServiceTicket)</PageTitle>

<div class="p-6 max-w-6xl mx-auto">
    @if (ticket is null)
    {
        <p class="text-sm text-gray-400">Cargando...</p>
    }
    else if (!showProductSelector)
    {
        @if (isPaid)
        {
            <div class="bg-green-50 border border-green-200 rounded-lg px-4 py-3 mb-4 flex items-center justify-between">
                <div class="flex items-center gap-2">
                    <i class="fa-solid fa-circle-check text-green-600"></i>
                    <span class="text-sm text-green-800 font-medium">@L.Tickets_AlreadyChargedBanner</span>
                </div>
                @if (!showRefundForm)
                {
                    <button class="text-sm bg-red-50 hover:bg-red-100 text-red-600 font-medium px-3 py-1.5 rounded-lg border border-red-200 transition-colors"
                            @onclick="() => showRefundForm = true">
                        <i class="fa-solid fa-rotate-left mr-1"></i>@L.Refund_Button
                    </button>
                }
            </div>
        }

        @if (showRefundForm && isPaid)
        {
            <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-4">
                <h4 class="text-sm font-semibold text-red-800 mb-3">@L.Refund_Title</h4>
                <div class="flex items-end gap-4">
                    <div>
                        <label class="block text-xs text-red-700 mb-1">@L.Pos_Amount</label>
                        <input type="number" step="0.01" min="0.01" max="@totalCharged"
                               class="border border-red-300 rounded-lg px-3 py-2 text-sm w-40 focus:outline-none focus:ring-2 focus:ring-red-300"
                               @bind="refundAmount" />
                    </div>
                    <div>
                        <label class="block text-xs text-red-700 mb-1">@L.Pos_PaymentMethod</label>
                        <select class="border border-red-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-red-300"
                                @bind="refundMethod">
                            <option value="@PaymentMethod.Cash">@L.Pos_Cash</option>
                            <option value="@PaymentMethod.Card">@L.Pos_Card</option>
                            <option value="@PaymentMethod.Transfer">@L.Pos_Transfer</option>
                        </select>
                    </div>
                    <button class="bg-red-600 hover:bg-red-700 text-white font-semibold px-4 py-2 rounded-lg transition-colors disabled:opacity-50"
                            @onclick="ProcessRefund"
                            disabled="@(refundAmount <= 0 || refundAmount > totalCharged)">
                        @L.Refund_Process
                    </button>
                    <button class="text-sm text-gray-500 hover:text-gray-700 px-3 py-2"
                            @onclick="() => showRefundForm = false">
                        @L.Common_Cancel
                    </button>
                </div>
                @if (refundSuccess is not null)
                {
                    <div class="mt-2 text-sm @(refundSuccess.Value ? "text-green-700" : "text-red-700")">
                        @(refundSuccess.Value ? L.Refund_Success : L.Refund_Failed)
                    </div>
                }
            </div>
        }

        @if (isCancelled)
        {
            <div class="bg-red-50 border border-red-200 rounded-lg px-4 py-3 mb-4 flex items-center gap-2">
                <i class="fa-solid fa-circle-xmark text-red-600"></i>
                <span class="text-sm text-red-800 font-medium">@L.Tickets_CancelledBanner</span>
            </div>
        }

        <div class="flex gap-6 items-start">
        @* Main ticket card *@
        <div class="flex-1 min-w-0 bg-white rounded-xl shadow-sm border border-gray-200 p-6">
            <div class="flex items-center justify-between mb-1">
                <h2 class="text-xl font-bold text-gray-800">@L.Tickets_ServiceTicket @ticket.TicketDisplay</h2>
                <div class="flex items-center gap-3">
                    <span class="text-xs px-2 py-1 rounded-full @StatusBadgeClass(ticket.Status)">@StatusLabel(ticket.Status)</span>
                    <span class="text-sm text-gray-500">@ticket.CreatedAt.ToString("g", culture)</span>
                </div>
            </div>

            <div class="mb-4">
                <span class="text-sm text-gray-500">@(ticket.Component?.Customer?.FullName ?? "—")</span>
                <span class="text-sm text-gray-800 ml-4 font-medium">@ticket.Component?.Name</span>
                <span class="text-xs text-gray-400 ml-2">(@(ticket.Component?.ComponentType ?? "—"))</span>
            </div>

            <div class="mb-4">
                <p class="text-sm text-gray-700">@(ticket.BaseService?.Name ?? L.Services_NoBaseService)</p>
            </div>

            @* Render ticket fields grouped by block *@
            @foreach (var blockGroup in ticketBlockGroups)
            {
                @foreach (var ff in blockGroup.Fields)
                {
                    @if (ff.IsBase)
                    {
                        @switch (ff.FieldKey)
                        {
                            case "Status":
                                <div class="mb-4">
                                    <label class="block text-sm text-gray-600 mb-1">@L.Common_Status</label>
                                    <select class="border border-gray-300 rounded-lg px-3 py-2 text-sm w-full max-w-xs focus:outline-none focus:ring-2 focus:ring-indigo-300 disabled:bg-gray-100 disabled:text-gray-500"
                                            @bind="ticket.Status" disabled="@isReadOnly">
                                        @foreach (var status in Enum.GetValues<TicketStatus>())
                                        {
                                            <option value="@status">@StatusLabel(status)</option>
                                        }
                                    </select>
                                </div>
                                break;
                            case "Mechanic":
                                <div class="mb-4">
                                    <label class="block text-sm text-gray-600 mb-1">@L.Tickets_AssignedMechanic</label>
                                    <select class="border border-gray-300 rounded-lg px-3 py-2 text-sm w-full max-w-xs focus:outline-none focus:ring-2 focus:ring-indigo-300 disabled:bg-gray-100 disabled:text-gray-500"
                                            @bind="ticket.MechanicId" disabled="@isReadOnly">
                                        <option value="">@L.Tickets_NoMechanic</option>
                                        @foreach (var m in mechanics)
                                        {
                                            <option value="@m.Id">@m.Name</option>
                                        }
                                    </select>
                                </div>
                                break;
                            case "Notes":
                                <div class="mb-4">
                                    <label class="block text-sm font-semibold text-gray-700 mb-1">@L.Common_Notes</label>
                                    <textarea class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300 disabled:bg-gray-100 disabled:text-gray-500"
                                              rows="3" @bind="ticket.Description" placeholder="@L.Common_NotesPlaceholder" disabled="@isReadOnly"></textarea>
                                </div>
                                break;
                            case "DiscountPercent":
                                <div class="mb-4">
                                    <label class="block text-sm text-gray-600 mb-1">@L.Common_DiscountPercent</label>
                                    <input type="number" step="0.01" min="0" max="100"
                                           class="border border-gray-300 rounded-lg px-3 py-2 text-sm w-full max-w-xs focus:outline-none focus:ring-2 focus:ring-indigo-300 disabled:bg-gray-100 disabled:text-gray-500"
                                           @bind="ticket.DiscountPercent" disabled="@isReadOnly" />
                                </div>
                                break;
                        }
                    }
                    else if (ff.MetaField is not null && IsMetaFieldVisible(ff.MetaField))
                    {
                        var field = ff.MetaField;
                        <div class="mb-4">
                            <label class="block text-xs text-gray-500 mb-1">
                                @field.Label
                                @if (field.IsRequired) { <span class="text-red-500">*</span> }
                            </label>
                            @if (field.FieldType == "select" && !string.IsNullOrEmpty(field.Options))
                            {
                                <select class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300 disabled:bg-gray-100 disabled:text-gray-500"
                                        value="@GetMetaValue(field.Id)" disabled="@isReadOnly"
                                        @onchange="e => OnMetaChange(field, e)">
                                    <option value="">@L.Common_Select</option>
                                    @foreach (var opt in field.Options.Split(',', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries))
                                    {
                                        <option value="@opt">@opt</option>
                                    }
                                </select>
                            }
                            else
                            {
                                <input type="@field.FieldType"
                                       class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300 disabled:bg-gray-100 disabled:text-gray-500"
                                       value="@GetMetaValue(field.Id)" disabled="@isReadOnly"
                                       placeholder="@(field.FormatMask ?? "")"
                                       @oninput="e => OnMetaInput(field, e)"
                                       @onfocusout="() => OnMetaBlur(field)" />
                            }
                            @if (metaFieldErrors.TryGetValue(field.Id, out var err))
                            {
                                <p class="text-xs text-red-500 mt-1">@err</p>
                            }
                        </div>
                    }
                }
            }

            @* Products *@
            @if (ticketProducts.Any())
            {
                <div class="mb-4">
                    <h4 class="text-sm font-semibold text-gray-700 mb-2">@L.Common_Products</h4>
                    @foreach (var tp in ticketProducts)
                    {
                        <div class="flex items-center justify-between text-sm py-1 border-b border-gray-100">
                            <span class="text-gray-700">@tp.Product?.Name x @tp.Quantity</span>
                            <div class="flex items-center gap-2">
                                <span class="text-gray-800">@((tp.UnitPrice * tp.Quantity).ToString("C", culture))</span>
                                @if (!isReadOnly)
                                {
                                    <button class="text-red-400 hover:text-red-600 text-xs" @onclick="() => RemoveProduct(tp)">@L.Common_Remove</button>
                                }
                            </div>
                        </div>
                    }
                </div>
            }

            @if (!isReadOnly)
            {
                <button class="text-sm text-indigo-600 hover:underline mb-4 block" @onclick="OpenProductSelector">
                    @L.Common_AddProducts
                </button>
            }

            @* Total *@
            <div class="border-t border-gray-200 pt-3 mb-4">
                @if (ticket.DiscountPercent > 0)
                {
                    <div class="flex justify-between items-center text-sm text-gray-500 mb-1">
                        <span>@L.Common_Subtotal</span>
                        <span>@CalculateSubtotal().ToString("C", culture)</span>
                    </div>
                    <div class="flex justify-between items-center text-sm text-red-500 mb-1">
                        <span>@L.Common_Discount (@ticket.DiscountPercent%)</span>
                        <span>-@((CalculateSubtotal() * ticket.DiscountPercent / 100m).ToString("C", culture))</span>
                    </div>
                }
                <div class="flex justify-between items-center text-sm font-semibold">
                    <span class="text-gray-700">@L.Common_Total</span>
                    <span class="text-gray-800 text-lg">@CalculateTotal().ToString("C", culture)</span>
                </div>
            </div>

            <div class="flex gap-3 items-center">
                @if (!isReadOnly)
                {
                    <button class="bg-indigo-600 hover:bg-indigo-700 text-white font-semibold px-6 py-2 rounded-lg transition-colors"
                            @onclick="SaveTicket">
                        @L.Common_Save
                    </button>
                    <button class="bg-green-600 hover:bg-green-700 text-white font-semibold px-6 py-2 rounded-lg transition-colors"
                            @onclick="GoToCharge">
                        <i class="fa-solid fa-cash-register mr-1"></i> @L.Tickets_Charge
                    </button>
                    @if (!isCancelled)
                    {
                        <button class="bg-red-50 hover:bg-red-100 text-red-600 font-semibold px-4 py-2 rounded-lg transition-colors border border-red-200"
                                @onclick="CancelTicket">
                            @L.Tickets_CancelTicket
                        </button>
                    }
                }
                <a href="/tickets" class="text-sm text-gray-500 hover:text-gray-700 px-4 py-2">&larr; @L.Common_BackToList</a>
            </div>

            @* Audit trail *@
            <div class="mt-6 pt-4 border-t border-gray-100 flex flex-wrap gap-x-6 gap-y-1 text-[11px] text-gray-400">
                @if (!string.IsNullOrEmpty(ticket.CreatedBy))
                {
                    <span><i class="fa-solid fa-user-plus mr-1"></i>@L.Common_CreatedBy @createdByDisplay · @ticket.CreatedAt.ToString("g", culture)</span>
                }
                @if (!string.IsNullOrEmpty(ticket.UpdatedBy))
                {
                    <span><i class="fa-solid fa-pen mr-1"></i>@L.Common_UpdatedBy @updatedByDisplay · @ticket.UpdatedAt.ToString("g", culture)</span>
                }
            </div>

        </div>

        @* Timeline sidebar *@
        <div class="w-72 flex-shrink-0 bg-white rounded-xl shadow-sm border border-gray-200 p-4 sticky top-6 max-h-[calc(100vh-4rem)] overflow-y-auto">
            <h4 class="text-sm font-semibold text-gray-700 mb-4 flex items-center gap-2">
                <i class="fa-solid fa-clock-rotate-left text-gray-400"></i> @L.Tickets_Timeline
            </h4>

            @* Status progress tracker *@
            <div class="mb-6">
                @for (var i = 0; i < statusSteps.Count; i++)
                {
                    var step = statusSteps[i];
                    var isLast = i == statusSteps.Count - 1;
                    var dotBg = step.State == StepState.Completed ? "#22c55e"
                              : step.State == StepState.Current ? "#f97316"
                              : "#e5e7eb";
                    var dotColor = step.State == StepState.Upcoming ? "#9ca3af" : "#ffffff";
                    var lineBg = step.State == StepState.Completed ? "#86efac" : "#e5e7eb";

                    <div class="flex gap-3" style="position: relative; @(!isLast ? "padding-bottom: 1.5rem;" : "")">
                        @* Connector line *@
                        @if (!isLast)
                        {
                            <div style="position: absolute; left: 11px; top: 24px; bottom: 0; width: 2px; background: @lineBg;"></div>
                        }
                        @* Status dot *@
                        <div class="flex-shrink-0 flex items-center justify-center"
                             style="width: 24px; height: 24px; border-radius: 50%; background: @dotBg; color: @dotColor; position: relative; z-index: 1;
                                    @(step.State == StepState.Current ? "box-shadow: 0 0 0 4px rgba(249,115,22,0.2);" : "")">
                            @if (step.State == StepState.Completed)
                            {
                                <i class="fa-solid fa-check" style="font-size: 10px;"></i>
                            }
                            else if (step.State == StepState.Current)
                            {
                                <div style="width: 8px; height: 8px; border-radius: 50%; background: white;"></div>
                            }
                        </div>
                        @* Label + timestamp *@
                        <div style="padding-top: 2px;" class="flex-1">
                            <p class="text-sm" style="@(step.State == StepState.Current ? "font-weight: 600; color: #c2410c;" : step.State == StepState.Completed ? "font-weight: 500; color: #374151;" : "color: #9ca3af;")">
                                @step.Label
                            </p>
                            @if (!string.IsNullOrEmpty(step.Timestamp))
                            {
                                <p class="text-gray-400" style="font-size: 11px;">@step.Timestamp</p>
                            }
                            @if (!string.IsNullOrEmpty(step.Actor))
                            {
                                <p class="text-gray-400" style="font-size: 11px;">@step.Actor</p>
                            }
                        </div>
                    </div>
                }
            </div>

            @* Activity log *@
            @if (timelineItems.Any())
            {
                <div class="border-t border-gray-200 pt-4">
                    <p class="text-[10px] text-gray-400 uppercase tracking-wide mb-3">@L.Tickets_Timeline</p>
                    <EntityTimeline Items="timelineItems" Culture="culture" />
                </div>
            }
        </div>
        </div>
    }
    else
    {
        @* Product Selector *@
        <div class="flex gap-6">
            <div class="flex-1">
                <div class="flex items-center gap-3 mb-4">
                    <button class="text-sm text-gray-500 hover:text-gray-700" @onclick="CloseProductSelector">&larr; Volver</button>
                    <input type="text" class="flex-1 border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300"
                           placeholder="@L.Common_SearchProduct" @bind="productSearch" @bind:event="oninput" @onkeyup="SearchProducts" />
                </div>

                <div class="grid grid-cols-3 gap-4">
                    @foreach (var product in productResults)
                    {
                        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4 cursor-pointer hover:shadow-md hover:border-indigo-300 transition-all"
                             @onclick="() => AddProduct(product)">
                            <div class="w-full h-24 bg-gray-100 rounded-lg mb-3 flex items-center justify-center">
                                <i class="fa-solid fa-box-open text-gray-300 text-3xl"></i>
                            </div>
                            <p class="text-sm font-medium text-gray-800">@product.Name</p>
                            <p class="text-sm text-gray-500">@product.Price.ToString("C", culture)</p>
                        </div>
                    }
                </div>
            </div>

            <div class="w-72 bg-white rounded-xl shadow-sm border border-gray-200 p-4 h-fit sticky top-6">
                <h4 class="text-sm font-bold text-gray-800 mb-1">@L.Tickets_ServiceTicket</h4>
                <p class="text-xs text-gray-500 mb-3">@(ticket.Component?.Customer?.FullName ?? "—")</p>

                <div class="text-xs text-gray-700 mb-1">@(ticket.BaseService?.Name ?? "—")</div>
                <div class="text-xs text-gray-500 mb-3 text-right">@(ticket.BaseService?.DefaultPrice.ToString("C", culture) ?? "—")</div>

                @foreach (var tp in ticketProducts)
                {
                    <div class="flex justify-between text-xs text-gray-700 mb-1">
                        <span>@tp.Product?.Name</span>
                        <span>@((tp.UnitPrice * tp.Quantity).ToString("C", culture))</span>
                    </div>
                }

                <div class="flex justify-between text-sm font-semibold border-t border-gray-200 pt-2 mt-3">
                    <span>@L.Common_Total</span>
                    <span>@CalculateTotal().ToString("C", culture)</span>
                </div>

                <button class="w-full bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold py-2 rounded-lg mt-3 transition-colors"
                        @onclick="SaveAndCloseProducts">
                    @L.Common_Save
                </button>
            </div>
        </div>
    }
</div>

<Snackbar @ref="snackbar" Color="SnackbarColor.Success" Interval="3000" Location="SnackbarLocation.BottomEnd">
    <SnackbarBody>@L.Tickets_TicketSaved</SnackbarBody>
</Snackbar>

@code {
    [CascadingParameter] public Text L { get; set; } = default!;
    CultureInfo culture = CultureInfo.CurrentCulture;

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    [SupplyParameterFromQuery]
    private string Id { get; set; } = "";

    private ServiceTicket? ticket;
    private List<Mechanic> mechanics = new();
    private List<TicketProduct> ticketProducts = new();
    private List<TicketProduct> removedProducts = new();
    private HashSet<string> savedProductIds = new();

    private string? createdByDisplay;
    private string? updatedByDisplay;

    // Timeline
    private List<EntityTimeline.TimelineItem> timelineItems = new();

    // Snapshot for change detection
    private TicketStatus originalStatus;
    private string? originalMechanicId;
    private string? originalDescription;
    private decimal originalDiscountPercent;
    private Dictionary<string, string> originalMetaValues = new();

    // Meta fields + form layout
    private List<MetaFieldDefinition> metaFields = new();
    private Dictionary<string, string> metaValues = new();
    private Dictionary<string, string> metaFieldErrors = new();
    private List<FormBlockGroup> ticketBlockGroups = new();

    private bool isPaid => ticket?.Status == TicketStatus.Charged;
    private bool isCancelled => ticket?.Status == TicketStatus.Cancelled;

    // Refund
    private bool showRefundForm;
    private decimal refundAmount;
    private PaymentMethod refundMethod = PaymentMethod.Cash;
    private bool? refundSuccess;
    private decimal totalCharged;
    private bool isReadOnly => isPaid || isCancelled;

    private Snackbar snackbar = null!;

    // Product selector
    private bool showProductSelector = false;
    private string productSearch = "";
    private List<Product> productResults = new();

    protected override async Task OnInitializedAsync()
    {
        if (AuthState != null)
        {
            var state = await AuthState;
            Tenant.PopulateFromClaims(state.User);
        }

        culture = await CultureService.GetCultureAsync();
        using var context = DbFactory.CreateDbContext();
        ticket = await context.ServiceTicket
            .Include(t => t.Component).ThenInclude(c => c!.Customer)
            .Include(t => t.Mechanic)
            .Include(t => t.BaseService)
            .FirstOrDefaultAsync(t => t.Id == Id);

        if (ticket is null)
        {
            NavigationManager.NotFound();
            return;
        }

        createdByDisplay = await AuditDisplay.ResolveAsync(ticket.CreatedBy);
        updatedByDisplay = await AuditDisplay.ResolveAsync(ticket.UpdatedBy);

        mechanics = await ListMechanicsHandler.HandleAsync();
        ticketProducts = await context.TicketProduct
            .Include(tp => tp.Product)
            .Where(tp => tp.ServiceTicketId == Id)
            .ToListAsync();
        savedProductIds = ticketProducts.Select(tp => tp.Id).ToHashSet();

        // Load meta fields + values
        metaFields = await context.MetaFieldDefinition
            .Where(f => f.IsActive && f.EntityType == "ServiceTicket" && f.CompanyId == Tenant.CompanyId)
            .OrderBy(f => f.SortOrder).ThenBy(f => f.Label)
            .ToListAsync();

        var existingMeta = await context.EntityMetaValue
            .Where(mv => mv.EntityType == "ServiceTicket" && mv.EntityId == Id)
            .ToListAsync();
        foreach (var mv in existingMeta)
            metaValues[mv.MetaFieldDefinitionId] = mv.Value ?? "";

        foreach (var field in metaFields)
        {
            if (!string.IsNullOrEmpty(field.DefaultValue) && !metaValues.ContainsKey(field.Id))
                metaValues[field.Id] = field.DefaultValue;
        }

        // Load base field layouts and build unified form field list
        var baseLayouts = await context.BaseFieldLayout
            .Where(b => b.EntityType == "ServiceTicket" && b.CompanyId == Tenant.CompanyId)
            .OrderBy(b => b.SortOrder)
            .ToListAsync();
        if (!baseLayouts.Any())
        {
            var defaults = BaseFieldLayout.GetBaseFields("ServiceTicket");
            foreach (var d in defaults) d.CompanyId = Tenant.CompanyId;
            context.BaseFieldLayout.AddRange(defaults);
            await context.SaveChangesAsync();
            baseLayouts = defaults;
        }
        BuildTicketFormFields(baseLayouts);

        // Snapshot original values for change detection
        originalStatus = ticket.Status;
        originalMechanicId = ticket.MechanicId;
        originalDescription = ticket.Description;
        originalDiscountPercent = ticket.DiscountPercent;
        originalMetaValues = new Dictionary<string, string>(metaValues);

        // Load total charged for refund cap
        totalCharged = await context.Charge
            .Where(c => c.ServiceTicketId == Id && c.PaymentStatus == PaymentStatus.Completed)
            .SumAsync(c => c.Amount);
        // Subtract any existing refunds
        var refunded = await context.Charge
            .Where(c => c.ServiceTicketId == Id && c.PaymentStatus == PaymentStatus.Completed && c.Amount < 0)
            .SumAsync(c => c.Amount);
        totalCharged += refunded; // refunded is negative, so this subtracts

        // Load timeline
        await LoadTimeline(context);
    }

    private async Task LoadTimeline(BikePOS.Data.BikePosContext context)
    {
        var events = await context.TicketEvent
            .Where(e => e.ServiceTicketId == Id)
            .OrderByDescending(e => e.CreatedAt)
            .ToListAsync();

        timelineItems = new();
        foreach (var evt in events)
        {
            var actor = await AuditDisplay.ResolveAsync(evt.CreatedBy);
            var (bg, color) = EventDotColors(evt.EventType);
            timelineItems.Add(new EntityTimeline.TimelineItem
            {
                Icon = EventIcon(evt.EventType),
                DotBg = bg,
                DotColor = color,
                Title = EventTitle(evt.EventType),
                Description = evt.Description,
                Actor = actor,
                Timestamp = evt.CreatedAt,
            });
        }

        await BuildStatusSteps(context);
    }

