    // Block-based form field ordering
    private void BuildTicketFormFields(List<BaseFieldLayout> baseLayouts)
    {
        var blocks = FormBlockDefinition.GetBlocks("ServiceTicket");
        var defaultBlock = FormBlockDefinition.DefaultBlock("ServiceTicket");
        var editableBaseKeys = new HashSet<string> { "Status", "Mechanic", "Notes", "DiscountPercent" };
        var allFields = new List<FormField>();

        foreach (var bl in baseLayouts.Where(b => editableBaseKeys.Contains(b.FieldKey)))
            allFields.Add(new FormField { FieldKey = bl.FieldKey, SortOrder = bl.SortOrder, IsBase = true, Block = bl.Block });
        foreach (var mf in metaFields)
            allFields.Add(new FormField { FieldKey = mf.Key, SortOrder = mf.SortOrder, IsBase = false, MetaField = mf, Block = mf.Block ?? defaultBlock });

        ticketBlockGroups = blocks
            .Where(b => !b.IsFixed) // Skip fixed blocks (header, products, totals) — rendered structurally
            .OrderBy(b => b.DisplayOrder)
            .Select(b => new FormBlockGroup
            {
                BlockKey = b.Key,
                Fields = allFields.Where(f => f.Block == b.Key).OrderBy(f => f.SortOrder).ThenBy(f => f.FieldKey).ToList()
            })
            .Where(g => g.Fields.Any())
            .ToList();
    }

    private class FormField
    {
        public string FieldKey { get; set; } = "";
        public int SortOrder { get; set; }
        public bool IsBase { get; set; }
        public string Block { get; set; } = "details";
        public MetaFieldDefinition? MetaField { get; set; }
    }

    private class FormBlockGroup
    {
        public string BlockKey { get; set; } = "";
        public List<FormField> Fields { get; set; } = new();
    }

