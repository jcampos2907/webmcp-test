    // ===== Status Progress Tracker =====

    private List<StatusStep> statusSteps = new();

    private enum StepState { Completed, Current, Upcoming }

    private class StatusStep
    {
        public TicketStatus Status { get; set; }
        public string Label { get; set; } = "";
        public StepState State { get; set; }
        public string? Timestamp { get; set; }
        public string? Actor { get; set; }
    }

    private async Task BuildStatusSteps(BikePOS.Data.BikePosContext context)
    {
        var lifecycle = new[] { TicketStatus.Open, TicketStatus.InProgress, TicketStatus.WaitingForParts, TicketStatus.Completed, TicketStatus.Charged };
        var currentStatus = ticket!.Status;
        var currentIndex = Array.IndexOf(lifecycle, currentStatus);

        // Load status-change events to get timestamps per status
        var statusEvents = await context.TicketEvent
            .Where(e => e.ServiceTicketId == ticket.Id &&
                (e.EventType == TicketEventType.StatusChanged || e.EventType == TicketEventType.Created || e.EventType == TicketEventType.Cancelled))
            .OrderBy(e => e.CreatedAt)
            .ToListAsync();

        // Map: which statuses have event timestamps
        var eventByStatus = new Dictionary<TicketStatus, TicketEvent>();
        var createdEvt = statusEvents.FirstOrDefault(e => e.EventType == TicketEventType.Created);
        if (createdEvt != null) eventByStatus[TicketStatus.Open] = createdEvt;

        foreach (var evt in statusEvents.Where(e => e.EventType == TicketEventType.StatusChanged))
        {
            var parts = evt.Description?.Split(" → ");
            if (parts?.Length == 2 && Enum.TryParse<TicketStatus>(parts[1].Trim(), out var toStatus))
                eventByStatus[toStatus] = evt;
        }

        var cancelledEvt = statusEvents.FirstOrDefault(e => e.EventType == TicketEventType.Cancelled);
        statusSteps = new();

        if (currentStatus == TicketStatus.Cancelled)
        {
            // Show all steps up to where we were before cancel, then the cancel step
            foreach (var status in lifecycle)
            {
                var idx = Array.IndexOf(lifecycle, status);
                if (eventByStatus.TryGetValue(status, out var evt))
                {
                    var actor = await AuditDisplay.ResolveAsync(evt.CreatedBy);
                    statusSteps.Add(new StatusStep { Status = status, Label = StatusLabel(status), State = StepState.Completed, Timestamp = evt.CreatedAt.ToString("g", culture), Actor = actor });
                }
                else if (status == TicketStatus.Open)
                {
                    // Open always happened
                    var actor = await AuditDisplay.ResolveAsync(ticket.CreatedBy);
                    statusSteps.Add(new StatusStep { Status = status, Label = StatusLabel(status), State = StepState.Completed, Timestamp = ticket.CreatedAt.ToString("g", culture), Actor = actor });
                }
                else break;
            }
            var cancelActor = cancelledEvt != null ? await AuditDisplay.ResolveAsync(cancelledEvt.CreatedBy) : null;
            statusSteps.Add(new StatusStep { Status = TicketStatus.Cancelled, Label = StatusLabel(TicketStatus.Cancelled), State = StepState.Current, Timestamp = cancelledEvt?.CreatedAt.ToString("g", culture), Actor = cancelActor });
        }
        else
        {
            for (int i = 0; i < lifecycle.Length; i++)
            {
                var status = lifecycle[i];
                StepState state;
                string? timestamp = null;
                string? actor = null;

                if (i < currentIndex)
                {
                    // Past step — completed
                    state = StepState.Completed;
                    if (eventByStatus.TryGetValue(status, out var evt))
                    {
                        timestamp = evt.CreatedAt.ToString("g", culture);
                        actor = await AuditDisplay.ResolveAsync(evt.CreatedBy);
                    }
                    else if (status == TicketStatus.Open)
                    {
                        timestamp = ticket.CreatedAt.ToString("g", culture);
                        actor = await AuditDisplay.ResolveAsync(ticket.CreatedBy);
                    }
                }
                else if (i == currentIndex)
                {
                    // Current step
                    state = StepState.Current;
                    if (eventByStatus.TryGetValue(status, out var evt))
                    {
                        timestamp = evt.CreatedAt.ToString("g", culture);
                        actor = await AuditDisplay.ResolveAsync(evt.CreatedBy);
                    }
                    else if (status == TicketStatus.Open)
                    {
                        timestamp = ticket.CreatedAt.ToString("g", culture);
                        actor = await AuditDisplay.ResolveAsync(ticket.CreatedBy);
                    }
                }
                else
                {
                    state = StepState.Upcoming;
                }

                statusSteps.Add(new StatusStep { Status = status, Label = StatusLabel(status), State = state, Timestamp = timestamp, Actor = actor });
            }
        }
    }

    private decimal CalculateSubtotal()
    {
        var servicePrice = ticket?.BaseService?.DefaultPrice ?? 0;
        var productsTotal = ticketProducts.Sum(tp => tp.UnitPrice * tp.Quantity);
        return servicePrice + productsTotal;
    }

    private decimal CalculateTotal()
    {
        var subtotal = CalculateSubtotal();
        var discount = ticket?.DiscountPercent ?? 0;
        return subtotal - (subtotal * discount / 100m);
    }

    private void RemoveProduct(TicketProduct tp)
    {
        ticketProducts.Remove(tp);
        if (savedProductIds.Contains(tp.Id)) removedProducts.Add(tp);
    }

    private async Task OpenProductSelector()
    {
        showProductSelector = true;
        var all = await ListProductsHandler.HandleAsync();
        productResults = all.Where(p => p.QuantityInStock > 0).ToList();
    }

    private void CloseProductSelector() => showProductSelector = false;

    private async Task SaveAndCloseProducts()
    {
        await SaveTicket();
        showProductSelector = false;
    }

    private async Task SearchProducts()
    {
        var all = await ListProductsHandler.HandleAsync(
            string.IsNullOrWhiteSpace(productSearch) ? null : productSearch);
