    private async Task SelectService(Service service)
    {
        selectedService = service;
        step = 4;
        availableMechanics = await ListMechanicsHandler.HandleAsync();
        using var context = DbFactory.CreateDbContext();
        metaFields = await context.MetaFieldDefinition
            .Where(f => f.IsActive && f.EntityType == "ServiceTicket" && f.CompanyId == Tenant.CompanyId)
            .OrderBy(f => f.SortOrder).ThenBy(f => f.Label)
            .ToListAsync();
        foreach (var field in metaFields)
        {
            if (!string.IsNullOrEmpty(field.DefaultValue) && !metaValues.ContainsKey(field.Id))
                metaValues[field.Id] = field.DefaultValue;
        }

        // Load base field layouts and build unified form field list
        var baseLayouts = await context.BaseFieldLayout
            .Where(b => b.EntityType == "ServiceTicket" && b.CompanyId == Tenant.CompanyId)
            .OrderBy(b => b.SortOrder)
            .ToListAsync();
        if (!baseLayouts.Any())
        {
            var defaults = BaseFieldLayout.GetBaseFields("ServiceTicket");
            foreach (var d in defaults) d.CompanyId = Tenant.CompanyId;
            context.BaseFieldLayout.AddRange(defaults);
            await context.SaveChangesAsync();
            baseLayouts = defaults;
        }
        BuildTicketFormFields(baseLayouts);
    }

