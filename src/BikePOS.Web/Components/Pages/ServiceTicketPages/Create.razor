    private async Task CreateComponent()
    {
        if (string.IsNullOrWhiteSpace(newComponentName)) return;
        using var context = DbFactory.CreateDbContext();
        var component = new Component
        {
            Name = newComponentName, Sku = newComponentSku, Color = newComponentColor,
            Brand = newComponentBrand, ComponentType = newComponentType, CustomerId = selectedCustomer!.Id,
            StoreId = Tenant.StoreId
        };
        context.Component.Add(component);
        await context.SaveChangesAsync();

        // Save component meta values
        foreach (var field in componentMetaFields)
        {
            var val = componentMetaValues.TryGetValue(field.Id, out var v) ? v : null;
            if (!string.IsNullOrWhiteSpace(val) && IsComponentMetaFieldVisible(field))
            {
                context.EntityMetaValue.Add(new EntityMetaValue
                {
                    EntityType = "Component",
                    EntityId = component.Id,
                    MetaFieldDefinitionId = field.Id,
                    Value = val
                });
            }
        }
        await context.SaveChangesAsync();

        showCreateComponent = false;
        newComponentName = ""; newComponentSku = ""; newComponentColor = ""; newComponentBrand = ""; newComponentType = "Bicicleta";
        componentMetaValues.Clear(); componentMetaFieldErrors.Clear();
        SelectComponent(component);
    }

