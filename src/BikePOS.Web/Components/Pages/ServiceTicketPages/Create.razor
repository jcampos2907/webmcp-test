    // --- Save ---
    private async Task SaveTicketInternal(bool navigateToCharge)
    {
        if (!ValidateMetaFields()) return;

        var result = await CreateTicketHandler.HandleAsync(new CreateTicketRequest(
            selectedComponent!.Id,
            selectedCustomer!.Id,
            selectedMechanicId,
            selectedService!.Id,
            selectedService.DefaultPrice,
            ticketNotes,
            discountPercent,
            Tenant.StoreId,
            Tenant.UserIdentifier,
            ticketProducts.Select(tp => new ProductLineRequest(
                tp.Product.Id, tp.Product.Name, tp.UnitPrice, tp.Quantity)).ToList()));

        // Save meta field values (not handled by CreateTicketCommandHandler)
        var visibleMeta = metaFields
            .Where(f => IsMetaFieldVisible(f) && !string.IsNullOrWhiteSpace(metaValues.GetValueOrDefault(f.Id)))
            .ToList();
        if (visibleMeta.Any())
        {
            using var context = DbFactory.CreateDbContext();
            foreach (var field in visibleMeta)
            {
                context.EntityMetaValue.Add(new EntityMetaValue
                {
                    EntityType = "ServiceTicket",
                    EntityId = result.TicketId,
                    MetaFieldDefinitionId = field.Id,
                    Value = metaValues[field.Id]
                });
            }
            await context.SaveChangesAsync();
        }

        NavigationManager.NavigateTo(navigateToCharge ? $"/?ticketId={result.TicketId}" : $"/tickets/details?id={result.TicketId}");
    }

    private Task SaveTicket() => SaveTicketInternal(navigateToCharge: false);
    private Task SaveAndCharge() => SaveTicketInternal(navigateToCharge: true);

