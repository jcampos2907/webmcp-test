@page "/tickets/delete"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "SuperAdmin,Admin")]
@using BikePOS.Models
@using BikePOS.Application.Commands
@using BikePOS.Application.Queries
@inject GetTicketByIdQueryHandler GetTicket
@inject CancelTicketCommandHandler CancelHandler
@inject NavigationManager NavigationManager
@inject ShopCultureService CultureService
@inject TenantContext Tenant

<PageTitle>@L.Tickets_DeleteTitle</PageTitle>

<h1>@L.Common_Delete</h1>

<p>@L.Tickets_ConfirmDelete</p>
<div>
    <h2>@L.Tickets_ServiceTicket</h2>
    <hr />
    @if (serviceticket is null)
    {
        <p><em>@L.Common_Loading</em></p>
    }
    else {
        <dl class="row">
            <dt class="col-sm-2">@L.Common_Status</dt>
            <dd class="col-sm-10">@serviceticket.Status</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">@L.Tickets_Component</dt>
            <dd class="col-sm-10">@serviceticket.Component?.Name (@(serviceticket.Component?.ComponentType ?? "—"))</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">@L.Tickets_Mechanic</dt>
            <dd class="col-sm-10">@(serviceticket.Mechanic?.Name ?? L.Common_Unassigned)</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">Price</dt>
            <dd class="col-sm-10">@serviceticket.Price.ToString("C", culture)</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">Created</dt>
            <dd class="col-sm-10">@serviceticket.CreatedAt.ToString("g", culture)</dd>
        </dl>
        <EditForm method="post" Model="serviceticket" OnValidSubmit="DeleteServiceTicket" FormName="delete" Enhance>
            <button type="submit" class="btn btn-danger" disabled="@(serviceticket is null)">Delete</button> |
            <a href="/tickets">Back to List</a>
        </EditForm>
    }
</div>

@code {
    [CascadingParameter] public Text L { get; set; } = default!;
    CultureInfo culture = CultureInfo.CurrentCulture;
    private ServiceTicket? serviceticket;

    [SupplyParameterFromQuery]
    private string Id { get; set; } = "";

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (AuthState != null) { var s = await AuthState; Tenant.PopulateFromClaims(s.User); }
        culture = await CultureService.GetCultureAsync();
        serviceticket = await GetTicket.HandleAsync(Id);
        if (serviceticket is null) NavigationManager.NotFound();
    }

    private async Task DeleteServiceTicket()
    {
        await CancelHandler.HandleAsync(new CancelTicketRequest(
            serviceticket!.Id, null, Tenant.StoreId));
        NavigationManager.NavigateTo("/tickets");
    }
}
