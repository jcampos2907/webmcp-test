@page "/services/create"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "SuperAdmin,Admin")]
@using Microsoft.EntityFrameworkCore
@using BikePOS.Models
@inject IDbContextFactory<BikePOS.Data.BikePosContext> DbFactory
@inject NavigationManager NavigationManager
@inject TenantContext Tenant

<PageTitle>@L.Services_Create</PageTitle>

<h1>@L.Common_Create</h1>

<h2>@L.Services_Entity</h2>
<hr />
<div class="row">
    <div class="col-md-4">
        <EditForm method="post" Model="Service" OnValidSubmit="AddService" FormName="create" Enhance>
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" role="alert"/>
            <div class="mb-3">
                <span class="text-danger">*</span>
                <label for="name" class="form-label">@L.Common_Name:</label>
                <InputText id="name" @bind-Value="Service.Name" class="form-control" aria-required="true"/> 
                <ValidationMessage For="() => Service.Name" class="text-danger" /> 
            </div>        
            <div class="mb-3">
                <label for="description" class="form-label">@L.Common_Description:</label>
                <InputText id="description" @bind-Value="Service.Description" class="form-control" /> 
                <ValidationMessage For="() => Service.Description" class="text-danger" /> 
            </div>        
            <div class="mb-3">
                <label for="defaultprice" class="form-label">@L.Common_DefaultPrice:</label>
                <InputNumber id="defaultprice" @bind-Value="Service.DefaultPrice" class="form-control" /> 
                <ValidationMessage For="() => Service.DefaultPrice" class="text-danger" /> 
            </div>        
            <div class="mb-3">
                <label for="estimatedminutes" class="form-label">@L.Common_EstimatedMinutes:</label>
                <InputNumber id="estimatedminutes" @bind-Value="Service.EstimatedMinutes" class="form-control" /> 
                <ValidationMessage For="() => Service.EstimatedMinutes" class="text-danger" /> 
            </div>        
            <button type="submit" class="btn btn-primary">@L.Common_Create</button>
        </EditForm>
    </div>
</div>

<div>
    <a href="/services">@L.Common_BackToList</a>
</div>

@code {
    [CascadingParameter] public Text L { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
    }
    [SupplyParameterFromForm]
    private Service Service { get; set; } = default!;

    protected override void OnInitialized() => Service ??= new();

    // To protect from overposting attacks, see https://learn.microsoft.com/aspnet/core/blazor/forms/#mitigate-overposting-attacks.
    private async Task AddService()
    {
        using var context = DbFactory.CreateDbContext();
        Service.StoreId = Tenant.StoreId;
        context.Service.Add(Service);
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/services");
    }
}
