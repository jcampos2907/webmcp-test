@page "/"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "SuperAdmin,Admin,Mechanic,Cashier")]
@implements IAsyncDisposable
@using Microsoft.EntityFrameworkCore
@using BikePOS.Models
@inject IJSRuntime JS
@inject IDbContextFactory<BikePOS.Data.BikePosContext> DbFactory
@inject NavigationManager NavigationManager
@inject ShopCultureService CultureService
@inject TenantContext Tenant
@inject PaymentTerminalService TerminalService
@inject TicketEventService TicketEvents
@inject ReportService ReportSvc
@inject SyncTriggerService SyncTrigger

<PageTitle>@L.Pos_Title</PageTitle>

<div class="p-6">
    @* Header *@
    <div class="flex items-center justify-between mb-6">
        <h1 class="text-2xl font-bold text-gray-800">@L.Pos_Title</h1>
        <div class="flex items-center gap-3">
            <span class="inline-block w-3 h-3 rounded-full @(isOnline ? "bg-green-400" : "bg-red-400")" title="@(isOnline ? L.Pos_Online : L.Pos_Offline)"></span>
            <span class="text-sm text-gray-500">@L.Pos_Cashier: <strong class="text-gray-800">@(Tenant.DisplayName ?? "—")</strong></span>
        </div>
    </div>

    @* Create Service Ticket — Hero Card *@
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-6 cursor-pointer hover:shadow-md transition-shadow"
         @onclick="ShowCreateTicket">
        <div class="flex items-center gap-4">
            <div class="w-14 h-14 bg-indigo-100 rounded-lg flex items-center justify-center">
                <i class="fa-solid fa-file-circle-plus text-indigo-600 text-2xl"></i>
            </div>
            <div>
                <h2 class="text-xl font-semibold text-gray-800">@L.Pos_CreateTicket</h2>
                <p class="text-sm text-gray-500">@L.Pos_CreateTicketDesc</p>
            </div>
        </div>
    </div>

    @* Two cards side by side *@
    <div class="grid grid-cols-2 gap-6 mb-6">
        @* Search Tickets *@
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
            <h3 class="text-lg font-semibold text-gray-800 mb-4">@L.Pos_SearchTicket</h3>
            <div class="mb-3">
                <input type="text" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300"
                       placeholder="@L.Pos_SearchTicketPlaceholder"
                       @bind="ticketSearch" @bind:event="oninput" @onkeyup="SearchTickets" />
            </div>
            @if (searchResults.Any())
            {
                <div class="space-y-2 max-h-48 overflow-y-auto">
                    @foreach (var ticket in searchResults)
                    {
                        <div class="flex items-center justify-between p-2 bg-gray-50 rounded-lg cursor-pointer hover:bg-indigo-50 transition-colors"
                             @onclick="() => SelectTicket(ticket)">
                            <div>
                                <span class="text-sm font-medium text-gray-800">@ticket.TicketDisplay</span>
                                <span class="text-sm text-gray-500 ml-2">@ticket.Component?.Name</span>
                            </div>
                            <span class="text-xs px-2 py-1 rounded-full @GetStatusBadgeClass(ticket.Status)">@ticket.Status</span>
                        </div>
                    }
                </div>
            }
            else if (!string.IsNullOrEmpty(ticketSearch))
            {
                <p class="text-sm text-gray-400">@L.Pos_NoTicketsFound</p>
            }
        </div>

        @* Customer Lookup *@
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
            <h3 class="text-lg font-semibold text-gray-800 mb-4">@L.Pos_SearchCustomer</h3>
            <div class="mb-3">
                <input type="text" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300"
                       placeholder="@L.Pos_SearchCustomerPlaceholder"
                       @bind="customerSearch" @bind:event="oninput" @onkeyup="SearchCustomers" />
            </div>
            @if (customerResults.Any())
            {
                <div class="space-y-2 max-h-48 overflow-y-auto">
                    @foreach (var customer in customerResults)
                    {
                        <div class="flex items-center justify-between p-2 bg-gray-50 rounded-lg">
                            <div>
                                <span class="text-sm font-medium text-gray-800">@customer.FullName</span>
                                <span class="text-xs text-gray-400 ml-2">@customer.Phone</span>
                            </div>
                            <span class="text-xs text-gray-500">@customer.Email</span>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    @* Charge / Selected Ticket + Recent Charges *@
    <div class="grid grid-cols-2 gap-6">
        @* Process Charge *@
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
            <h3 class="text-lg font-semibold text-gray-800 mb-4">@L.Pos_ProcessCharge</h3>
            @if (selectedTicket is not null)
            {
                @* Ticket info header *@
                <div class="bg-indigo-50 rounded-lg p-3 mb-4">
                    <div class="flex justify-between text-sm">
                        <span class="text-gray-600">@selectedTicket.TicketDisplay</span>
                        <span class="font-semibold text-gray-800">@selectedTicket.Component?.Name</span>
                    </div>
                    <div class="flex justify-between text-sm mt-1">
                        <span class="text-gray-600">@(selectedTicket.Mechanic?.Name ?? L.Common_Unassigned)</span>
                        <span class="font-bold text-indigo-600">@selectedTicket.Price.ToString("C", culture)</span>
                    </div>
                </div>

                @* Previous payments on this ticket (partial payments) *@
                @if (ticketCharges.Any())
                {
                    <div class="bg-amber-50 border border-amber-200 rounded-lg p-3 mb-4">
                        <p class="text-xs font-semibold text-amber-700 uppercase mb-1">@L.Pos_PreviousPayments</p>
                        @foreach (var c in ticketCharges)
                        {
                            <div class="flex justify-between text-xs text-amber-800">
                                <span>@c.PaymentMethod — @c.ChargedAt.ToLocalTime().ToString("g", culture)</span>
                                <span class="font-medium">@c.Amount.ToString("C", culture)</span>
                            </div>
                        }
                        <div class="flex justify-between text-sm font-bold text-amber-900 mt-1 pt-1 border-t border-amber-300">
                            <span>@L.Pos_RemainingBalance</span>
                            <span>@remainingBalance.ToString("C", culture)</span>
                        </div>
                    </div>
                }

                @* Terminal waiting overlay *@
                @if (terminalPolling)
                {
                    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6 mb-4 text-center">
                        <i class="fa-solid fa-spinner fa-spin text-blue-500 text-2xl mb-3"></i>
                        <p class="text-sm text-blue-700 font-medium">@L.Pos_WaitingForTerminal</p>
                        <p class="text-xs text-blue-500 mt-1">@selectedTerminal?.Name</p>
                        <button class="mt-3 text-xs text-red-500 hover:text-red-700 underline"
                                @onclick="CancelTerminalPayment">
                            @L.Pos_CancelTerminalPayment
                        </button>
                    </div>
                }
                else
                {
                    @* Amount input with partial payment toggle *@
                    <div class="mb-3">
                        <div class="flex items-center justify-between mb-1">
                            <label class="block text-sm text-gray-600">@L.Pos_Amount</label>
                            @if (remainingBalance > 0)
                            {
                                <label class="flex items-center gap-1.5 text-xs text-gray-500 cursor-pointer">
                                    <input type="checkbox" class="rounded border-gray-300" @bind="isPartialPayment" @bind:after="OnPartialToggle" />
                                    @L.Pos_PartialPayment
                                </label>
                            }
                        </div>
                        <input type="number" step="0.01" min="0" max="@remainingBalance"
                               class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300"
                               @bind="chargeAmount"
                               disabled="@(!isPartialPayment && ticketCharges.Count == 0)" />
                        @if (isPartialPayment)
                        {
                            <p class="text-xs text-gray-400 mt-1">@L.Pos_DepositAmount — max @remainingBalance.ToString("C", culture)</p>
                        }
                    </div>

                    @* Payment method selector *@
                    <div class="mb-4">
                        <label class="block text-sm text-gray-600 mb-1">@L.Pos_PaymentMethod</label>
                        <select class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300"
                                @bind="selectedPaymentMethod">
                            <option value="@PaymentMethod.Cash">@L.Pos_Cash</option>
                            <option value="@PaymentMethod.Card">@L.Pos_Card</option>
                            <option value="@PaymentMethod.Transfer">@L.Pos_Transfer</option>
                        </select>
                    </div>

                    @* Terminal selector (only for Card payments) *@
                    @if (selectedPaymentMethod == PaymentMethod.Card)
                    {
                        <div class="mb-4">
                            <label class="block text-sm text-gray-600 mb-1">@L.Pos_SelectTerminal</label>
                            @if (storeTerminals.Any())
                            {
                                <select class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300"
                                        @bind="selectedTerminalId">
                                    <option value="">@L.Common_Select</option>
                                    @foreach (var t in storeTerminals)
                                    {
                                        <option value="@t.Id">@t.Name (@t.Provider — @t.IpAddress)</option>
                                    }
                                </select>
                            }
                            else
                            {
                                <p class="text-xs text-amber-600 bg-amber-50 rounded-lg px-3 py-2">
                                    <i class="fa-solid fa-triangle-exclamation mr-1"></i>@L.Pos_NoTerminalsConfigured
                                </p>
                            }
                        </div>
                    }

                    <button class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-2 rounded-lg transition-colors disabled:opacity-50"
                            @onclick="ProcessCharge"
                            disabled="@(!isOnline || chargeAmount <= 0 || (selectedPaymentMethod == PaymentMethod.Card && string.IsNullOrEmpty(selectedTerminalId)))">
                        @L.Pos_ProcessChargeButton
                    </button>
                }

                @if (chargeSuccess is not null)
                {
                    <div class="mt-3 p-2 rounded-lg text-sm text-center @(chargeSuccess.Value ? "bg-green-100 text-green-700" : "bg-red-100 text-red-700")">
                        @if (chargeSuccess.Value)
                        {
                            <span>@L.Pos_ChargeSuccess</span>
                            @if (!string.IsNullOrEmpty(lastChargeId))
                            {
                                <button class="ml-2 underline font-medium" @onclick="PrintReceipt">
                                    <i class="fa-solid fa-print mr-1"></i>@L.Receipt_Print
                                </button>
                            }
                        }
                        else
                        {
                            @(chargeError ?? L.Pos_ChargeFailed)
                        }
                    </div>
                }
            }
            else
            {
                <p class="text-sm text-gray-400">@L.Pos_SelectTicketHint</p>
            }
        </div>

        @* Recent Charges *@
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
            <h3 class="text-lg font-semibold text-gray-800 mb-4">@L.Pos_RecentCharges</h3>
            @if (recentCharges.Any())
            {
                <div class="space-y-2 max-h-64 overflow-y-auto">
                    @foreach (var charge in recentCharges)
                    {
                        <div class="flex items-center justify-between p-2 bg-gray-50 rounded-lg">
                            <div>
                                <span class="text-sm font-medium text-gray-800">@charge.Amount.ToString("C", culture)</span>
                                <span class="text-xs text-gray-400 ml-2">@(charge.ServiceTicket?.TicketDisplay ?? charge.ServiceTicketId)</span>
                            </div>
                            <div class="text-right">
                                <span class="text-xs px-2 py-1 rounded-full bg-blue-100 text-blue-700">@charge.PaymentMethod</span>
                                <div class="text-xs text-gray-400 mt-1">@charge.ChargedAt.ToLocalTime().ToString("g", culture)</div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="text-sm text-gray-400">@L.Pos_NoCharges</p>
            }
        </div>
    </div>
</div>

@* Hidden receipt for print *@
@if (receiptData is not null)
{
    <div class="receipt-print">
        <div class="receipt-header">
            <h2>@receiptData.StoreName</h2>
            @if (!string.IsNullOrEmpty(receiptData.StoreAddress)) { <p>@receiptData.StoreAddress</p> }
            @if (!string.IsNullOrEmpty(receiptData.StorePhone)) { <p>@L.Common_Phone: @receiptData.StorePhone</p> }
            @if (!string.IsNullOrEmpty(receiptData.CompanyTaxId)) { <p>@L.Receipt_TaxId: @receiptData.CompanyTaxId</p> }
        </div>
        <div class="receipt-info">
            <p><strong>@receiptData.TicketDisplay</strong> — @receiptData.ChargeDate.ToLocalTime().ToString("g", culture)</p>
            @if (!string.IsNullOrEmpty(receiptData.CustomerName)) { <p>@L.Receipt_Customer: @receiptData.CustomerName</p> }
            @if (!string.IsNullOrEmpty(receiptData.ComponentName)) { <p>@L.Receipt_Component: @receiptData.ComponentName</p> }
            @if (!string.IsNullOrEmpty(receiptData.ServiceName)) { <p>@L.Receipt_Service: @receiptData.ServiceName</p> }
        </div>
        @if (receiptData.Products.Any())
        {
            <table class="receipt-items">
                <thead>
                    <tr>
                        <th>@L.Receipt_Item</th>
                        <th>@L.Receipt_Qty</th>
                        <th>@L.Common_Total</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in receiptData.Products)
                    {
                        <tr>
                            <td>@item.Name</td>
                            <td>@item.Quantity x @item.UnitPrice.ToString("C", culture)</td>
                            <td>@item.LineTotal.ToString("C", culture)</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        <div class="receipt-totals">
            @if (receiptData.DiscountPercent > 0)
            {
                <div class="total-line"><span>@L.Common_Subtotal</span><span>@receiptData.Subtotal.ToString("C", culture)</span></div>
                <div class="total-line"><span>@L.Common_Discount (@receiptData.DiscountPercent%)</span><span>-@((receiptData.Subtotal - receiptData.Total).ToString("C", culture))</span></div>
            }
            <div class="total-line grand-total"><span>@L.Common_Total</span><span>@receiptData.Total.ToString("C", culture)</span></div>
        </div>
        <div class="receipt-payment">
            <p>@L.Receipt_PaymentMethod: @receiptData.PaymentMethod</p>
            <p>@L.Receipt_AmountPaid: @receiptData.AmountPaid.ToString("C", culture)</p>
            @if (!string.IsNullOrEmpty(receiptData.CashierName)) { <p>@L.Pos_Cashier: @receiptData.CashierName</p> }
        </div>
        <div class="receipt-footer">
            <p>@L.Receipt_ThankYou</p>
        </div>
    </div>
}

@code {
    [CascadingParameter] public Text L { get; set; } = default!;
    CultureInfo culture = CultureInfo.CurrentCulture;

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    protected override async Task OnInitializedAsync()
    {
        culture = await CultureService.GetCultureAsync();

        if (AuthState != null)
        {
            var state = await AuthState;
            Tenant.PopulateFromClaims(state.User);
        }

        await LoadStoreTerminals();
    }

    private IJSObjectReference? module;
    private DotNetObjectReference<Home>? dotNetRef;

    private bool isOnline = true;

    [SupplyParameterFromQuery]
    private string? ticketId { get; set; }

    // Ticket search
    private string ticketSearch = "";
    private List<ServiceTicket> searchResults = new();
    private ServiceTicket? selectedTicket;

    // Customer search
    private string customerSearch = "";
    private List<Customer> customerResults = new();

    // Charge
    private decimal chargeAmount;
    private PaymentMethod selectedPaymentMethod = PaymentMethod.Cash;
    private bool? chargeSuccess;
    private string? chargeError;
    private List<Charge> recentCharges = new();

    // Terminal
    private List<PaymentTerminal> storeTerminals = new();
    private string selectedTerminalId = "";
    private PaymentTerminal? selectedTerminal => storeTerminals.FirstOrDefault(t => t.Id == selectedTerminalId);
    private bool terminalPolling;
    private CancellationTokenSource? pollCts;

    // Partial payments
    private List<Charge> ticketCharges = new();
    private decimal remainingBalance;
    private bool isPartialPayment;

    // Receipt
    private string? lastChargeId;
    private ReceiptData? receiptData;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            module = await JS.InvokeAsync<IJSObjectReference>("import",
                "./Components/Pages/Home.razor.js");

            dotNetRef = DotNetObjectReference.Create(this);
            await module.InvokeVoidAsync("initialize", dotNetRef);
            await module.InvokeVoidAsync("addOnlineStatusListener");

            await LoadRecentCharges();

            // Auto-select ticket if ticketId query param is provided
            if (!string.IsNullOrEmpty(ticketId))
            {
                using var context = DbFactory.CreateDbContext();
                var t = await context.ServiceTicket
                    .Include(t => t.Component)
                    .Include(t => t.Mechanic)
                    .FirstOrDefaultAsync(t => t.Id == ticketId);
                if (t is not null)
                {
                    await SelectTicket(t);
                }
            }

            StateHasChanged();
        }
    }

    private async Task LoadStoreTerminals()
    {
        using var context = DbFactory.CreateDbContext();
        storeTerminals = await context.PaymentTerminal
            .Where(t => t.StoreId == Tenant.StoreId && t.IsActive)
            .OrderBy(t => t.Name)
            .ToListAsync();

        if (storeTerminals.Count == 1)
            selectedTerminalId = storeTerminals[0].Id;
    }

    private async Task SearchTickets()
    {
        if (string.IsNullOrWhiteSpace(ticketSearch))
        {
            searchResults.Clear();
            return;
        }

        using var context = DbFactory.CreateDbContext();
        var query = context.ServiceTicket
            .Include(t => t.Component)
            .Include(t => t.Mechanic)
            .Where(t => t.Status != TicketStatus.Cancelled && t.Status != TicketStatus.Charged);

        if (int.TryParse(ticketSearch, out var searchNum))
        {
            query = query.Where(t => t.TicketNumber == searchNum);
        }
        else
        {
            query = query.Where(t => t.Component.Name!.Contains(ticketSearch));
        }

        searchResults = await query.OrderByDescending(t => t.CreatedAt).Take(10).ToListAsync();
    }

    private async Task SearchCustomers()
    {
        if (string.IsNullOrWhiteSpace(customerSearch))
        {
            customerResults.Clear();
            return;
        }

        using var context = DbFactory.CreateDbContext();
        customerResults = await context.Customer
            .Where(c => c.FirstName.Contains(customerSearch) || c.LastName.Contains(customerSearch) ||
                   (c.Phone != null && c.Phone.Contains(customerSearch)) ||
                   (c.Email != null && c.Email.Contains(customerSearch)))
            .Take(10)
            .ToListAsync();
    }

    private async Task SelectTicket(ServiceTicket ticket)
    {
        selectedTicket = ticket;
        chargeSuccess = null;
        chargeError = null;
        isPartialPayment = false;

        // Load existing charges for this ticket (partial payments)
        using var context = DbFactory.CreateDbContext();
        ticketCharges = await context.Charge
            .Where(c => c.ServiceTicketId == ticket.Id && c.PaymentStatus == PaymentStatus.Completed)
            .OrderBy(c => c.ChargedAt)
            .ToListAsync();

        var totalPaid = ticketCharges.Sum(c => c.Amount);
        remainingBalance = ticket.Price - totalPaid;
        chargeAmount = remainingBalance;
    }

    private void OnPartialToggle()
    {
        if (!isPartialPayment)
            chargeAmount = remainingBalance;
    }

    private async Task ProcessCharge()
    {
        if (selectedTicket is null || chargeAmount <= 0) return;
        chargeError = null;

        // Prevent charging cancelled tickets
        if (selectedTicket.Status == TicketStatus.Cancelled)
        {
            chargeError = L.Pos_ErrorCancelled;
            chargeSuccess = false;
            return;
        }

        // Prevent charging already fully charged tickets
        if (selectedTicket.Status == TicketStatus.Charged)
        {
            chargeError = L.Pos_ErrorAlreadyCharged;
            chargeSuccess = false;
            return;
        }

        // Prevent charging $0 tickets
        if (selectedTicket.Price <= 0)
        {
            chargeError = L.Pos_ErrorZeroTotal;
            chargeSuccess = false;
            return;
        }

        // Cap charge at remaining balance
        var amount = Math.Min(chargeAmount, remainingBalance);

        // Card payment → send to terminal
        if (selectedPaymentMethod == PaymentMethod.Card && selectedTerminal is not null)
        {
            await ProcessTerminalPayment(amount);
            return;
        }

        // Cash/Transfer → immediate completion
        await CreateCharge(amount, PaymentStatus.Completed);
    }

    private async Task ProcessTerminalPayment(decimal amount)
    {
        var terminal = selectedTerminal;
        if (terminal is null) return;

        terminalPolling = true;
        pollCts = new CancellationTokenSource();
        StateHasChanged();

        try
        {
            var provider = TerminalService.GetProvider(terminal.Provider);
            var request = new PaymentRequest(amount, "");

            // Send payment to terminal
            var session = await provider.CreatePaymentAsync(terminal, request);

            if (session.Status == PaymentSessionStatus.Completed)
            {
                // Instant completion (e.g., ManualPaymentProvider or fast terminal)
                await CreateCharge(amount, PaymentStatus.Completed, session.ExternalRef);
                return;
            }

            // Poll for result
            var externalRef = session.ExternalRef ?? "";
            var maxAttempts = 60; // ~2 minutes at 2s intervals
            for (var i = 0; i < maxAttempts && !pollCts.Token.IsCancellationRequested; i++)
            {
                await Task.Delay(2000, pollCts.Token);
                var status = await provider.GetStatusAsync(terminal, externalRef);

                if (status == PaymentSessionStatus.Completed)
                {
                    await CreateCharge(amount, PaymentStatus.Completed, externalRef);
                    return;
                }
                if (status is PaymentSessionStatus.Failed or PaymentSessionStatus.Cancelled)
                {
                    chargeError = L.Pos_TerminalPaymentFailed;
                    chargeSuccess = false;
                    return;
                }
            }

            // Timeout
            chargeError = L.Pos_TerminalPaymentFailed;
            chargeSuccess = false;
        }
        catch (OperationCanceledException)
        {
            // User cancelled — try to cancel on terminal too
            if (terminal is not null)
            {
                try
                {
                    var provider = TerminalService.GetProvider(terminal.Provider);
                    await provider.CancelAsync(terminal, "");
                }
                catch { }
            }
            chargeError = L.Pos_TerminalPaymentFailed;
            chargeSuccess = false;
        }
        catch
        {
            chargeError = L.Pos_ChargeFailed;
            chargeSuccess = false;
        }
        finally
        {
            terminalPolling = false;
            pollCts?.Dispose();
            pollCts = null;
            StateHasChanged();
        }
    }

    private void CancelTerminalPayment()
    {
        pollCts?.Cancel();
    }

    private async Task CreateCharge(decimal amount, PaymentStatus paymentStatus, string? externalRef = null)
    {
        try
        {
            using var context = DbFactory.CreateDbContext();
            var charge = new Charge
            {
                ServiceTicketId = selectedTicket!.Id,
                Amount = amount,
                ChargedAt = DateTime.UtcNow,
                CashierName = Tenant.UserIdentifier,
                PaymentMethod = selectedPaymentMethod,
                PaymentStatus = paymentStatus,
                CompletedAt = paymentStatus == PaymentStatus.Completed ? DateTime.UtcNow : null,
                ExternalTransactionId = externalRef,
                StoreId = Tenant.StoreId,
                CreatedBy = Tenant.UserIdentifier
            };

            context.Charge.Add(charge);

            // Save the charge first to get its Id
            await context.SaveChangesAsync();

            // If a terminal session was used, persist it linked to the charge
            if (selectedPaymentMethod == PaymentMethod.Card && selectedTerminal is not null)
            {
                context.PaymentSession.Add(new PaymentSession
                {
                    ChargeId = charge.Id,
                    TerminalId = selectedTerminal.Id,
                    Status = paymentStatus == PaymentStatus.Completed
                        ? PaymentSessionStatus.Completed
                        : PaymentSessionStatus.Pending,
                    Amount = amount,
                    ExternalRef = externalRef,
                    CompletedAt = paymentStatus == PaymentStatus.Completed ? DateTime.UtcNow : null
                });
                await context.SaveChangesAsync();
            }

            // Check if ticket is fully paid
            var totalPaid = await context.Charge
                .Where(c => c.ServiceTicketId == selectedTicket.Id && c.PaymentStatus == PaymentStatus.Completed)
                .SumAsync(c => c.Amount);

            var ticket = await context.ServiceTicket.FindAsync(selectedTicket.Id);
            if (ticket is not null && totalPaid >= ticket.Price)
            {
                ticket.Status = TicketStatus.Charged;
                ticket.UpdatedAt = DateTime.UtcNow;
                ticket.UpdatedBy = Tenant.UserIdentifier;
                await context.SaveChangesAsync();
            }

            SyncTrigger.TriggerPush("Charge", charge.Id);
            if (ticket?.Status == TicketStatus.Charged)
                SyncTrigger.TriggerPush("ServiceTicket", selectedTicket!.Id);

            // Record timeline events
            await TicketEvents.RecordCharge(selectedTicket!.Id, amount, selectedPaymentMethod.ToString(), Tenant.UserIdentifier, Tenant.StoreId);
            if (ticket?.Status == TicketStatus.Charged)
                await TicketEvents.RecordStatusChange(selectedTicket.Id, TicketStatus.Open, TicketStatus.Charged, Tenant.UserIdentifier, Tenant.StoreId);

            chargeSuccess = true;
            terminalPolling = false;
            lastChargeId = charge.Id;

            // If fully paid, clear selection; otherwise refresh partial state
            if (ticket?.Status == TicketStatus.Charged)
            {
                selectedTicket = null;
                chargeAmount = 0;
                ticketCharges.Clear();
            }
            else
            {
                // Refresh partial payment state
                await SelectTicket(selectedTicket!);
                chargeSuccess = true; // SelectTicket resets this
            }

            await LoadRecentCharges();

            if (module is not null)
            {
                await module.InvokeAsync<bool>("showNotification",
                    "BikePOS", $"Charge of {charge.Amount.ToString("C", culture)} processed by {Tenant.DisplayName ?? "unknown"}.");
            }
        }
        catch
        {
            chargeSuccess = false;
        }
    }

    private async Task LoadRecentCharges()
    {
        using var context = DbFactory.CreateDbContext();
        recentCharges = await context.Charge
            .Include(c => c.ServiceTicket)
            .OrderByDescending(c => c.ChargedAt)
            .Take(10)
            .ToListAsync();
    }

    private void ShowCreateTicket()
    {
        NavigationManager.NavigateTo("/tickets/create");
    }

    [JSInvokable]
    public void OnConnectionStatusChanged(bool online)
    {
        isOnline = online;
        InvokeAsync(StateHasChanged);
    }

    private static string GetStatusBadgeClass(TicketStatus status) => status switch
    {
        TicketStatus.Open => "bg-yellow-100 text-yellow-700",
        TicketStatus.InProgress => "bg-blue-100 text-blue-700",
        TicketStatus.WaitingForParts => "bg-orange-100 text-orange-700",
        TicketStatus.Completed => "bg-green-100 text-green-700",
        TicketStatus.Charged => "bg-purple-100 text-purple-700",
        TicketStatus.Cancelled => "bg-red-100 text-red-700",
        _ => "bg-gray-100 text-gray-700"
    };

    private async Task PrintReceipt()
    {
        if (string.IsNullOrEmpty(lastChargeId)) return;
        receiptData = await ReportSvc.GetReceiptDataAsync(lastChargeId);
        StateHasChanged();
        await Task.Yield();
        if (module is not null)
            await module.InvokeVoidAsync("printReceipt");
    }

    public async ValueTask DisposeAsync()
    {
        pollCts?.Cancel();
        pollCts?.Dispose();
        dotNetRef?.Dispose();
        if (module is not null)
            await module.DisposeAsync();
    }
