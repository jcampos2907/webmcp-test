@page "/"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "SuperAdmin,Admin,Mechanic,Cashier")]
@implements IAsyncDisposable
@using Microsoft.EntityFrameworkCore
@using BikePOS.Models
@using BikePOS.Application.Queries
@inject IJSRuntime JS
@inject IDbContextFactory<BikePOS.Data.BikePosContext> DbFactory
@inject SearchTicketsQueryHandler SearchTicketsHandler
@inject ListCustomersQueryHandler ListCustomersHandler
@inject NavigationManager NavigationManager
@inject ShopCultureService CultureService
@inject TenantContext Tenant

<PageTitle>@L.Pos_Title</PageTitle>

<div class="p-6">
    @* Welcome header *@
    <div class="flex flex-wrap items-center justify-between gap-3 mb-6">
        <div>
            <h1 class="text-2xl font-bold text-gray-800">@L.Home_Welcome, @(Tenant.DisplayName ?? L.Pos_Cashier)</h1>
            <p class="text-sm text-gray-500 mt-0.5">@DateTime.Now.ToString("dddd, d MMMM yyyy", culture)</p>
        </div>
        <div class="flex items-center gap-2 px-3 py-1.5 bg-white border border-gray-200 rounded-full shadow-sm">
            <span class="inline-block w-2.5 h-2.5 rounded-full @(isOnline ? "bg-green-400" : "bg-red-400")"></span>
            <span class="text-xs font-medium text-gray-600">@(isOnline ? L.Pos_Online : L.Pos_Offline)</span>
        </div>
    </div>

    @* KPI tiles *@
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5">
            <div class="flex items-center justify-between">
                <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide">@L.Home_TodayRevenue</p>
                <div class="w-9 h-9 rounded-lg bg-emerald-100 flex items-center justify-center">
                    <i class="fa-solid fa-dollar-sign text-emerald-600"></i>
                </div>
            </div>
            <p class="text-2xl font-bold text-gray-800 mt-2">@todayRevenue.ToString("C", culture)</p>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5">
            <div class="flex items-center justify-between">
                <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide">@L.Home_TodayTransactions</p>
                <div class="w-9 h-9 rounded-lg bg-indigo-100 flex items-center justify-center">
                    <i class="fa-solid fa-receipt text-indigo-600"></i>
                </div>
            </div>
            <p class="text-2xl font-bold text-gray-800 mt-2">@todayTransactions</p>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5">
            <div class="flex items-center justify-between">
                <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide">@L.Home_OpenTickets</p>
                <div class="w-9 h-9 rounded-lg bg-amber-100 flex items-center justify-center">
                    <i class="fa-solid fa-wrench text-amber-600"></i>
                </div>
            </div>
            <p class="text-2xl font-bold text-gray-800 mt-2">@openTicketsCount</p>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5">
            <div class="flex items-center justify-between">
                <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide">@L.Home_ReadyToCharge</p>
                <div class="w-9 h-9 rounded-lg bg-green-100 flex items-center justify-center">
                    <i class="fa-solid fa-circle-check text-green-600"></i>
                </div>
            </div>
            <p class="text-2xl font-bold text-gray-800 mt-2">@readyToChargeCount</p>
        </div>
    </div>

    @* Quick actions *@
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-6">
        <button class="group bg-white rounded-xl shadow-sm border border-gray-200 p-4 hover:border-indigo-400 hover:shadow-md transition text-left"
                @onclick='() => NavigationManager.NavigateTo("/tickets/create")'>
            <div class="w-10 h-10 rounded-lg bg-indigo-100 flex items-center justify-center mb-3 group-hover:bg-indigo-600 transition-colors">
                <i class="fa-solid fa-file-circle-plus text-indigo-600 group-hover:text-white"></i>
            </div>
            <p class="text-sm font-semibold text-gray-800">@L.Home_NewTicket</p>
        </button>
        <button class="group bg-white rounded-xl shadow-sm border border-gray-200 p-4 hover:border-indigo-400 hover:shadow-md transition text-left"
                @onclick='() => NavigationManager.NavigateTo("/tickets")'>
            <div class="w-10 h-10 rounded-lg bg-amber-100 flex items-center justify-center mb-3 group-hover:bg-amber-600 transition-colors">
                <i class="fa-solid fa-list text-amber-600 group-hover:text-white"></i>
            </div>
            <p class="text-sm font-semibold text-gray-800">@L.Home_AllTickets</p>
        </button>
        <button class="group bg-white rounded-xl shadow-sm border border-gray-200 p-4 hover:border-indigo-400 hover:shadow-md transition text-left"
                @onclick='() => NavigationManager.NavigateTo("/customers")'>
            <div class="w-10 h-10 rounded-lg bg-sky-100 flex items-center justify-center mb-3 group-hover:bg-sky-600 transition-colors">
                <i class="fa-solid fa-users text-sky-600 group-hover:text-white"></i>
            </div>
            <p class="text-sm font-semibold text-gray-800">@L.Home_Customers</p>
        </button>
        <button class="group bg-white rounded-xl shadow-sm border border-gray-200 p-4 hover:border-indigo-400 hover:shadow-md transition text-left"
                @onclick='() => NavigationManager.NavigateTo("/reports")'>
            <div class="w-10 h-10 rounded-lg bg-emerald-100 flex items-center justify-center mb-3 group-hover:bg-emerald-600 transition-colors">
                <i class="fa-solid fa-chart-bar text-emerald-600 group-hover:text-white"></i>
            </div>
            <p class="text-sm font-semibold text-gray-800">@L.Home_Reports</p>
        </button>
    </div>

    @* Quick search — tabbed panel *@
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-6">
        <div class="flex items-center justify-between mb-4">
            <h3 class="text-lg font-semibold text-gray-800">@L.Common_Search</h3>
            <div class="flex bg-gray-100 rounded-lg p-1">
                <button class="px-3 py-1 text-xs font-medium rounded-md transition @(searchMode == "ticket" ? "bg-white text-gray-800 shadow-sm" : "text-gray-500")"
                        @onclick='() => searchMode = "ticket"'>
                    @L.Pos_SearchTicket
                </button>
                <button class="px-3 py-1 text-xs font-medium rounded-md transition @(searchMode == "customer" ? "bg-white text-gray-800 shadow-sm" : "text-gray-500")"
                        @onclick='() => searchMode = "customer"'>
                    @L.Pos_SearchCustomer
                </button>
            </div>
        </div>

        @if (searchMode == "ticket")
        {
            <input type="text" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300"
                   placeholder="@L.Pos_SearchTicketPlaceholder"
                   @bind="ticketSearch" @bind:event="oninput" @onkeyup="SearchTickets" />
            @if (searchResults.Any())
            {
                <div class="space-y-2 max-h-48 overflow-y-auto mt-3">
                    @foreach (var ticket in searchResults)
                    {
                        <a href="@($"/tickets/edit?id={ticket.Id}")" class="flex items-center justify-between p-2 bg-gray-50 rounded-lg hover:bg-indigo-50 transition-colors no-underline">
                            <div>
                                <span class="text-sm font-medium text-gray-800">@ticket.TicketDisplay</span>
                                <span class="text-sm text-gray-500 ml-2">@ticket.Component?.Name</span>
                            </div>
                            <span class="text-xs px-2 py-1 rounded-full @GetStatusBadgeClass(ticket.Status)">@ticket.Status</span>
                        </a>
                    }
                </div>
            }
            else if (!string.IsNullOrEmpty(ticketSearch))
            {
                <p class="text-sm text-gray-400 mt-3">@L.Pos_NoTicketsFound</p>
            }
        }
        else
        {
            <input type="text" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300"
                   placeholder="@L.Pos_SearchCustomerPlaceholder"
                   @bind="customerSearch" @bind:event="oninput" @onkeyup="SearchCustomers" />
            @if (customerResults.Any())
            {
                <div class="space-y-2 max-h-48 overflow-y-auto mt-3">
                    @foreach (var customer in customerResults)
                    {
                        <a href="@($"/customers/edit?id={customer.Id}")" class="flex items-center justify-between p-2 bg-gray-50 rounded-lg hover:bg-indigo-50 transition-colors no-underline">
                            <div>
                                <span class="text-sm font-medium text-gray-800">@customer.FullName</span>
                                <span class="text-xs text-gray-400 ml-2">@customer.Phone</span>
                            </div>
                            <span class="text-xs text-gray-500">@customer.Email</span>
                        </a>
                    }
                </div>
            }
        }
    </div>

    @* Recent Charges *@
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        <h3 class="text-lg font-semibold text-gray-800 mb-4">@L.Pos_RecentCharges</h3>
        @if (recentCharges.Any())
        {
            <div class="space-y-2 max-h-64 overflow-y-auto">
                @foreach (var charge in recentCharges)
                {
                    <div class="flex items-center justify-between p-2 bg-gray-50 rounded-lg">
                        <div>
                            <span class="text-sm font-medium text-gray-800">@charge.Amount.ToString("C", culture)</span>
                            <span class="text-xs text-gray-400 ml-2">@(charge.ServiceTicket?.TicketDisplay ?? charge.ServiceTicketId)</span>
                        </div>
                        <div class="text-right">
                            <span class="text-xs px-2 py-1 rounded-full bg-blue-100 text-blue-700">@charge.PaymentMethod</span>
                            <div class="text-xs text-gray-400 mt-1">@charge.ChargedAt.ToLocalTime().ToString("g", culture)</div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <p class="text-sm text-gray-400">@L.Pos_NoCharges</p>
        }
    </div>
</div>

@code {
    [CascadingParameter] public Text L { get; set; } = default!;
    CultureInfo culture = CultureInfo.CurrentCulture;

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    private IJSObjectReference? module;
    private DotNetObjectReference<Home>? dotNetRef;
    private bool isOnline = true;

    // Search
    private string ticketSearch = "";
    private List<ServiceTicket> searchResults = new();
    private string customerSearch = "";
    private List<Customer> customerResults = new();
    private string searchMode = "ticket";

    // Recent charges (read-only)
    private List<Charge> recentCharges = new();

    // Dashboard KPIs
    private decimal todayRevenue;
    private int todayTransactions;
    private int openTicketsCount;
    private int readyToChargeCount;

    protected override async Task OnInitializedAsync()
    {
        culture = await CultureService.GetCultureAsync();

        if (AuthState != null)
        {
            var state = await AuthState;
            Tenant.PopulateFromClaims(state.User);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            module = await JS.InvokeAsync<IJSObjectReference>("import",
                "./Components/Pages/Home.razor.js");

            dotNetRef = DotNetObjectReference.Create(this);
            await module.InvokeVoidAsync("initialize", dotNetRef);
            await module.InvokeVoidAsync("addOnlineStatusListener");

            await LoadRecentCharges();
            await LoadDashboardKpis();

            StateHasChanged();
        }
    }

    private async Task SearchTickets()
    {
        if (string.IsNullOrWhiteSpace(ticketSearch))
        {
            searchResults.Clear();
            return;
        }
        searchResults = await SearchTicketsHandler.HandleAsync(ticketSearch);
    }

    private async Task SearchCustomers()
    {
        if (string.IsNullOrWhiteSpace(customerSearch))
        {
            customerResults.Clear();
            return;
        }
        customerResults = await ListCustomersHandler.HandleAsync(customerSearch);
    }

    private async Task LoadRecentCharges()
    {
        using var context = DbFactory.CreateDbContext();
        recentCharges = await context.Charge
            .Include(c => c.ServiceTicket)
            .OrderByDescending(c => c.ChargedAt)
            .Take(10)
            .ToListAsync();
    }

    private async Task LoadDashboardKpis()
    {
        var todayStart = DateTime.UtcNow.Date;
        var todayEnd = todayStart.AddDays(1);

        using var context = DbFactory.CreateDbContext();

        var todays = await context.Charge
            .Where(c => c.PaymentStatus == PaymentStatus.Completed &&
                        c.ChargedAt >= todayStart && c.ChargedAt < todayEnd)
            .Select(c => c.Amount)
            .ToListAsync();
        todayRevenue = todays.Sum();
        todayTransactions = todays.Count;

        openTicketsCount = await context.ServiceTicket
            .CountAsync(t => t.Status == TicketStatus.Open ||
                             t.Status == TicketStatus.InProgress ||
                             t.Status == TicketStatus.WaitingForParts);

        readyToChargeCount = await context.ServiceTicket
            .CountAsync(t => t.Status == TicketStatus.Completed);
    }

    [JSInvokable]
    public void OnConnectionStatusChanged(bool online)
    {
        isOnline = online;
        InvokeAsync(StateHasChanged);
    }

    private static string GetStatusBadgeClass(TicketStatus status) => status switch
    {
        TicketStatus.Open => "bg-yellow-100 text-yellow-700",
        TicketStatus.InProgress => "bg-blue-100 text-blue-700",
        TicketStatus.WaitingForParts => "bg-orange-100 text-orange-700",
        TicketStatus.Completed => "bg-green-100 text-green-700",
        TicketStatus.Charged => "bg-purple-100 text-purple-700",
        TicketStatus.Cancelled => "bg-red-100 text-red-700",
        _ => "bg-gray-100 text-gray-700"
    };

    public async ValueTask DisposeAsync()
    {
        dotNetRef?.Dispose();
        if (module is not null)
        {
            try { await module.DisposeAsync(); }
            catch (Microsoft.JSInterop.JSDisconnectedException) { }
        }
    }
}
