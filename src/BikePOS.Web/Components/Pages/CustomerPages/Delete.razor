@page "/customers/delete"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "SuperAdmin,Admin")]
@using BikePOS.Models
@using BikePOS.Application.Commands
@using BikePOS.Application.Queries
@inject GetCustomerByIdQueryHandler GetCustomer
@inject DeleteCustomerCommandHandler DeleteHandler
@inject NavigationManager NavigationManager

<PageTitle>@L.Customers_Delete</PageTitle>

<div class="p-6 max-w-lg mx-auto">
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        <h2 class="text-lg font-semibold text-gray-800 mb-4">@L.Customers_Delete</h2>
        @if (customer is null)
        {
            <p class="text-sm text-gray-400">@L.Common_Loading</p>
        }
        else
        {
            <p class="text-sm text-gray-600 mb-4">@L.Customers_ConfirmDelete <strong>@customer.FullName</strong>?</p>
            <dl class="text-sm space-y-1 mb-6">
                <div class="flex gap-2"><dt class="text-gray-500 w-20">@L.Common_Phone</dt><dd class="text-gray-800">@(customer.Phone ?? "—")</dd></div>
                <div class="flex gap-2"><dt class="text-gray-500 w-20">@L.Common_Email</dt><dd class="text-gray-800">@(customer.Email ?? "—")</dd></div>
                <div class="flex gap-2"><dt class="text-gray-500 w-20">@L.Common_City</dt><dd class="text-gray-800">@(customer.City ?? "—")</dd></div>
            </dl>

            <EditForm method="post" Model="customer" OnValidSubmit="DeleteCustomer" FormName="delete" Enhance>
                <button type="submit" class="bg-red-600 hover:bg-red-700 text-white text-sm font-semibold px-5 py-2 rounded-lg transition-colors">
                    @L.Common_Delete
                </button>
                <a href="/customers" class="ml-3 text-sm text-gray-500 hover:text-gray-700">@L.Common_Cancel</a>
            </EditForm>
        }
    </div>
</div>

@code {
    [CascadingParameter] public Text L { get; set; } = default!;
    private Customer? customer;

    [SupplyParameterFromQuery]
    private string Id { get; set; } = "";

    protected override async Task OnInitializedAsync()
    {
        customer = await GetCustomer.HandleAsync(Id);
        if (customer is null) NavigationManager.NotFound();
    }

    private async Task DeleteCustomer()
    {
        await DeleteHandler.HandleAsync(new DeleteCustomerRequest(customer!.Id));
        NavigationManager.NavigateTo("/customers");
    }
}
