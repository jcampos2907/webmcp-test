@page "/mechanics/edit"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "SuperAdmin,Admin")]
@using BikePOS.Models
@using BikePOS.Application.Commands
@using BikePOS.Application.Queries
@inject GetMechanicByIdQueryHandler GetMechanic
@inject UpdateMechanicCommandHandler UpdateHandler
@inject NavigationManager NavigationManager

<PageTitle>@L.Mechanics_Edit</PageTitle>

<h1>@L.Common_Edit</h1>

<h2>@L.Mechanics_Entity</h2>
<hr />
@if (Mechanic is null)
{
    <p><em>@L.Common_Loading</em></p>
}
else
{
    <div class="row">
        <div class="col-md-4">
            <EditForm method="post" Model="Mechanic" OnValidSubmit="UpdateMechanic" FormName="edit" Enhance>
                <DataAnnotationsValidator />
                <ValidationSummary role="alert"/>
                <input type="hidden" name="Mechanic.Id" value="@Mechanic.Id" />
                <div class="mb-3">
                <span class="text-danger">*</span>
                    <label for="name" class="form-label">@L.Common_Name:</label>
                    <InputText id="name" @bind-Value="Mechanic.Name" class="form-control" aria-required="true"/>
                    <ValidationMessage For="() => Mechanic.Name" class="text-danger" />
                </div>
                <div class="mb-3">
                    <label for="phone" class="form-label">@L.Common_Phone:</label>
                    <InputText id="phone" @bind-Value="Mechanic.Phone" class="form-control" />
                    <ValidationMessage For="() => Mechanic.Phone" class="text-danger" />
                </div>
                <div class="mb-3">
                    <label for="email" class="form-label">@L.Common_Email:</label>
                    <InputText id="email" @bind-Value="Mechanic.Email" class="form-control" />
                    <ValidationMessage For="() => Mechanic.Email" class="text-danger" />
                </div>
                <div class="mb-3">
                    <label for="isactive" class="form-label">@L.Common_IsActive:</label>
                    <InputCheckbox id="isactive" @bind-Value="Mechanic.IsActive" class="form-check-input" />
                    <ValidationMessage For="() => Mechanic.IsActive" class="text-danger" />
                </div>
                <button type="submit" class="btn btn-primary">@L.Common_Save</button>
            </EditForm>
        </div>
    </div>
}

<div>
    <a href="/mechanics">@L.Common_BackToList</a>
</div>

@code {
    [CascadingParameter] public Text L { get; set; } = default!;
    [SupplyParameterFromQuery]
    private string Id { get; set; } = "";

    [SupplyParameterFromForm]
    private Mechanic? Mechanic { get; set; }

    protected override async Task OnInitializedAsync()
    {
        Mechanic ??= await GetMechanic.HandleAsync(Id);
        if (Mechanic is null) NavigationManager.NotFound();
    }

    private async Task UpdateMechanic()
    {
        var success = await UpdateHandler.HandleAsync(new UpdateMechanicRequest(
            Mechanic!.Id, Mechanic.Name, Mechanic.Phone,
            Mechanic.Email, Mechanic.IsActive));
        if (!success) NavigationManager.NotFound();
        else NavigationManager.NavigateTo("/mechanics");
    }
}
